<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Mnemo.UI.Services"
             xmlns:vm="using:Mnemo.UI.ViewModels"
             xmlns:components="using:Mnemo.UI.Components"
             x:Class="Mnemo.UI.Components.ToastHost"
             x:DataType="services:ToastService">
    <ItemsControl ItemsSource="{Binding ActiveToasts}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Spacing="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ToastItemViewModel">
                <components:ToastItemView DataContext="{Binding}" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
