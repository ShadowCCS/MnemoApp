<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:vm="using:Mnemo.UI.Components.RightSidebar"
             xmlns:vmroot="using:Mnemo.UI.ViewModels"
             xmlns:markup="using:Mnemo.UI.Markup"
             x:Class="Mnemo.UI.Components.RightSidebar.RightSidebar"
             x:DataType="vm:RightSidebarViewModel"
             x:Name="SidebarRoot">
    <UserControl.Resources>
        <converters:BoolToStreamingIntervalConverter x:Key="BoolToStreamingIntervalConverter"/>
        <converters:NullToBoolConverter x:Key="StringNotEmptyToBoolConverter"/>
        <converters:AssistantModeToLabelConverter x:Key="AssistantModeToLabelConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Button.SuggestionChip">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.PromptActionButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
        </Style>
        
        <Style Selector="Button.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            </Style>
        </Style>

        <!-- Mode dropdown in prompt box: pill-like appearance -->
        <Style Selector="controls|ModernComboBox.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="Border.PulsingDot">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="controls|SvgIcon.ActivePulse">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                </Animation>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
    <Grid IsVisible="{Binding !IsCollapsed}"
          MinWidth="288">
        <Border Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1, 0, 0, 0"
                CornerRadius="15, 0, 0, 15"
                BoxShadow="0 -2 24 0 #08000000"
                MinWidth="276">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Padding="18,14" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SidebarBorderBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Background="{DynamicResource CardAccentBrush}"
                                Padding="10" CornerRadius="10"
                                VerticalAlignment="Center"
                                BoxShadow="0 2 8 0 #15000000">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                              Width="22" Height="22"
                                              Color="{DynamicResource AccentButtonIconBrush}"/>
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{markup:T Ns=Chat, Key=Atlas}"
                                       FontSize="{DynamicResource FontSize.Body.Large}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{markup:T Ns=Chat, Key=AskAnything}"
                                       FontSize="{DynamicResource FontSize.Body.Caption}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button Classes="PromptActionButton"
                                Command="{Binding NewChatCommand}"
                                Padding="6"
                                ToolTip.Tip="{markup:T Ns=Chat, Key=NewChat}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/circle-plus.svg"
                                              Width="18" Height="18"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding ToggleCommand}"
                                ToolTip.Tip="{markup:T Ns=Chat, Key=CloseAssistant}"
                                Padding="6">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                              Width="20" Height="20"
                                              Color="{DynamicResource ChevronSidebarBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages / content area: padding on inner Border so ScrollViewer passes correct width (avoids text crop) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border HorizontalAlignment="Stretch" MinWidth="0" Padding="18,16">
                <ItemsControl ItemsSource="{Binding Messages}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ChatMessage">
                            <Panel Margin="0,0,0,24" MinWidth="0">
                                <!-- Assistant Message -->
                                <Grid ColumnDefinitions="Auto, *" IsVisible="{Binding IsAssistant}" MinWidth="0">
                                    <!-- Icon -->
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" 
                                            Background="{DynamicResource CardAccentBrush}" 
                                            Margin="0,2,12,0" VerticalAlignment="Top"
                                            BoxShadow="0 2 6 0 #15000000">
                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                                          Width="14" Height="14"
                                                          Color="{DynamicResource AccentButtonIconBrush}"/>
                                    </Border>
                                    
                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                        <TextBlock Text="{markup:T Ns=Chat, Key=Atlas}" 
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   FontFamily="{DynamicResource Font.SemiBold}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <!-- Thought Process Panel -->
                                        <Border IsVisible="{Binding HasProcessThreadOrThoughts}"
                                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                CornerRadius="10"
                                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                BorderThickness="1"
                                                Margin="0,6,0,4">
                                            <StackPanel>
                                                <!-- Header bar -->
                                                <Border Padding="12,8">
                                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                                Classes="PulsingDot"
                                                                Background="{DynamicResource ChatProcessStateActiveBrush}" Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding IsStreaming}"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ElapsedText}"
                                                                   IsVisible="{Binding HasElapsedText}"
                                                                   FontFamily="{DynamicResource Font.Monospace}"
                                                                   FontSize="{DynamicResource FontSize.Body.Caption}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding ProcessHeaderText}"
                                                                   FontSize="{DynamicResource FontSize.Body.Caption}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontFamily="{DynamicResource Font.Medium}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <ToggleButton Grid.Column="3"
                                                                      IsChecked="{Binding IsProcessThreadExpanded, Mode=TwoWay}"
                                                                      Background="Transparent"
                                                                      BorderThickness="0"
                                                                      Padding="6,2"
                                                                      MinWidth="0" MinHeight="0"
                                                                      VerticalAlignment="Center"
                                                                      Cursor="Hand">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="{Binding IsProcessThreadExpanded, Converter={x:Static converters:BoolToTextConverter.HideShow}}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontFamily="{DynamicResource Font.Medium}"
                                                                           VerticalAlignment="Center"/>
                                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                                                  Width="12" Height="12"
                                                                                  Color="{DynamicResource TextSecondaryBrush}">
                                                                    <controls:SvgIcon.RenderTransform>
                                                                        <RotateTransform Angle="-90"/>
                                                                    </controls:SvgIcon.RenderTransform>
                                                                </controls:SvgIcon>
                                                            </StackPanel>
                                                        </ToggleButton>
                                                    </Grid>
                                                </Border>

                                                <!-- Collapsible step list -->
                                                <Border IsVisible="{Binding IsProcessThreadExpanded}"
                                                        Padding="12,4,12,8">
                                                    <StackPanel>
                                                        <ItemsControl ItemsSource="{Binding ProcessSteps}" IsVisible="{Binding HasProcessThread}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="vmroot:ChatProcessStepViewModel">
                                                                    <Grid ColumnDefinitions="Auto,*">
                                                                        <Grid Grid.Column="0" RowDefinitions="Auto, *" Width="20" Margin="0,2,8,0" HorizontalAlignment="Center">
                                                                            <Panel Grid.Row="0" Width="20" Height="20">
                                                                                <Panel Width="20" Height="20" IsVisible="{Binding IsComplete}">
                                                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/done-disc.svg"
                                                                                                      Width="16" Height="16"
                                                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                      Color="{DynamicResource ChatProcessStateDoneFillBrush}"/>
                                                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/done-check.svg"
                                                                                                      Width="16" Height="16"
                                                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                      Color="{DynamicResource ChatProcessStateDoneGlyphBrush}"/>
                                                                                </Panel>
                                                                                <controls:SvgIcon Classes="ActivePulse"
                                                                                                  SvgPath="avares://Mnemo.UI/Icons/States/active.svg"
                                                                                                  Width="16" Height="16"
                                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                  Color="{DynamicResource ChatProcessStateActiveBrush}"
                                                                                                  IsVisible="{Binding IsActive}"/>
                                                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/pending.svg"
                                                                                                  Width="16" Height="16"
                                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                  Color="{DynamicResource ChatProcessStatePendingBrush}"
                                                                                                  IsVisible="{Binding IsPending}"/>
                                                                            </Panel>
                                                                            <Border Grid.Row="1" Width="1.5"
                                                                                    Background="{DynamicResource SidebarBorderBrush}"
                                                                                    Margin="0,4,0,0"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Stretch"/>
                                                                        </Grid>
                                                                        <StackPanel Grid.Column="1" Spacing="2" MinWidth="0" Margin="0,0,0,14">
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                       FontFamily="{DynamicResource Font.SemiBold}"
                                                                                       TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding Detail}"
                                                                                       FontSize="{DynamicResource FontSize.Body.Caption}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap"
                                                                                       IsVisible="{Binding HasDetail}"/>
                                                                            <ItemsControl ItemsSource="{Binding ToolCalls}"
                                                                                          IsVisible="{Binding HasToolCalls}"
                                                                                          Margin="0,4,0,0">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate DataType="vmroot:ChatToolCallViewModel">
                                                                                        <Expander Padding="0" MinHeight="0"
                                                                                                  Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                                                  BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                                                  BorderThickness="1"
                                                                                                  CornerRadius="8"
                                                                                                  Margin="0,0,0,4">
                                                                                            <Expander.Header>
                                                                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/external-link.svg"
                                                                                                                      Width="13" Height="13"
                                                                                                                      Color="{DynamicResource TextSecondaryBrush}"/>
                                                                                                    <TextBlock Text="{Binding Name}"
                                                                                                               FontFamily="{DynamicResource Font.Monospace}"
                                                                                                               FontSize="11"
                                                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                                               VerticalAlignment="Center"/>
                                                                                                    <TextBlock Text="{Binding Summary}"
                                                                                                               FontSize="11"
                                                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                                               VerticalAlignment="Center"/>
                                                                                                </StackPanel>
                                                                                            </Expander.Header>
                                                                                            <StackPanel Spacing="6" Margin="12,6,12,10">
                                                                                                <TextBlock Text="Arguments" FontSize="10" FontFamily="{DynamicResource Font.SemiBold}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                                                <TextBlock Text="{Binding Arguments}" FontFamily="{DynamicResource Font.Monospace}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                                                <TextBlock Text="Result" FontSize="10" FontFamily="{DynamicResource Font.SemiBold}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                                                                                <TextBlock Text="{Binding Result}" FontFamily="{DynamicResource Font.Monospace}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                                            </StackPanel>
                                                                                        </Expander>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <components:MarkdownView Source="{Binding Thoughts}"
                                                                                 IsVisible="{Binding IsThinking}"
                                                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                 Margin="0,0,0,4"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Markdown content (throttled when streaming, like Chat module) -->
                                        <components:MarkdownView Source="{Binding Content}"
                                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 StreamingUpdateIntervalMs="{Binding IsStreaming, Converter={StaticResource BoolToStreamingIntervalConverter}}"/>
                                        
                                        <!-- Sources -->
                                        <ItemsControl ItemsSource="{Binding Sources}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="0,0,6,6">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                             <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                              Width="12" Height="12"
                                                                              Color="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Suggestions: stretch to full message width so chips use entire row (demo message) -->
                                        <ItemsControl ItemsSource="{Binding Suggestions}" Margin="0,12,0,0" HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}" 
                                                            Classes="SuggestionChip" Margin="0,0,8,8"
                                                            Command="{Binding $parent[UserControl].DataContext.SuggestionSelectedCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>

                                <!-- User Message -->
                                <Grid IsVisible="{Binding IsUser}" HorizontalAlignment="Right" MaxWidth="280">
                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}" 
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18,18,4,18" 
                                            Padding="14,10"
                                            BoxShadow="0 1 4 0 #05000000">
                                        <TextBlock Text="{Binding Content}" 
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"/>
                                    </Border>
                                </Grid>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </Border>
            </ScrollViewer>

            <!-- Input area -->
            <Border Grid.Row="2" Padding="18,18" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SidebarBorderBrush}"
                    Background="{DynamicResource SidebarBackgroundBrush}">
                <Border Background="{DynamicResource CardBackgroundPrimaryBrush}"
                        CornerRadius="16"
                        BoxShadow="0 4 12 0 #10000000"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        Padding="12,12">
                    <Grid RowDefinitions="Auto, Auto">
                        <!-- Row 0: Text Input only -->
                        <TextBox x:Name="InputBox"
                                 Grid.Row="0" 
                                 Classes="TransparentBackground"
                                 Watermark="{markup:T Ns=Chat, Key=AskPlaceholder}"
                                 AcceptsReturn="False"
                                 TextWrapping="Wrap"
                                 MinHeight="40"
                                 MaxHeight="120"
                                 BorderThickness="0"
                                 Background="{DynamicResource TextControlTransparentBackgroundBrush}"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4"
                                 Margin="0,0,0,8"/>

                        <!-- Bottom Row: Attach, Mode, (space), Mic, Send -->
                        <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *, Auto, Auto" MinWidth="0">
                            <Button Grid.Column="0" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=AddAttachment}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/upload.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                            <controls:ModernComboBox Grid.Column="1"
                                                      Classes="PromptPill"
                                                      ItemsSource="{Binding AssistantModes}"
                                                      SelectedItem="{Binding SelectedAssistantMode}"
                                                      MinWidth="80"
                                                      Margin="0,0,6,0"
                                                      ToolTip.Tip="{markup:T Ns=Chat, Key=AssistantMode}">
                                <controls:ModernComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource AssistantModeToLabelConverter}}"
                                                   FontSize="{DynamicResource FontSize.Body.Caption}"
                                                   FontFamily="{DynamicResource Font.Medium}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </controls:ModernComboBox.ItemTemplate>
                            </controls:ModernComboBox>
                            <Border Grid.Column="2" MinWidth="0"/>
                            <Button Grid.Column="3" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=VoiceInput}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/microphone.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                            <Button Grid.Column="4"
                                    Command="{Binding SendCommand}"
                                    IsVisible="{Binding !IsBusy}"
                                    Background="{DynamicResource CardAccentBrush}"
                                    Foreground="{DynamicResource AccentButtonIconBrush}"
                                    Padding="8"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    Width="32" Height="32"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=SendEnter}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource AccentButtonIconBrush}">
                                    <controls:SvgIcon.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </controls:SvgIcon.RenderTransform>
                                </controls:SvgIcon>
                            </Button>
                            <Button Grid.Column="4"
                                    Command="{Binding StopCommand}"
                                    IsVisible="{Binding IsBusy}"
                                    Background="{DynamicResource StopButtonBackgroundBrush}"
                                    Foreground="{DynamicResource StopButtonForegroundBrush}"
                                    Padding="8"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    Width="32" Height="32"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=Stop}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-pause.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource StopButtonForegroundBrush}"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
