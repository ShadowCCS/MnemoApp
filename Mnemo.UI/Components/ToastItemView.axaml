<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:vm="using:Mnemo.UI.ViewModels"
             x:Class="Mnemo.UI.Components.ToastItemView"
             x:DataType="vm:ToastItemViewModel">
    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NotEmptyToVisible" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ProgressBar.toast-timer-info">
            <Setter Property="Foreground" Value="{DynamicResource ToastAccentInfoBrush}" />
        </Style>
        <Style Selector="ProgressBar.toast-timer-success">
            <Setter Property="Foreground" Value="{DynamicResource ToastAccentSuccessBrush}" />
        </Style>
        <Style Selector="ProgressBar.toast-timer-warning">
            <Setter Property="Foreground" Value="{DynamicResource ToastAccentWarningBrush}" />
        </Style>
        <Style Selector="ProgressBar.toast-timer-action">
            <Setter Property="Foreground" Value="{DynamicResource ToastAccentActionBrush}" />
        </Style>
        <Style Selector="ProgressBar.toast-timer-task">
            <Setter Property="Foreground" Value="{DynamicResource ToastAccentTaskBrush}" />
        </Style>
    </UserControl.Styles>
    <Border x:Name="RootBorder"
            MinWidth="320"
            MaxWidth="420"
            Background="{DynamicResource ToastBackgroundPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            BoxShadow="0 1 3 0 #12000000"
            ClipToBounds="True">
        <Border.Transitions>
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut" />
            </Transitions>
        </Border.Transitions>
        <Grid RowDefinitions="*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="4,Auto,*">
                <Panel Grid.Column="0" Width="4">
                    <Border Background="{DynamicResource ToastAccentInfoBrush}" IsVisible="{Binding IsInfo}" />
                    <Border Background="{DynamicResource ToastAccentSuccessBrush}" IsVisible="{Binding IsSuccess}" />
                    <Border Background="{DynamicResource ToastAccentWarningBrush}" IsVisible="{Binding IsWarning}" />
                    <Border Background="{DynamicResource ToastAccentActionBrush}" IsVisible="{Binding IsAction}" />
                    <Border Background="{DynamicResource ToastAccentTaskBrush}" IsVisible="{Binding IsTask}" />
                </Panel>
                <Border Grid.Column="1"
                        Width="40"
                        Height="40"
                        Margin="12,14,0,14"
                        CornerRadius="10"
                        VerticalAlignment="Top">
                    <Panel>
                        <Border Background="{DynamicResource ToastIconBadgeInfoBrush}" IsVisible="{Binding IsInfo}" CornerRadius="10" />
                        <Border Background="{DynamicResource ToastIconBadgeSuccessBrush}" IsVisible="{Binding IsSuccess}" CornerRadius="10" />
                        <Border Background="{DynamicResource ToastIconBadgeWarningBrush}" IsVisible="{Binding IsWarning}" CornerRadius="10" />
                        <Border Background="{DynamicResource ToastIconBadgeActionBrush}" IsVisible="{Binding IsAction}" CornerRadius="10" />
                        <Border Background="{DynamicResource ToastIconBadgeTaskBrush}" IsVisible="{Binding IsTask}" CornerRadius="10" />
                        <controls:SvgIcon SvgPath="{Binding IconSvgPath}"
                                          Width="22"
                                          Height="22"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          PreserveSvgColors="True" />
                    </Panel>
                </Border>
                <Grid Grid.Column="2" Margin="12,12,12,12" RowDefinitions="Auto,Auto,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                   Foreground="{DynamicResource ToastTitleColorBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Top" />
                        <Button Grid.Column="1"
                                Command="{Binding DismissCommand}"
                                Background="{DynamicResource ToastDismissButtonBackgroundBrush}"
                                Foreground="{DynamicResource ToastDismissButtonForegroundBrush}"
                                BorderThickness="0"
                                Padding="10,4"
                                CornerRadius="14"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/square-rounded-x.svg"
                                              Color="{DynamicResource ToastDismissButtonForegroundBrush}"
                                              Width="14"
                                              Height="14" />
                        </Button>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding Description}"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource ToastDescriptionColorBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               IsVisible="{Binding Description, Converter={StaticResource NotEmptyToVisible}}" />
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8"
                                Margin="0,10,0,0"
                                IsVisible="{Binding HasAnyAction}">
                        <Button Content="{Binding SecondaryActionLabel}"
                                Command="{Binding SecondaryActionCommand}"
                                IsVisible="{Binding HasSecondaryAction}"
                                Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                                Foreground="{DynamicResource SecondaryButtonTextColorBrush}"
                                BorderThickness="0"
                                Padding="12,6"
                                CornerRadius="8"
                                FontSize="{DynamicResource FontSize.Caption}" />
                        <Button Content="{Binding PrimaryActionLabel}"
                                Command="{Binding PrimaryActionCommand}"
                                IsVisible="{Binding HasPrimaryAction}"
                                Background="{DynamicResource InstallButtonBackgroundBrush}"
                                Foreground="{DynamicResource InstallButtonTextColorBrush}"
                                BorderThickness="0"
                                Padding="12,6"
                                CornerRadius="8"
                                FontSize="{DynamicResource FontSize.Caption}" />
                    </StackPanel>
                </Grid>
            </Grid>
            <ProgressBar x:Name="ToastTimerBar"
                         Grid.Row="1"
                         IsVisible="{Binding ShowTimerBar}"
                         Value="{Binding TimerProgress}"
                         Maximum="1"
                         Minimum="0"
                         Height="3"
                         MinHeight="3"
                         MaxHeight="3"
                         Padding="0"
                         CornerRadius="0"
                         Background="{DynamicResource ToastTimerTrackBrush}"
                         VerticalAlignment="Bottom" />
        </Grid>
    </Border>
</UserControl>
