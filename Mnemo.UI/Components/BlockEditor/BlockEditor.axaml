<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockEditor"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Mnemo.UI.Components.BlockEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:CompileBindings="False"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    DragDrop.AllowDrop="True"
    Background="Transparent"
    VerticalAlignment="Stretch"
    ClipToBounds="False">
    <Grid Background="Transparent" Cursor="IBeam">
        <Border Background="Transparent" ClipToBounds="False" Padding="32,0,32,0" DragDrop.AllowDrop="True">
            <Grid Background="Transparent">
                <Grid x:Name="EditorRoot" RowDefinitions="Auto,*" Background="Transparent" ClipToBounds="False">
                    <ItemsControl x:Name="BlocksItemsControl" Grid.Row="0" ItemsSource="{Binding Blocks}" Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter">
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:EditableBlock />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Hit target below last block; keep modest so the page does not show a huge empty band. -->
                    <Border x:Name="BelowBlocksArea" Grid.Row="1" MinHeight="56" Background="Transparent" DragDrop.AllowDrop="True" />
                </Grid>
                <!-- Overlay inside padded Border so (0,0) = content area; selection box coords match GetPosition(overlay). -->
                <local:LayoutOverlayPanel x:Name="SelectionBoxOverlay" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border
                        x:Name="SelectionBoxBorder"
                        Background="{DynamicResource AccentPrimaryBrush}"
                        Opacity="0.15"
                        BorderBrush="{DynamicResource AccentPrimaryBrush}"
                        BorderThickness="1"
                        IsVisible="False"
                        IsHitTestVisible="False" />
                </local:LayoutOverlayPanel>
                <local:LayoutOverlayPanel x:Name="BlockDragGhostOverlay" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Grid>
        </Border>
    </Grid>
</UserControl>






