<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.EditableBlock"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Mnemo.UI.Components.BlockEditor"
    xmlns:components="using:Mnemo.UI.Components.BlockEditor.BlockComponents"
    x:CompileBindings="False"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <components:BlockTypeToComponentConverter x:Key="BlockTypeConverter" />
        <local:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter" />
    </UserControl.Resources>
    <UserControl.Styles>
        <!-- Avoid stretching the editor to the grid row: text draws at y=0 and looked vertically mis-centered. -->
        <Style Selector="local|RichTextEditor">
            <Setter Property="VerticalAlignment" Value="Top" />
            <!-- ~1 line; MinHeight tracks body size (16px) without forcing excess row height. -->
            <Setter Property="MinHeight" Value="22" />
        </Style>
    </UserControl.Styles>
    <Grid>
        <!-- Horizontal inset + modest vertical padding; Spacing on editor ItemsControl separates blocks. -->
        <Border
            x:Name="BlockContainer"
            Padding="8,4"
            CornerRadius="4"
            Background="Transparent"
            DragDrop.AllowDrop="True"
            PointerEntered="BlockContainer_PointerEntered"
            PointerExited="BlockContainer_PointerExited">
        <Grid
            x:Name="BlockLayoutGrid"
            ColumnDefinitions="Auto,Auto,*">
            <!-- Insert block below -->
            <Border
                x:Name="AddBlockBelowBorder"
                Grid.Column="0"
                Margin="0,0,2,0"
                MinWidth="26"
                MinHeight="26"
                Padding="3"
                VerticalAlignment="Top"
                ClipToBounds="True"
                CornerRadius="4"
                Cursor="Hand"
                Background="Transparent"
                Tag="AddBlockBelow"
                PointerEntered="BlockGutterBorder_PointerEntered"
                PointerExited="BlockGutterBorder_PointerExited"
                Tapped="AddBlockBelow_Tapped">
                <!-- Path (not SvgIcon): custom Skia SVG draw + opacity caused partial invalidation and stale pixels between blocks. -->
                <Path
                    x:Name="AddBlockBelowIcon"
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Opacity="0"
                    Stretch="None"
                    Stroke="{DynamicResource TextTertiaryBrush}"
                    StrokeLineCap="Round"
                    StrokeThickness="2"
                    Data="M 8 3.5 L 8 12.5 M 3.5 8 L 12.5 8" />
            </Border>
            <!--  Drag Handle  -->
            <Border
                x:Name="DragHandleBorder"
                Grid.Column="1"
                Margin="0,0,2,0"
                MinWidth="26"
                MinHeight="26"
                Padding="3"
                VerticalAlignment="Top"
                ClipToBounds="True"
                CornerRadius="4"
                Cursor="Hand"
                Background="Transparent"
                Tag="DragHandle"
                PointerEntered="BlockGutterBorder_PointerEntered"
                PointerExited="BlockGutterBorder_PointerExited"
                PointerPressed="DragHandle_PointerPressed">
                <Path
                    x:Name="DragHandleGripPath"
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Opacity="0"
                    Data="M9 5L9 7L7 7L7 5L9 5ZM11 5L11 7L13 7L13 5L11 5ZM9 9L9 11L7 11L7 9L9 9ZM11 9L11 11L13 11L13 9L11 9ZM9 13L9 15L7 15L7 13L9 13ZM11 13L11 15L13 15L13 13L11 13Z"
                    Fill="{DynamicResource TextControlForeground}"
                    Stretch="Uniform" />
            </Border>

            <!--  Block Content: left-aligned so selection hugs content width (image blocks align via EditableBlock.HorizontalAlignment).  -->
            <Border
                x:Name="BlockContentChrome"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="4">
                <Border.Background>
                    <MultiBinding Converter="{StaticResource BoolToSelectionBrushConverter}">
                        <Binding Path="IsSelected" />
                        <Binding RelativeSource="{RelativeSource Self}" Path="." />
                    </MultiBinding>
                </Border.Background>
                <!-- Stretch vertically was expanding RichTextEditor to the full row height while glyphs stay at y=0. -->
                <ContentControl
                    x:Name="BlockContentControl"
                    VerticalContentAlignment="Top"
                    Content="{Binding Type, Converter={StaticResource BlockTypeConverter}}"
                    DataContext="{Binding}" />
            </Border>
        </Grid>
    </Border>
        <!-- Vertical split-into-columns cue (horizontal reorder line lives on BlockEditor overlay). -->
        <Border
            x:Name="DropIndicatorLineVerticalLeft"
            Width="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Background="{DynamicResource BlockEditorDropLineBrush}"
            CornerRadius="1"
            IsHitTestVisible="False"
            IsVisible="False" />
        <Border
            x:Name="DropIndicatorLineVerticalRight"
            Width="3"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Background="{DynamicResource BlockEditorDropLineBrush}"
            CornerRadius="1"
            IsHitTestVisible="False"
            IsVisible="False" />
    </Grid>
</UserControl>






