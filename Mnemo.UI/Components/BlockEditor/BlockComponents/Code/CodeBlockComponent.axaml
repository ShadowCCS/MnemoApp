<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Code.CodeBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Mnemo.UI.Controls"
    HorizontalAlignment="Stretch"
    x:CompileBindings="False">
    <Border
        x:Name="RootBorder"
        HorizontalAlignment="Stretch"
        Background="{DynamicResource TextControlBackgroundBrush}"
        BorderBrush="{DynamicResource RichTextSeparationLineBrush}"
        BorderThickness="1"
        CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
            <!-- Header: language dropdown | spacer | Copy -->
            <Border
                Grid.Row="0"
                Background="{DynamicResource TextControlBackgroundBrush}"
                BorderBrush="{DynamicResource NotesEditorSeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <controls:ModernComboBox
                        x:Name="LanguageCombo"
                        Grid.Column="0"
                        Width="272"
                        MinWidth="200"
                        MaxWidth="360"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="12"
                        PlaceholderText="Language" />
                    <TextBlock
                        x:Name="LanguageReadLabel"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextTertiaryBrush}"
                        IsVisible="False"
                        TextWrapping="NoWrap" />
                    <Button
                        x:Name="CopyButton"
                        Grid.Column="2"
                        Padding="10,6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Background="{DynamicResource TextControlBackgroundBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderBrush="{DynamicResource RichTextSeparationLineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Content="Copy" />
                </Grid>
            </Border>

            <!-- Body: line gutter + horizontal scroll for code; vertical scroll wraps both -->
            <ScrollViewer
                x:Name="BodyScroll"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                MinHeight="120"
                MaxHeight="480"
                Background="{DynamicResource TextControlBackgroundBrush}">
                <Grid ColumnDefinitions="Auto,*">
                    <Border
                        Grid.Column="0"
                        Width="48"
                        MinHeight="120"
                        VerticalAlignment="Stretch"
                        Background="{DynamicResource NotesEditorSeparatorBrush}"
                        BorderBrush="{DynamicResource RichTextSeparationLineBrush}"
                        BorderThickness="0,0,1,0">
                        <TextBlock
                            x:Name="LineNumbersBlock"
                            Padding="6,8,8,10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                            FontSize="13"
                            LineHeight="20"
                            Foreground="{DynamicResource TextTertiaryBrush}"
                            TextAlignment="Right"
                            TextWrapping="NoWrap" />
                    </Border>
                    <ScrollViewer
                        x:Name="CodeScroll"
                        Grid.Column="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled"
                        SizeChanged="CodeScroll_SizeChanged">
                        <Grid
                            x:Name="CodeEditorHost"
                            MinHeight="120"
                            MinWidth="200"
                            HorizontalAlignment="Left">
                            <controls:TextSelectionBackgroundLayer
                                x:Name="SelectionBackground"
                                ZIndex="0"
                                IsHitTestVisible="False"
                                FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                FontSize="13"
                                LineHeight="20"
                                SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
                                TextPadding="10,8,10,10"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                x:Name="HighlightBlock"
                                ZIndex="1"
                                Padding="10,8,10,10"
                                HorizontalAlignment="Left"
                                FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                FontSize="13"
                                LineHeight="20"
                                TextWrapping="NoWrap"
                                Foreground="{DynamicResource SyntaxCodeDefaultBrush}"
                                IsHitTestVisible="False" />
                            <TextBox
                                x:Name="CodeEditor"
                                ZIndex="2"
                                AcceptsReturn="True"
                                Padding="10,8,10,10"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                FontSize="13"
                                LineHeight="20"
                                Foreground="Transparent"
                                CaretBrush="{DynamicResource TextControlForegroundBrush}"
                                SelectionBrush="Transparent"
                                SelectionForegroundBrush="Transparent"
                                Text="{Binding Content, Mode=TwoWay}"
                                TextWrapping="NoWrap"
                                PlaceholderText="{Binding Watermark}" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
