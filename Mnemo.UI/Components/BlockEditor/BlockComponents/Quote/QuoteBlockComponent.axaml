<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Quote.QuoteBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:Mnemo.UI.Components.BlockEditor"
    x:CompileBindings="False">
    <Grid ColumnDefinitions="3,*">
        <Border
            Grid.Column="0"
            Width="3"
            Margin="0,4,0,4"
            VerticalAlignment="Stretch"
            Background="{DynamicResource QuoteLineBrush}" />
        <Border
            Grid.Column="1"
            Padding="12,4,0,4"
            Background="Transparent">
            <editor:RichTextEditor
                x:Name="Editor"
                MinWidth="200"
                HorizontalAlignment="Stretch"
                FontSize="14"
                Foreground="{DynamicResource TextPrimaryBrush}"
                CaretBrush="{DynamicResource TextPrimaryBrush}"
                SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
                Opacity="0.8"
                Watermark="{Binding Watermark}" />
        </Border>
    </Grid>
</UserControl>
