<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Page.PageBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Mnemo.UI.Controls"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="Button.page-block-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.page-block-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        </Style>
    </UserControl.Styles>
    <Button
        x:Name="OpenPageButton"
        Classes="page-block-card"
        MinHeight="48"
        Click="OpenPageButton_Click">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <Border
                Grid.Column="0"
                Width="32"
                Height="32"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="6">
                <controls:SvgIcon
                    Width="18"
                    Height="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Color="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg" />
            </Border>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="2"
                HorizontalAlignment="Stretch">
                <TextBlock
                    x:Name="TitleText"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    Text="{Binding ReferencedNoteTitle}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    Text="{Binding PageBlockSubtitle}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
            </StackPanel>
            <controls:SvgIcon
                Grid.Column="2"
                Width="16"
                Height="16"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Color="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg" />
        </Grid>
    </Button>
</UserControl>
