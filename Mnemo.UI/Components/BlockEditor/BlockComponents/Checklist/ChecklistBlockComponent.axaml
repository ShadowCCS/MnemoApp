<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Checklist.ChecklistBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:Mnemo.UI.Components.BlockEditor"
    x:CompileBindings="False">
    <Grid ColumnDefinitions="Auto,*">
        <CheckBox
            Grid.Column="0"
            Margin="0,2,8,0"
            IsChecked="{Binding IsChecked, Mode=TwoWay}"
            IsThreeState="False"
            MinHeight="20"
            VerticalAlignment="Top"
            Cursor="Hand" />
        <editor:RichTextEditor
            x:Name="Editor"
            Grid.Column="1"
            MinWidth="200"
            HorizontalAlignment="Stretch"
            FontSize="14"
            Foreground="{DynamicResource TextPrimaryBrush}"
            CaretBrush="{DynamicResource TextPrimaryBrush}"
            SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
            Watermark="{Binding Watermark}" />
    </Grid>
</UserControl>
