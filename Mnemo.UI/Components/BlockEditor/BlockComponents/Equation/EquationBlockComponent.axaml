<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Equation.EquationBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Mnemo.UI.Controls"
    x:CompileBindings="False"
    HorizontalAlignment="Left">

    <!-- Hug rendered width (like Notion block math); stretch made selection chrome span the full note width. -->
    <Border x:Name="EquationHost"
            Background="Transparent"
            Cursor="Hand"
            Focusable="True"
            MinHeight="32"
            Padding="8,6"
            HorizontalAlignment="Left">
        <Panel>
            <!-- Rendered LaTeX preview (shown when equation is non-empty) -->
            <ContentControl x:Name="RenderedContent"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            VerticalAlignment="Center" />

            <!-- Empty placeholder (shown when no equation yet) -->
            <TextBlock x:Name="EmptyPlaceholder"
                       IsVisible="False"
                       FontSize="14"
                       FontStyle="Italic"
                       Opacity="0.5"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       VerticalAlignment="Center" />

            <!-- Error display (shown on parse failure) -->
            <TextBlock x:Name="ErrorDisplay"
                       IsVisible="False"
                       FontSize="12"
                       Foreground="{DynamicResource DangerBrush}"
                       VerticalAlignment="Center" />
        </Panel>
    </Border>
</UserControl>
