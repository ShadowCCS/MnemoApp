<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.BulletList.BulletListBlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:Mnemo.UI.Components.BlockEditor"
    x:CompileBindings="False">
    <Grid ColumnDefinitions="Auto,*">
        <TextBlock
            Grid.Column="0"
            Margin="0,0,8,0"
            FontSize="16"
            Text="•"
            VerticalAlignment="Top" />
        <editor:RichTextEditor
            x:Name="Editor"
            Grid.Column="1"
            MinWidth="200"
            HorizontalAlignment="Stretch"
            FontSize="16"
            Foreground="{DynamicResource TextPrimaryBrush}"
            CaretBrush="{DynamicResource TextPrimaryBrush}"
            SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
            Watermark="{Binding Watermark}" />
    </Grid>
</UserControl>
