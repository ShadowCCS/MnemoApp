<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockComponents.Heading4.Heading4BlockComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editor="using:Mnemo.UI.Components.BlockEditor"
    x:CompileBindings="False">
    <editor:RichTextEditor
        x:Name="Editor"
        MinWidth="200"
        HorizontalAlignment="Stretch"
        FontSize="16"
        FontWeight="SemiBold"
        Foreground="{DynamicResource TextPrimaryBrush}"
        CaretBrush="{DynamicResource TextPrimaryBrush}"
        SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
        Watermark="{Binding Watermark}" />
</UserControl>
