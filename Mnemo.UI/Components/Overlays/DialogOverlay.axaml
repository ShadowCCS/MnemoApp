<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Mnemo.UI.Components.Overlays"
             xmlns:conv="using:Mnemo.UI.Converters"
             xmlns:controls="using:Mnemo.UI.Controls"
             x:Class="Mnemo.UI.Components.Overlays.DialogOverlay"
             x:DataType="local:DialogOverlay">
  <UserControl.Resources>
    <conv:NullToBoolConverter x:Key="NullToBoolConverter" />
  </UserControl.Resources>
  <Border Background="{DynamicResource OverlayBackgroundBrush}"
          BorderBrush="{DynamicResource IconsSeparationBarBrush}"
          BorderThickness="1"
          CornerRadius="12"
          Padding="24"
          MinWidth="400"
          MaxWidth="520">
    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding Title}"
                   FontSize="{DynamicResource FontSize.Heading4}" 
                   FontFamily="{DynamicResource Font.Bold}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   IsVisible="{Binding Title, Converter={StaticResource NullToBoolConverter}}"/>
        <Button Grid.Column="1" Classes="ghost" Command="{Binding CloseCommand}" Padding="4" Margin="0,-4,-4,0">
          <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg" Width="20" Height="20" />
        </Button>
      </Grid>
      
      <TextBlock Grid.Row="1"
                  Text="{Binding Description}"
                  FontFamily="{DynamicResource Font.Medium}"
                  FontSize="{DynamicResource FontSize.Body.Small}"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"
                 IsVisible="{Binding Description, Converter={StaticResource NullToBoolConverter}}"/>

      <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
        <Button Content="{Binding SecondaryText}"
                Classes="secondary"
                Command="{Binding SecondaryCommand}"
                IsVisible="{Binding SecondaryText, Converter={StaticResource NullToBoolConverter}}"/>
        <Button Content="{Binding PrimaryText}"
                Classes="destructive"
                Command="{Binding PrimaryCommand}"
                IsVisible="{Binding PrimaryText, Converter={StaticResource NullToBoolConverter}}"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>







