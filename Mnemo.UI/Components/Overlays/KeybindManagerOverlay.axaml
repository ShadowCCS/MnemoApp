<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Components.Overlays"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:converters="using:Mnemo.UI.Converters"
             x:Class="Mnemo.UI.Components.Overlays.KeybindManagerOverlay"
             x:DataType="vm:KeybindManagerOverlayViewModel"
             Width="720"
             MinWidth="560"
             Height="600"
             MinHeight="480"
             MaxHeight="720">
    <UserControl.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegation"/>
        <converters:BoolToDoubleConverter x:Key="BoolToDoubleConverter"/>
        <DataTemplate x:Key="ShortcutPieceTemplate" x:DataType="vm:ShortcutDisplayPieceVm">
            <Panel>
                <Border IsVisible="{Binding IsKeyPill}"
                        CornerRadius="4"
                        Padding="8,4"
                        Background="{DynamicResource CardBackgroundPrimaryBrush}"
                        BorderBrush="{DynamicResource TextFadedBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding Text}"
                               FontSize="11"
                               FontFamily="{DynamicResource Font.Medium}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                <TextBlock IsVisible="{Binding IsThenLabel}"
                           Text="{Binding Text}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="2,0"/>
                <TextBlock IsVisible="{Binding IsAlternativeSeparator}"
                           Text="{Binding Text}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="4,0"/>
            </Panel>
        </DataTemplate>
    </UserControl.Resources>
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            CornerRadius="12"
            Padding="20"
            BoxShadow="0 8 32 0 #40000000">
        <Grid>
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="0">
                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0"
                               Text="{Binding OverlayTitle}"
                               FontSize="18"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Padding="8,4"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnCloseClick"
                            ToolTip.Tip="Close"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding OverlaySubtitle}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <!-- Search + filters -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="0,0,0,12">
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchQuery}"
                             PlaceholderText="{Binding SearchWatermark}"
                             MinHeight="36"/>
                    <ComboBox Grid.Column="1"
                              MinWidth="160"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding ModuleFilterOptions}"
                              SelectedItem="{Binding SelectedModuleFilter}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:KeybindModuleFilterOption">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{DynamicResource ComboBoxForegroundBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.SelectionBoxItemTemplate>
                            <DataTemplate x:DataType="vm:KeybindModuleFilterOption">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{DynamicResource ComboBoxForegroundBrush}"/>
                            </DataTemplate>
                        </ComboBox.SelectionBoxItemTemplate>
                    </ComboBox>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding ShowConflictsOnly}"
                              VerticalAlignment="Center"
                              Content="{Binding ConflictsOnlyLabel}"/>
                </Grid>

                <!-- Conflicts -->
                <Border Grid.Row="3"
                        IsVisible="{Binding HasConflicts}"
                        Background="{DynamicResource CardBackgroundSecondaryBrush}"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding ConflictsHeader}"
                                   FontFamily="{DynamicResource Font.Medium}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ListBox ItemsSource="{Binding Conflicts}"
                                 Background="Transparent"
                                 MaxHeight="88">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeybindConflictRowVm">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{Binding Severity}"/><Run Text=": "/><Run Text="{Binding Message}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="4,0,12,8"
                              Margin="0,2,0,0">
                    <ItemsControl ItemsSource="{Binding ModuleSections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:KeybindModuleSectionVm">
                                <StackPanel Margin="0,0,0,20">
                                    <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ModuleHeaderUpper}"
                                                   FontSize="11"
                                                   FontFamily="{DynamicResource Font.SemiBold}"
                                                   LetterSpacing="0.8"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                Height="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource TextFadedBrush}"
                                                Opacity="0.35"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:KeybindCategorySectionVm">
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding CategoryTitle}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               Margin="0,0,0,6"/>
                                                    <ItemsControl ItemsSource="{Binding Rows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:KeybindActionRowVm">
                                                                <Border Margin="0,0,0,6"
                                                                        Padding="10,8"
                                                                        CornerRadius="8"
                                                                        Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                                        Classes="keybind-action-row"
                                                                        Opacity="{Binding Enabled, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter=1|0.52}">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border.keybind-row-edit">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                        </Style>
                                                                        <Style Selector="Border.keybind-action-row:pointerover Border.keybind-row-edit">
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                            <Setter Property="IsHitTestVisible" Value="True"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <Grid ColumnDefinitions="*,Auto"
                                                                          ColumnSpacing="16">
                                                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontSize="13"
                                                                                       FontFamily="{DynamicResource Font.Medium}"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                            <TextBlock Text="{Binding DetailLine}"
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                                                       TextWrapping="Wrap"
                                                                                       IsVisible="{Binding HasDetailLine}"/>
                                                                            <TextBlock Text="{Binding ActionId}"
                                                                                       FontSize="10"
                                                                                       Foreground="{DynamicResource TextFadedBrush}"
                                                                                       Opacity="0.85"
                                                                                       IsVisible="{Binding ShowDeveloperActionId}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1"
                                                                                    Orientation="Horizontal"
                                                                                    Spacing="4"
                                                                                    VerticalAlignment="Center"
                                                                                    HorizontalAlignment="Right">
                                                                            <ItemsControl ItemsSource="{Binding ShortcutStrip}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <StaticResource ResourceKey="ShortcutPieceTemplate"/>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                            <Panel IsVisible="{Binding IsShortcutEditable}"
                                                                                   Width="28"
                                                                                   Height="28">
                                                                                <Border Classes="keybind-row-edit"
                                                                                        Tag="{Binding ActionId}"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        VerticalAlignment="Stretch"
                                                                                        Padding="0"
                                                                                        Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                                        BorderBrush="{DynamicResource TextFadedBrush}"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="6"
                                                                                        ToolTip.Tip="{Binding EditShortcutToolTip}"
                                                                                        Cursor="Hand"
                                                                                        Tapped="OnEditShortcutTapped">
                                                                                    <TextBlock Text="✎"
                                                                                               FontSize="13"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                                </Border>
                                                                            </Panel>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
                    <TextBlock Grid.Column="0"
                               Text="{Binding FooterStatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding CloseLabel}" Click="OnCloseClick"/>
                        <Button Content="{Binding ResetAllLabel}" Command="{Binding ResetAllCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Shortcut editor: full-area transparent layer blocks clicks to the list; no dimmed backdrop. -->
            <Panel IsVisible="{Binding IsShortcutEditorOpen}" ZIndex="20">
                <Border Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
                <Border Margin="20,28"
                        Padding="0"
                        MaxWidth="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource OverlayBackgroundBrush}"
                        BorderBrush="{DynamicResource TextFadedBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        BoxShadow="0 6 20 0 #28000000">
                    <Grid RowDefinitions="Auto,1,Auto,Auto,Auto,Auto" RowSpacing="0">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="18,16,14,12">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding EditorActionTitle}"
                                           FontSize="15"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding EditorPressSubtitle}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Padding="8,4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnEditorShortcutCancelClick"
                                    VerticalAlignment="Top">
                                <TextBlock Text="✕" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Height="1"
                                Margin="18,0"
                                Background="{DynamicResource TextFadedBrush}"
                                Opacity="0.25"/>

                        <Border x:Name="KeyCaptureHost"
                                Grid.Row="2"
                                Margin="18,14,18,0"
                                MinHeight="108"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource TextFadedBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                Focusable="True"
                                IsEnabled="{Binding EditorCaptureEnabled}"
                                KeyDown="OnShortcutEditorCaptureKeyDown">
                            <Grid Margin="14,12">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6"
                                            IsVisible="{Binding EditorAwaitingCapture}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="6">
                                        <TextBlock Text="⌨"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding EditorWaitingForInput}"
                                                   FontSize="12"
                                                   FontFamily="{DynamicResource Font.Medium}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding EditorCaptureHint}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="340"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding EditorPendingShortcutStrip}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              IsVisible="{Binding EditorAwaitingCapture, Converter={StaticResource BoolNegation}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <StaticResource ResourceKey="ShortcutPieceTemplate"/>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="18,12,18,0" ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding EditorCurrentShortcutLabel}"
                                       FontSize="10"
                                       LetterSpacing="0.6"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding EditorCurrentShortcutStrip}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="ShortcutPieceTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <CheckBox Grid.Row="4"
                                  Margin="18,14,18,0"
                                  IsVisible="{Binding EditorCanDisableShortcut}"
                                  IsChecked="{Binding EditorDisableShortcut, Mode=TwoWay}"
                                  Content="{Binding EditorDisableLabel}"/>

                        <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="18,16,18,16">
                            <Button Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    Content="{Binding EditorCancelLabel}"
                                    Click="OnEditorShortcutCancelClick"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right">
                                <Button Click="OnEditorShortcutRestoreClick">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <controls:SvgIcon Width="14"
                                                          Height="14"
                                                          Color="{DynamicResource TextPrimaryBrush}"
                                                          SvgPath="avares://Mnemo.UI/Icons/Common/refresh.svg"/>
                                        <TextBlock Text="{Binding EditorRestoreDefaultLabel}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="accent"
                                        Content="{Binding EditorSaveLabel}"
                                        Click="OnEditorShortcutSaveClick"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Panel>
        </Grid>
    </Border>
</UserControl>
