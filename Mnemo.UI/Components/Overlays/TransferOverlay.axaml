<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mnemo.UI.Components.Overlays"
             xmlns:icons="using:Mnemo.UI.Controls"
             x:Class="Mnemo.UI.Components.Overlays.TransferOverlay"
             x:DataType="controls:TransferOverlay">
    <Border CornerRadius="16"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource OverlayBackgroundBrush}"
            Width="760"
            MaxWidth="860"
            Padding="0">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="24,20,24,14">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Title}"
                               FontSize="{DynamicResource FontSize.Heading3}"
                               FontFamily="{DynamicResource Font.Bold}" />
                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSize.Body.Small}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="ghost"
                        Padding="6"
                        Command="{Binding CancelCommand}">
                    <icons:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg"
                                   Width="18"
                                   Height="18" />
                </Button>
            </Grid>

            <icons:SegmentedToggle Grid.Row="1"
                                   Margin="24,0,24,18"
                                   LeftText="Import"
                                   RightText="Export"
                                   LeftIconPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/download.svg"
                                   RightIconPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/upload.svg"
                                   IsLeftSelected="{Binding IsImportMode}"
                                   LeftCommand="{Binding SelectImportCommand}"
                                   RightCommand="{Binding SelectExportCommand}" />

            <ScrollViewer Grid.Row="2" Margin="24,0,24,0" HorizontalScrollBarVisibility="Disabled">
                <Grid ColumnDefinitions="1.2*,*" ColumnSpacing="16">
                    <Border CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource CardBackgroundSecondaryBrush}"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="File format"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           FontSize="{DynamicResource FontSize.Body}" />
                                <TextBlock Text="Choose which format you want to transfer."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSize.Body.Small}" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AvailableFormats}"
                                      SelectedItem="{Binding SelectedFormat, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock IsVisible="{Binding IsImportMode}"
                                       Text="Import reads cards from a file and merges them into your deck."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       TextWrapping="Wrap" />
                            <TextBlock IsVisible="{Binding IsExportMode}"
                                       Text="Export writes your cards to a file that can be reused elsewhere."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            IsVisible="{Binding IsImportMode}"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource CardBackgroundSecondaryBrush}"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Import settings"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           FontSize="{DynamicResource FontSize.Body}" />
                                <TextBlock Text="Control how existing cards and unknown fields are handled."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <CheckBox Content="Duplicate on conflict"
                                          IsChecked="{Binding DuplicateOnConflict, Mode=TwoWay}" />
                                <CheckBox Content="Strict unknown payload handling"
                                          IsChecked="{Binding StrictUnknownPayloads, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10"
                            Margin="24,14,24,18">
                    <Button Classes="ghost" Command="{Binding CancelCommand}" Padding="16,8">
                        <TextBlock Text="{Binding CancelText}" />
                    </Button>
                    <Button Classes="accent" Command="{Binding ConfirmCommand}" Padding="18,8">
                        <TextBlock Text="{Binding ConfirmText}" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
