<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:local="using:Mnemo.UI.Components.Overlays"
             xmlns:markup="using:Mnemo.UI.Markup"
             x:Class="Mnemo.UI.Components.Overlays.GlobalSearchOverlay"
             x:Name="Root"
             x:DataType="local:GlobalSearchOverlayViewModel">
  <UserControl.Resources>
    <DataTemplate x:Key="SearchItemTemplate" x:DataType="local:GlobalSearchItemViewModel">
      <Button BorderThickness="0"
              BorderBrush="{DynamicResource CardAccentBrush}"
              Padding="8,6"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              Background="Transparent"
              Classes.selected="{Binding IsSelected}"
              Command="{Binding DataContext.OpenItemCommand, ElementName=Root}"
              CommandParameter="{Binding .}">
        <Button.Styles>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource NavElementHoverBackgroundBrush}"/>
          </Style>
          <Style Selector="Button.selected">
            <Setter Property="Background" Value="{DynamicResource NavElementHoverBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
          </Style>
        </Button.Styles>
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
          <Border Width="32"
                  Height="32"
                  CornerRadius="6"
                  Background="{DynamicResource CardIconBackgroundBrush}"
                  VerticalAlignment="Top">
            <controls:SvgIcon SvgPath="{Binding IconPath}"
                              Width="16"
                              Height="16"
                              Color="{DynamicResource ListItemIconColorBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
          </Border>

          <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="2" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}"
                       FontWeight="Medium"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Grid.Row="1"
                       Text="{Binding Subtitle}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource FontSize.Caption}"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>

          <Border Grid.Column="2"
                  Background="{DynamicResource CardBackgroundSecondaryBrush}"
                  BorderBrush="{DynamicResource IconsSeparationBarBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="8,3"
                  VerticalAlignment="Center"
                  IsVisible="{Binding HasTypeLabel}">
            <TextBlock Text="{Binding TypeLabel}"
                       Foreground="{DynamicResource TextFadedBrush}"
                       FontSize="{DynamicResource FontSize.Caption}"/>
          </Border>
        </Grid>
      </Button>
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="{DynamicResource OverlayBackgroundBrush}"
          BorderBrush="{DynamicResource IconsSeparationBarBrush}"
          BorderThickness="1"
          CornerRadius="14"
          Padding="18"
          Width="720">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource IconsSeparationBarBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,0">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Height="40">
            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/search.svg"
                              Width="16"
                              Height="16"
                              Color="{DynamicResource TextSecondaryBrush}"
                              VerticalAlignment="Center"/>
            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     PlaceholderText="{Binding PlaceholderText}"
                     VerticalAlignment="Center"
                     FontSize="{DynamicResource FontSize.Body.Small}" />
            <TextBlock Grid.Column="2"
                       Text="{markup:T Ns=GlobalSearch, Key=ShortcutHint}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       FontSize="{DynamicResource FontSize.Caption}" />
          </Grid>
        </Border>
        <Button Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Padding="4"
                Command="{Binding CloseCommand}">
          <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/x.svg"
                            Width="18"
                            Height="18"
                            Color="{DynamicResource TextSecondaryBrush}"/>
        </Button>
      </Grid>

      <Border Grid.Row="1"
              Height="1"
              Background="{DynamicResource IconsSeparationBarBrush}"/>

      <ScrollViewer Grid.Row="2" MaxHeight="460" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch" Margin="2,0,18,0">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="6" HorizontalAlignment="Stretch">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{markup:T Ns=GlobalSearch, Key=BestMatches}"
                         Foreground="{DynamicResource TextFadedBrush}"
                         FontSize="{DynamicResource FontSize.Caption}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding BestMatches.Count}"
                         Foreground="{DynamicResource TextFadedBrush}"
                         FontSize="{DynamicResource FontSize.Caption}" />
            </Grid>
            <ItemsControl Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding BestMatches}"
                          ItemTemplate="{StaticResource SearchItemTemplate}" />
          </Grid>

          <ItemsControl ItemsSource="{Binding Groups}" HorizontalAlignment="Stretch">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="local:GlobalSearchGroupViewModel">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6" HorizontalAlignment="Stretch">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding GroupDisplayName}"
                               Foreground="{DynamicResource TextFadedBrush}"
                               FontSize="{DynamicResource FontSize.Caption}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalMatched}"
                               Foreground="{DynamicResource TextFadedBrush}"
                               FontSize="{DynamicResource FontSize.Caption}" />
                  </Grid>

                  <ItemsControl Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding Items}"
                                ItemTemplate="{StaticResource SearchItemTemplate}" />

                  <Button Grid.Row="2"
                          Content="{markup:T Ns=GlobalSearch, Key=LoadMore}"
                          HorizontalAlignment="Left"
                          IsVisible="{Binding HasMore}"
                          Command="{Binding DataContext.LoadMoreCommand, ElementName=Root}"
                          CommandParameter="{Binding .}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding StatusText}"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="{DynamicResource FontSize.Body.Small}" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
