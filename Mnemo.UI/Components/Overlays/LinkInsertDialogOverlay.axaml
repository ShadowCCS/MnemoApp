<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Mnemo.UI.Components.Overlays"
             xmlns:controls="using:Mnemo.UI.Controls"
             x:Class="Mnemo.UI.Components.Overlays.LinkInsertDialogOverlay"
             x:DataType="local:LinkInsertDialogOverlay">
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource InputDialogSelectionForegroundBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundPointerOverBrush}" />
            </Style>
            <Style Selector="^:focus">
                <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundFocusedBrush}" />
                <Style Selector="^ /template/ Border#PART_BorderElement">
                    <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Style>
            </Style>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24"
            MinWidth="420"
            MaxWidth="560">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding Title}"
                           FontSize="{DynamicResource FontSize.Heading4}"
                           FontFamily="{DynamicResource Font.Bold}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="1" Classes="ghost" Command="{Binding CloseCommand}" Padding="4" Margin="0,-4,-4,0">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg" Width="20" Height="20" />
                </Button>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding UrlLabel}"
                       FontFamily="{DynamicResource Font.Medium}"
                       FontSize="{DynamicResource FontSize.Body.Small}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Grid.Row="2"
                     x:Name="UrlTextBox"
                     Text="{Binding Url, Mode=TwoWay}"
                     Watermark="{Binding UrlPlaceholder}"
                     FontFamily="{DynamicResource Font.Medium}"
                     FontSize="{DynamicResource FontSize.Body.ExtraSmall}"/>

            <StackPanel Grid.Row="3" IsVisible="{Binding ShowDisplaySection}">
                <TextBlock Text="{Binding DisplayLabel}"
                           Margin="0,4,0,0"
                           FontFamily="{DynamicResource Font.Medium}"
                           FontSize="{DynamicResource FontSize.Body.Small}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="DisplayTextBox"
                         Text="{Binding DisplayText, Mode=TwoWay}"
                         Watermark="{Binding DisplayPlaceholder}"
                         Margin="0,8,0,0"
                         FontFamily="{DynamicResource Font.Medium}"
                         FontSize="{DynamicResource FontSize.Body.ExtraSmall}"/>
            </StackPanel>

            <TextBlock Grid.Row="4"
                       IsVisible="{Binding ShowCrossBlockHint}"
                       Text="{Binding CrossBlockHint}"
                       TextWrapping="Wrap"
                       FontFamily="{DynamicResource Font.Medium}"
                       FontSize="{DynamicResource FontSize.Body.Small}"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="{Binding RemoveLinkText}"
                        Classes="ghost"
                        Command="{Binding RemoveLinkCommand}"
                        IsVisible="{Binding ShowRemoveLink}"/>
                <Button Content="{Binding CancelText}"
                        Classes="secondary"
                        Command="{Binding CancelCommand}"/>
                <Button Content="{Binding ConfirmText}"
                        Classes="accent"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
