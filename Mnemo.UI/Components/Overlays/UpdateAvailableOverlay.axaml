<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:vm="using:Mnemo.UI.Modules.Updates.ViewModels"
             x:Class="Mnemo.UI.Components.Overlays.UpdateAvailableOverlay"
             x:DataType="vm:UpdateAvailableViewModel">
    <Border MaxWidth="520"
            Padding="24"
            CornerRadius="12"
            Background="{DynamicResource CardBackgroundPrimaryBrush}"
            BorderBrush="{DynamicResource IconsSeparationBarBrush}"
            BorderThickness="1">
        <StackPanel Spacing="16">
            <TextBlock Text="{Binding Title}"
                       FontSize="{DynamicResource FontSize.Heading4}"
                       FontFamily="{DynamicResource Font.Bold}"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding Subtitle}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <Border MaxHeight="240"
                    CornerRadius="8"
                    Padding="12"
                    Background="{DynamicResource CardBackgroundSecondaryBrush}"
                    IsVisible="{Binding HasReleaseNotes}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <components:MarkdownView Source="{Binding ReleaseNotes}" />
                </ScrollViewer>
            </Border>
            <StackPanel Spacing="8" IsVisible="{Binding ShowDownloadProgress}">
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}" Height="6" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="{Binding SkipLabel}"
                        Command="{Binding SkipThisVersionCommand}" />
                <Button Content="{Binding RemindTomorrowLabel}"
                        Command="{Binding RemindTomorrowCommand}" />
                <Button Content="{Binding RemindLaterLabel}"
                        Command="{Binding RemindLaterCommand}" />
                <Button Content="{Binding OpenReleaseLabel}"
                        Command="{Binding OpenReleasePageCommand}"
                        IsVisible="{Binding IsPortableFlow}" />
                <Button Content="{Binding InstallLabel}"
                        Command="{Binding InstallCommand}"
                        IsVisible="{Binding CanInstallInApp}"
                        Classes="accent" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
