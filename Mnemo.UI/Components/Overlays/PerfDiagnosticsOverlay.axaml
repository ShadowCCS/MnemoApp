<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Mnemo.UI.Components.Overlays.PerfDiagnosticsOverlay"
             MinWidth="520"
             MaxWidth="720">
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource IconsSeparationBarBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20"
            BoxShadow="0 8 32 0 #20000000">
        <StackPanel Spacing="12">
            <TextBlock Text="Performance diagnostics"
                       FontSize="{DynamicResource FontSize.Body.Large}"
                       FontFamily="{DynamicResource Font.SemiBold}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Ring buffer of recent timings, metrics, and memory snapshots. Enable via Settings → Developer."
                       TextWrapping="Wrap"
                       FontSize="{DynamicResource FontSize.Body.Small}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <ScrollViewer MaxHeight="420" HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="ReportText"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="280"
                         FontFamily="{DynamicResource Font.Monospace}"
                         FontSize="11"
                         Background="{DynamicResource CardBackgroundSecondaryBrush}"
                         BorderThickness="0"/>
            </ScrollViewer>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CaptureMemoryButton" Content="Memory snapshot" Classes="Secondary"/>
                <Button x:Name="ClearButton" Content="Clear" Classes="Secondary"/>
                <Button x:Name="RefreshButton" Content="Refresh" Classes="Primary"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
