<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Mnemo.UI.Components.Overlays"
             xmlns:icons="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             x:Class="Mnemo.UI.Components.Overlays.FlashcardDeckSettingsOverlay"
             x:DataType="controls:FlashcardDeckSettingsOverlay">
    <Border CornerRadius="14"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource CardBackgroundSecondaryBrush}"
            Width="560"
            MaxWidth="700"
            MaxHeight="640"
            Padding="0">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="20,16,20,12">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}"
                               FontSize="{DynamicResource FontSize.Heading3}"
                               FontFamily="{DynamicResource Font.Bold}" />
                    <TextBlock Text="{Binding DeckName}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSize.Body.Small}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6"
                        Command="{Binding CancelCommand}">
                    <icons:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg"
                                   Width="16" Height="16" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="20,0,20,0" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=SchedulingSectionTitle}"
                                   FontFamily="{DynamicResource Font.SemiBold}" />
                        <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:T Ns=Flashcards, Key=SchedulingEngineLabel}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding AlgorithmOptions}"
                                      SelectedItem="{Binding SelectedAlgorithmOption, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="controls:DeckAlgorithmOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Margin="0,4,0,0"
                                       Text="{markup:T Ns=Flashcards, Key=SchedulingEngineHint}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="{DynamicResource FontSize.Body.Small}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=GeneralSectionTitle}"
                                   FontFamily="{DynamicResource Font.SemiBold}" />
                        <Grid ColumnDefinitions="150,*" RowDefinitions="Auto" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:T Ns=Flashcards, Key=FolderLabel}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding FolderOptions}"
                                      SelectedItem="{Binding SelectedFolderOption, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="controls:DeckFolderOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="20,14,20,16">
                <Button Classes="ghost" Command="{Binding CancelCommand}" Padding="14,8">
                    <TextBlock Text="{Binding CancelText}" />
                </Button>
                <Button Classes="accent" Command="{Binding SaveCommand}" Padding="16,8">
                    <TextBlock Text="{Binding SaveText}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
