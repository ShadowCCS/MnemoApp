<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Mnemo.UI.Controls"
                    xmlns:local="using:Mnemo.UI.Components"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

  <ControlTheme x:Key="{x:Type local:CollapsibleSection}" TargetType="local:CollapsibleSection">
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="VerticalAlignment" Value="Top"/>
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="0">
          <!-- Header -->
          <Button Name="PART_HeaderButton"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Center"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="8"
                  Padding="10,10"
                  Cursor="Hand"
                  Focusable="True">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="Transitions">
                  <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                  </Transitions>
                </Setter>
              </Style>
              <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Transitions">
                  <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                  </Transitions>
                </Setter>
              </Style>
              <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
              </Style>
              <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ListItemActiveBackgroundBrush}"/>
              </Style>
              <Style Selector="Button:focus-visible /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
              </Style>
            </Button.Styles>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{TemplateBinding Title}"
                         FontSize="12"
                         FontFamily="{DynamicResource Font.SemiBold}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         LetterSpacing="0.5"
                         VerticalAlignment="Center"/>
              <controls:SvgIcon Grid.Column="1"
                                Name="PART_Chevron"
                                Width="14" Height="14"
                                Margin="8,0,2,0"
                                VerticalAlignment="Center"
                                SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-down.svg"
                                Color="{DynamicResource TextSecondaryBrush}"
                                RenderTransformOrigin="50%,50%"
                                RenderTransform="rotate(-90deg)">
                <controls:SvgIcon.Transitions>
                  <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                  </Transitions>
                </controls:SvgIcon.Transitions>
              </controls:SvgIcon>
            </Grid>
          </Button>

          <!-- Content host: clipped, max-height+opacity animated. -->
          <Border Name="PART_ContentHost"
                  ClipToBounds="True"
                  MaxHeight="0"
                  Opacity="0"
                  HorizontalAlignment="Stretch">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
              </Transitions>
            </Border.Transitions>
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Margin="0,10,0,2"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top"/>
          </Border>
        </StackPanel>
      </ControlTemplate>
    </Setter>

    <!-- Chevron rotation states. Default (collapsed) is -90deg (pointing right).
         Expanded rotates it to 0deg (pointing down). -->
    <Style Selector="^:expanded /template/ controls|SvgIcon#PART_Chevron">
      <Setter Property="RenderTransform" Value="rotate(0deg)"/>
    </Style>
    <Style Selector="^:collapsed /template/ controls|SvgIcon#PART_Chevron">
      <Setter Property="RenderTransform" Value="rotate(-90deg)"/>
    </Style>
  </ControlTheme>
</ResourceDictionary>
