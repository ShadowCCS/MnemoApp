<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="using:Mnemo.UI.Components"
        xmlns:controls="using:Mnemo.UI.Controls"
        xmlns:converters="using:Mnemo.UI.Converters"
        xmlns:vm="using:Mnemo.UI.ViewModels"
        xmlns:markup="using:Mnemo.UI.Markup"
        x:Class="Mnemo.UI.Components.Topbar"
        x:DataType="components:TopbarViewModel">
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource TopbarBackgroundBrush}"
            BorderBrush="Transparent"
            BorderThickness="0, 0, 0, 1"
            Padding="10,8">
        <Grid ColumnDefinitions="Auto,*" Margin="10">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Command="{Binding OpenGlobalSearchCommand}">
                <Button.Styles>
                    <Style Selector="Button:pointerover Border#SearchButtonChrome">
                        <Setter Property="Background" Value="{DynamicResource TopbarButtonBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource IconsSeparationBarBrush}"/>
                    </Style>
                    <Style Selector="Button:pressed Border#SearchButtonChrome">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource IconsSeparationBarBrush}"/>
                    </Style>
                    <Style Selector="Button:pointerover TextBlock#SearchPlaceholderText">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pressed TextBlock#SearchPlaceholderText">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pointerover TextBlock#SearchShortcutText">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pressed TextBlock#SearchShortcutText">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pointerover Border#SearchShortcutBadge">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pressed Border#SearchShortcutBadge">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pointerover controls|SvgIcon#SearchIcon">
                        <Setter Property="Color" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                    <Style Selector="Button:pressed controls|SvgIcon#SearchIcon">
                        <Setter Property="Color" Value="{DynamicResource TextSecondaryBrush}"/>
                    </Style>
                </Button.Styles>
                <Border Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        x:Name="SearchButtonChrome"
                        CornerRadius="12"
                        Height="34"
                        Padding="10,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" MinWidth="330">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/search.svg"
                                          x:Name="SearchIcon"
                                          Color="{DynamicResource TextFadedBrush}"
                                          Width="16"
                                          Height="16"
                                          VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   x:Name="SearchPlaceholderText"
                                   Text="{markup:T Ns=Topbar, Key=SearchPlaceholder}"
                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                   Foreground="{DynamicResource TextFadedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="2"
                                x:Name="SearchShortcutBadge"
                                Background="Transparent"
                                BorderBrush="{DynamicResource IconsSeparationBarBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,2"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="SearchShortcutText"
                                       Text="{Binding GlobalSearchShortcutDisplay}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextFadedBrush}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
            </Button>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <Button Background="{DynamicResource TopbarButtonBackgroundBrush}" Foreground="{DynamicResource TopbarButtonForegroundBrush}" Height="34" Width="34" Padding="7" CornerRadius="19" BorderThickness="0">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/device-speaker.svg" Color="{DynamicResource TopbarIconsBrush}" Width="20" Height="20" />
                </Button>
                <Button Background="{DynamicResource TopbarButtonBackgroundBrush}" Foreground="{DynamicResource TopbarButtonForegroundBrush}" Height="34" Width="34" Padding="7" CornerRadius="19" BorderThickness="0">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight" ShowMode="TransientWithDismissOnPointerMoveAway">
                            <!-- No inner ScrollViewer: FlyoutPresenter template already wraps content in ScrollViewer.
                                 No second Background/Border: presenter supplies rounded chrome; avoids square bleed in corners. -->
                            <StackPanel MinWidth="300"
                                        MaxWidth="380"
                                        Margin="12,10"
                                        Spacing="4">
                                    <TextBlock Text="{markup:T Ns=Topbar, Key=NotificationsTitle}"
                                               FontWeight="SemiBold"
                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="4,2,4,6" />
                                    <TextBlock Text="{markup:T Ns=Topbar, Key=NotificationsEmpty}"
                                               IsVisible="{Binding ShowsNotificationsEmpty}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextAlignment="Center"
                                               Margin="8,12"
                                               TextWrapping="Wrap" />
                                    <ItemsControl IsVisible="{Binding HasNotifications}"
                                                  ItemsSource="{Binding RecentNotifications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="components:NotificationFlyoutRowViewModel">
                                                <Border Padding="10,10"
                                                        CornerRadius="8"
                                                        Margin="0,2"
                                                        Background="Transparent">
                                                    <Border.Styles>
                                                        <Style Selector="Border:pointerover">
                                                            <Setter Property="Background" Value="{DynamicResource NotificationFlyoutRowHoverBrush}" />
                                                        </Style>
                                                    </Border.Styles>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                        <Ellipse Grid.RowSpan="2"
                                                                 Width="10"
                                                                 Height="10"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"
                                                                 Fill="{Binding TypeAccentBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding TimeText}"
                                                                   FontSize="{DynamicResource FontSize.Caption}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Top"
                                                                   Margin="8,0,0,0" />
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding Description}"
                                                                   FontSize="{DynamicResource FontSize.Caption}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/bell.svg" Color="{DynamicResource TopbarIconsBrush}" Width="20" Height="20" />
                </Button>

                <!-- Gamification Topbar XP & Streak -->
                <Border Background="{DynamicResource TopbarButtonBackgroundBrush}" 
                        Padding="7" 
                        CornerRadius="19" 
                        BorderThickness="0" 
                        IsVisible="{Binding IsGamificationEnabled}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Assets/xp.svg" Width="18" Height="18" PreserveSvgColors="True" />
                            <TextBlock Text="{Binding GamificationXpText}" FontSize="{DynamicResource FontSize.Body.Small}" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Assets/streak.svg" Width="18" Height="18" PreserveSvgColors="True" />
                            <TextBlock Text="{Binding GamificationStreakText}" FontSize="{DynamicResource FontSize.Body.Small}" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource TopbarButtonBackgroundBrush}" Padding="7" CornerRadius="19" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding MinimizeCommand}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/square-rounded-minus.svg"
                                             Color="{DynamicResource TopbarIconsBrush}"
                                             Width="22" Height="22" />
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding MaximizeCommand}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/maximize.svg"
                                             Color="{DynamicResource TopbarIconsBrush}"
                                             Width="22" Height="22" />
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding CloseCommand}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Common/square-rounded-x.svg"
                                             Color="{DynamicResource TopbarIconsBrush}"
                                             Width="22" Height="22"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </Button.Styles>
                            <Image Source="{Binding ProfilePicturePath, Converter={StaticResource PathToImageConverter}}" Width="22" Height="22" />
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

