<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Overview.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="840" d:DesignHeight="680"
             x:DataType="vm:AddWidgetViewModel"
             x:Class="Mnemo.UI.Modules.Overview.Views.AddWidgetView"
             x:Name="AddWidgetRoot">

    <UserControl.Styles>
        <Style Selector="Button.gallery-filter-chip">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource NavButtonHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
        </Style>
        <Style Selector="Button.gallery-filter-chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.gallery-filter-chip.selected">
            <Setter Property="Background" Value="{DynamicResource NavElementActiveBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.gallery-filter-chip.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavElementActiveBackgroundBrush}"/>
            <Setter Property="Opacity" Value="0.92"/>
        </Style>
        <Style Selector="Button.gallery-filter-chip.selected:not(:pointerover) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Card action: same idle look as filter chips; orange accent on hover -->
        <Style Selector="Button.gallery-add-btn">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="{DynamicResource NavButtonHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
        </Style>
        <Style Selector="Button.gallery-add-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavElementActiveBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.gallery-add-btn:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.gallery-add-btn TextBlock.gallery-add-remove">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Button.gallery-add-btn:pointerover TextBlock.gallery-add-remove">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="Button.gallery-add-btn:pointerover TextBlock.gallery-add-added">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Button.gallery-add-btn:not(:pointerover) TextBlock.gallery-add-added">
            <Setter Property="IsVisible" Value="True"/>
        </Style>

        <Style Selector="TextBox.add-widget-search">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
            CornerRadius="20"
            BoxShadow="0 12 40 0 #28000000"
            Padding="28"
            MinWidth="320"
            Width="800"
            MaxWidth="880"
            MinHeight="520"
            Height="620"
            MaxHeight="720"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
              ColumnDefinitions="*"
              MinHeight="0">

            <!-- Header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="{markup:T Ns=AddWidget, Key=Title}"
                               FontSize="{DynamicResource FontSize.Heading2}"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{markup:T Ns=AddWidget, Key=Subtitle}"
                               FontSize="{DynamicResource FontSize.Caption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Padding="8"
                        MinWidth="36"
                        MinHeight="36"
                        CornerRadius="10"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Top"
                        ToolTip.Tip="{markup:T Ns=Common, Key=Cancel}">
                    <TextBlock Text="×"
                               FontSize="22"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Search -->
            <Grid Grid.Row="1" Margin="0,16,0,12">
                <TextBox x:Name="SearchBox"
                         Classes="add-widget-search"
                         Padding="44,10,18,10"
                         Text="{Binding SearchQuery, Mode=TwoWay}"
                         Watermark="{markup:T Ns=AddWidget, Key=SearchPlaceholder}"/>
                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/search.svg"
                                  Width="18" Height="18"
                                  Margin="18,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Color="{DynamicResource TextTertiaryBrush}"/>
            </Grid>

            <!-- Filter chips -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,0,0,18">
                <Button Classes="gallery-filter-chip"
                        Classes.selected="{Binding IsAllFilterSelected}"
                        Content="{markup:T Ns=AddWidget, Key=FilterAll}"
                        Command="{Binding SelectGalleryFilterCommand}"
                        CommandParameter="All"/>
                <Button Classes="gallery-filter-chip"
                        Classes.selected="{Binding IsStudyFilterSelected}"
                        Content="{markup:T Ns=AddWidget, Key=FilterStudy}"
                        Command="{Binding SelectGalleryFilterCommand}"
                        CommandParameter="Study"/>
                <Button Classes="gallery-filter-chip"
                        Classes.selected="{Binding IsFlashcardsFilterSelected}"
                        Content="{markup:T Ns=AddWidget, Key=FilterFlashcards}"
                        Command="{Binding SelectGalleryFilterCommand}"
                        CommandParameter="Flashcards"/>
                <Button Classes="gallery-filter-chip"
                        Classes.selected="{Binding IsProductivityFilterSelected}"
                        Content="{markup:T Ns=AddWidget, Key=FilterProductivity}"
                        Command="{Binding SelectGalleryFilterCommand}"
                        CommandParameter="Productivity"/>
                <Button Classes="gallery-filter-chip"
                        Classes.selected="{Binding IsCommunityFilterSelected}"
                        Content="{markup:T Ns=AddWidget, Key=FilterCommunity}"
                        Command="{Binding SelectGalleryFilterCommand}"
                        CommandParameter="Community"/>
            </StackPanel>

            <ScrollViewer Grid.Row="3"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding FilteredWidgets}"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:WidgetGalleryDisplayItem">
                            <Border Margin="0,0,14,14"
                                    MinHeight="168"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource WidgetBackgroundPrimaryBrush}"
                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18"
                                    BoxShadow="0 2 8 0 #14000000">
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto">
                                    <!-- Icon tile -->
                                    <Border Grid.RowSpan="4"
                                            Background="{DynamicResource CardIconBackgroundBrush}"
                                            CornerRadius="12"
                                            Padding="10"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Top">
                                        <controls:SvgIcon SvgPath="{Binding Metadata.Icon}"
                                                          Width="22" Height="22"
                                                          Color="{DynamicResource CardAccentBrush}"/>
                                    </Border>

                                    <!-- Title row -->
                                    <Grid Grid.Column="1"
                                          ColumnDefinitions="*,Auto"
                                          MinHeight="36">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ResolvedTitle}"
                                                       FontFamily="{DynamicResource Font.SemiBold}"
                                                       FontSize="15"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border VerticalAlignment="Center"
                                                    CornerRadius="6"
                                                    Padding="8,3"
                                                    IsVisible="{Binding Metadata.IsFeatured}"
                                                    Background="#33E9573F">
                                                <TextBlock Text="{markup:T Ns=AddWidget, Key=PickBadge}"
                                                           FontSize="10"
                                                           FontFamily="{DynamicResource Font.SemiBold}"
                                                           Foreground="{DynamicResource CardAccentBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding $parent[UserControl].((vm:AddWidgetViewModel)DataContext).ToggleWidgetOnDashboardCommand}"
                                                CommandParameter="{Binding Metadata}"
                                                VerticalAlignment="Center"
                                                Classes="gallery-add-btn">
                                            <Panel>
                                                <TextBlock Text="{Binding GalleryAddLabel}"
                                                           IsVisible="{Binding !IsOnDashboard}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                <Grid IsVisible="{Binding IsOnDashboard}">
                                                    <TextBlock Classes="gallery-add-added"
                                                               Text="{Binding GalleryAddedLabel}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Classes="gallery-add-remove"
                                                               Text="{Binding GalleryRemoveLabel}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Panel>
                                        </Button>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding MetaLine}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               Margin="0,4,0,6"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Text="{Binding ResolvedGalleryDescription}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               LineHeight="20"
                                               TextWrapping="Wrap"/>

                                    <ItemsControl Grid.Row="3"
                                                  Grid.Column="1"
                                                  ItemsSource="{Binding TagLabels}"
                                                  Margin="0,12,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="sys:String">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFadedBrush}"
                                                           Margin="0,0,12,4"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="4"
                  Margin="0,20,0,0"
                  ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding WidgetCountFooter}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <Button Grid.Column="1"
                        Content="{markup:T Ns=Common, Key=Cancel}"
                        Command="{Binding CancelCommand}"
                        Classes="ghost"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
