<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Chat.ViewModels"
             xmlns:vmroot="using:Mnemo.UI.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:markup="using:Mnemo.UI.Markup"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="Mnemo.UI.Modules.Chat.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             x:Name="ChatRoot">

    <UserControl.Resources>
        <converters:BoolToStreamingIntervalConverter x:Key="BoolToStreamingIntervalConverter"/>
        <converters:NullToBoolConverter x:Key="StringNotEmptyToBoolConverter"/>
        <converters:AssistantModeToLabelConverter x:Key="AssistantModeToLabelConverter"/>
        <converters:LocalPathToBitmapConverter x:Key="LocalPathToBitmapConverter"/>
        <converters:ChatAttachmentKindToBoolConverter x:Key="ChatAttachmentKindToBoolConverter"/>
        <converters:ChatViewModelDataContextCommandConverter x:Key="ChatViewModelDataContextCommandConverter"/>
        <converters:BoolToBrushConverter x:Key="ChatHistoryRowHoverBrushConverter"
                                         TrueBrush="{DynamicResource ListItemHoverBackgroundBrush}"
                                         FalseBrush="Transparent"/>
        <converters:BoolToDoubleConverter x:Key="BoolToDoubleConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.SuggestionChip">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource TextFadedBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.PromptActionButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFadedBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            </Style>
        </Style>

        <Style Selector="controls|ModernComboBox.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="Button.ScrollToBottomLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.ScrollToBottomLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.ScrollToBottomLink:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Border.PulsingDot">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="controls|SvgIcon.ActivePulse">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                </Animation>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Button.NewChatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource TextFadedBrush}"/>
            </Style>
        </Style>

        <Style Selector="Border.chat-history-row">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>

        <Style Selector="Button.chat-history-row-segment">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
        </Style>

        <Style Selector="Button.ChatHistoryToggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.chat-history-more">
            <Setter Property="Padding" Value="6,8,10,8"/>
            <Setter Property="MinWidth" Value="32"/>
        </Style>

        <Style Selector="Button.MessageActionIcon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.35"/>
            </Style>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="Auto,*">
        <!-- Chat history sidebar -->
        <Border Grid.Column="0"
                Width="{Binding ChatHistorySidebarWidth}"
                MinWidth="48"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,0,1,0"
                Background="{DynamicResource WorkspaceBackgroundBrush}">
            <Panel>
                <!-- Collapsed: narrow controls -->
                <StackPanel Margin="0,12,0,0"
                            Spacing="8"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding !IsChatHistorySidebarOpen}">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="6"
                            HorizontalAlignment="Center"
                            Cursor="Hand"
                            Command="{Binding ToggleChatHistorySidebarCommand}"
                            ToolTip.Tip="{markup:T Ns=Notes, Key=ToggleSidebar}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                          Width="20" Height="20"
                                          Color="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="6"
                            HorizontalAlignment="Center"
                            Cursor="Hand"
                            Command="{Binding NewChatCommand}"
                            ToolTip.Tip="{markup:T Ns=Chat, Key=NewChat}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/plus.svg"
                                          Width="20" Height="20"
                                          Color="{DynamicResource TextPrimaryBrush}"/>
                    </Button>
                </StackPanel>
                <!-- Expanded -->
                <Grid RowDefinitions="Auto,Auto,*"
                      Margin="12,12,12,12"
                      IsVisible="{Binding IsChatHistorySidebarOpen}">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0"
                                   Text="{markup:T Ns=Chat, Key=ChatHistory}"
                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                   FontFamily="{DynamicResource Font.SemiBold}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6"
                                Cursor="Hand"
                                Command="{Binding ToggleChatHistorySidebarCommand}"
                                ToolTip.Tip="{markup:T Ns=Notes, Key=ToggleSidebar}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                              Width="20" Height="20"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>
                    <Button Grid.Row="1"
                            Command="{Binding NewChatCommand}"
                            Classes="NewChatButton"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/plus.svg"
                                              Width="15" Height="15"
                                              Color="{DynamicResource TextPrimaryBrush}"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="{markup:T Ns=Chat, Key=NewChat}"
                                       FontFamily="{DynamicResource Font.Medium}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ConversationRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatConversationRowViewModel">
                                    <Panel Margin="0,0,0,4">
                                        <Border IsVisible="{Binding IsSelected}"
                                                CornerRadius="8"
                                                Background="{DynamicResource ListItemHoverBackgroundBrush}"
                                                Opacity="0.65"/>
                                        <Border Classes="chat-history-row"
                                                MinWidth="0"
                                                Background="{Binding IsRowHovered, Converter={StaticResource ChatHistoryRowHoverBrushConverter}}">
                                            <Grid ColumnDefinitions="*,Auto" MinWidth="0">
                                                <Button Grid.Column="0"
                                                        Classes="chat-history-row-segment"
                                                        Command="{Binding SelectCommand}"
                                                        Padding="10,8,4,8"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        PointerEntered="ChatHistoryRowSegment_PointerEntered"
                                                        PointerExited="ChatHistoryRowSegment_PointerExited">
                                                    <Button.IsEnabled>
                                                        <Binding ElementName="ChatRoot" Path="HistoryNavigationEnabled"/>
                                                    </Button.IsEnabled>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Button>
                                                <Button Grid.Column="1"
                                                        Classes="chat-history-row-segment chat-history-more"
                                                        Opacity="{Binding IsRowHovered, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter=1|0}"
                                                        ToolTip.Tip="{markup:T Ns=Chat, Key=MoreChatActions}"
                                                        PointerEntered="ChatHistoryRowSegment_PointerEntered"
                                                        PointerExited="ChatHistoryRowSegment_PointerExited">
                                                    <Button.IsEnabled>
                                                        <Binding ElementName="ChatRoot" Path="HistoryNavigationEnabled"/>
                                                    </Button.IsEnabled>
                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/dots-vertical.svg"
                                                                      Width="16" Height="16"
                                                                      Color="{DynamicResource TextSecondaryBrush}"/>
                                                    <Button.Flyout>
                                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                            <MenuItem Header="{markup:T Ns=Notes, Key=Rename}">
                                                                <MenuItem.Command>
                                                                    <Binding ElementName="ChatRoot" Path="DataContext" Converter="{StaticResource ChatViewModelDataContextCommandConverter}" ConverterParameter="RenameChat"/>
                                                                </MenuItem.Command>
                                                                <MenuItem.CommandParameter>
                                                                    <Binding Path="ConversationId"/>
                                                                </MenuItem.CommandParameter>
                                                            </MenuItem>
                                                            <MenuItem Header="{markup:T Ns=Notes, Key=Delete}">
                                                                <MenuItem.Command>
                                                                    <Binding ElementName="ChatRoot" Path="DataContext" Converter="{StaticResource ChatViewModelDataContextCommandConverter}" ConverterParameter="DeleteChat"/>
                                                                </MenuItem.Command>
                                                                <MenuItem.CommandParameter>
                                                                    <Binding Path="ConversationId"/>
                                                                </MenuItem.CommandParameter>
                                                            </MenuItem>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Panel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Background="{DynamicResource CardAccentBrush}"
                        Width="40" Height="40"
                        CornerRadius="12"
                        BoxShadow="0 1 4 0 #10000000">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                      Width="20" Height="20"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Color="{DynamicResource AccentButtonIconBrush}"/>
                </Border>
                <StackPanel Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{markup:T Ns=Chat, Key=Atlas}"
                               FontSize="{DynamicResource FontSize.Body.Large}"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{markup:T Ns=Chat, Key=AskAnything}"
                               FontSize="{DynamicResource FontSize.Body.Small}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Messages -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <!-- Center column 6/(1+6+1) = 75% of available width -->
                <Grid ColumnDefinitions="*,6*,*" MinWidth="0">
                    <Border Grid.Column="1" MinWidth="0" HorizontalAlignment="Stretch" Padding="20,24,20,16">
                    <StackPanel MinWidth="0">
                    <!-- Welcome intro (not persisted; hidden after first user message) -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" MinWidth="0"
                          Margin="0,0,0,32"
                          IsVisible="{Binding ShowWelcomeIntro}">
                        <Border Grid.Row="0" Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                Background="{DynamicResource CardAccentBrush}"
                                Margin="0,2,12,0" VerticalAlignment="Top"
                                BoxShadow="0 1 4 0 #10000000">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                              Width="14" Height="14"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Color="{DynamicResource AccentButtonIconBrush}"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{markup:T Ns=Chat, Key=Atlas}"
                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                   FontFamily="{DynamicResource Font.SemiBold}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,2"/>
                        <Border Grid.Row="1" Grid.Column="1"
                                Background="{DynamicResource WorkspaceBackgroundBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4,16,16,16"
                                Padding="16,12"
                                BoxShadow="0 1 3 0 #06000000"
                                MinWidth="0">
                            <components:MarkdownView Source="{Binding WelcomeIntroText}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding WelcomeSuggestionList}"
                                      Margin="0,10,0,0" HorizontalAlignment="Stretch" MinWidth="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="SuggestionChip" Margin="0,0,8,8"
                                            Command="{Binding #ChatRoot.DataContext, Converter={StaticResource ChatViewModelDataContextCommandConverter}, ConverterParameter=Suggestion}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   FontFamily="{DynamicResource Font.Medium}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Messages}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ChatMessageViewModel">
                                <Panel Margin="0,0,0,32" MinWidth="0">
                                    <!-- Assistant Message -->
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" IsVisible="{Binding !IsUser}" MinWidth="0">
                                        <Border Grid.Row="0" Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource CardAccentBrush}"
                                                Margin="0,2,12,0" VerticalAlignment="Top"
                                                BoxShadow="0 1 4 0 #10000000">
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                                              Width="14" Height="14"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Color="{DynamicResource AccentButtonIconBrush}"/>
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{markup:T Ns=Chat, Key=Atlas}"
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   FontFamily="{DynamicResource Font.SemiBold}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,2"/>

                                            <!-- Thought Process Panel (same visibility as sidebar: any pipeline steps or model thoughts) -->
                                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    IsVisible="{Binding HasProcessThreadOrThoughts}"
                                                    Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                    CornerRadius="12"
                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    Margin="0,2,0,6"
                                                    HorizontalAlignment="Stretch"
                                                    MinWidth="0">
                                                <StackPanel>
                                                    <!-- Header bar -->
                                                    <Border Padding="14,10">
                                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                                    Classes="PulsingDot"
                                                                    Background="{DynamicResource ChatProcessStateActiveBrush}" Margin="0,0,10,0"
                                                                    VerticalAlignment="Center"
                                                                    IsVisible="{Binding IsStreaming}"/>
                                                            <Border Grid.Column="1"
                                                                    IsVisible="{Binding HasElapsedText}"
                                                                    Background="{DynamicResource WorkspaceBackgroundBrush}"
                                                                    CornerRadius="4"
                                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                    BorderThickness="1"
                                                                    Padding="6,2"
                                                                    Margin="0,0,10,0"
                                                                    BoxShadow="0 1 2 0 #06000000"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ElapsedText}"
                                                                           FontFamily="{DynamicResource Font.Monospace}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding ProcessHeaderText}"
                                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontFamily="{DynamicResource Font.Medium}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ToggleButton Grid.Column="3"
                                                                          IsChecked="{Binding IsProcessThreadExpanded, Mode=TwoWay}"
                                                                          Background="Transparent"
                                                                          BorderThickness="0"
                                                                          Padding="6,2"
                                                                          MinWidth="0" MinHeight="0"
                                                                          VerticalAlignment="Center"
                                                                          Cursor="Hand">
                                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                                                  Width="14" Height="14"
                                                                                  Color="{DynamicResource TextFadedBrush}">
                                                                    <controls:SvgIcon.RenderTransform>
                                                                        <RotateTransform Angle="90"/>
                                                                    </controls:SvgIcon.RenderTransform>
                                                                </controls:SvgIcon>
                                                            </ToggleButton>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Collapsible step list -->
                                                    <Border IsVisible="{Binding IsProcessThreadExpanded}"
                                                            Padding="12,4,12,8">
                                                        <StackPanel>
                                                            <ItemsControl ItemsSource="{Binding ProcessSteps}" IsVisible="{Binding HasProcessThread}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="vmroot:ChatProcessStepViewModel">
                                                                        <Grid ColumnDefinitions="Auto,*">
                                                                            <Grid Grid.Column="0" RowDefinitions="Auto, *" Width="20" Margin="0,2,8,0" HorizontalAlignment="Center">
                                                                                <Panel Grid.Row="0" Width="20" Height="20">
                                                                                    <Panel Width="20" Height="20" IsVisible="{Binding IsComplete}">
                                                                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/done-disc.svg"
                                                                                                          Width="16" Height="16"
                                                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                          Color="{DynamicResource ChatProcessStateDoneFillBrush}"/>
                                                                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/done-check.svg"
                                                                                                          Width="16" Height="16"
                                                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                          Color="{DynamicResource ChatProcessStateDoneGlyphBrush}"/>
                                                                                    </Panel>
                                                                                    <controls:SvgIcon Classes="ActivePulse"
                                                                                                      SvgPath="avares://Mnemo.UI/Icons/States/active.svg"
                                                                                                      Width="16" Height="16"
                                                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                      Color="{DynamicResource ChatProcessStateActiveBrush}"
                                                                                                      IsVisible="{Binding IsActive}"/>
                                                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/States/pending.svg"
                                                                                                      Width="16" Height="16"
                                                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                      Color="{DynamicResource ChatProcessStatePendingBrush}"
                                                                                                      IsVisible="{Binding IsPending}"/>
                                                                                </Panel>
                                                                                <Border Grid.Row="1" Width="1.5"
                                                                                        Background="{DynamicResource SidebarBorderBrush}"
                                                                                        Margin="0,4,0,0"
                                                                                        HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Stretch"/>
                                                                            </Grid>
                                                                            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0" Margin="0,0,0,14">
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                           FontFamily="{DynamicResource Font.SemiBold}"
                                                                                           TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding Detail}"
                                                                                           FontSize="{DynamicResource FontSize.Body.Caption}"
                                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                           TextWrapping="Wrap"
                                                                                           IsVisible="{Binding HasDetail}"/>
                                                                                <ItemsControl ItemsSource="{Binding ToolCalls}"
                                                                                              IsVisible="{Binding HasToolCalls}"
                                                                                              Margin="0,4,0,0">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate DataType="vmroot:ChatToolCallViewModel">
                                                                                            <Expander Padding="0" MinHeight="0"
                                                                                                      Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                                                      BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                                                      BorderThickness="1"
                                                                                                      CornerRadius="8"
                                                                                                      Margin="0,0,0,4">
                                                                                                <Expander.Header>
                                                                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                                                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/external-link.svg"
                                                                                                                          Width="13" Height="13"
                                                                                                                          Color="{DynamicResource TextSecondaryBrush}"/>
                                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                                   FontFamily="{DynamicResource Font.Monospace}"
                                                                                                                   FontSize="11"
                                                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                                                   VerticalAlignment="Center"/>
                                                                                                        <TextBlock Text="{Binding Summary}"
                                                                                                                   FontSize="11"
                                                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                                                   VerticalAlignment="Center"/>
                                                                                                    </StackPanel>
                                                                                                </Expander.Header>
                                                                                                <StackPanel Spacing="6" Margin="12,6,12,10">
                                                                                                    <TextBlock Text="Arguments" FontSize="10" FontFamily="{DynamicResource Font.SemiBold}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                                                    <TextBlock Text="{Binding Arguments}" FontFamily="{DynamicResource Font.Monospace}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                                                    <TextBlock Text="Result" FontSize="10" FontFamily="{DynamicResource Font.SemiBold}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                                                                                    <TextBlock Text="{Binding Result}" FontFamily="{DynamicResource Font.Monospace}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                                                </StackPanel>
                                                                                            </Expander>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <components:MarkdownView Source="{Binding Thoughts}"
                                                                                     IsVisible="{Binding IsThinking}"
                                                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                     Margin="0,0,0,4"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Assistant message content in a card -->
                                            <Border Grid.Row="2" Grid.Column="1"
                                                    Background="{DynamicResource WorkspaceBackgroundBrush}"
                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4,16,16,16"
                                                    Padding="16,12"
                                                    BoxShadow="0 1 3 0 #06000000"
                                                    MinWidth="0">
                                                <components:MarkdownView Source="{Binding Content}"
                                                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                                                         StreamingUpdateIntervalMs="{Binding IsStreaming, Converter={StaticResource BoolToStreamingIntervalConverter}}"/>
                                            </Border>

                                            <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Sources}" Margin="0,8,0,0" MinWidth="0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="8,4"
                                                                Margin="0,0,6,6">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                                  Width="12" Height="12"
                                                                                  Color="{DynamicResource TextSecondaryBrush}"/>
                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Suggestions}" Margin="0,10,0,0" HorizontalAlignment="Stretch" MinWidth="0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="SuggestionChip" Margin="0,0,8,8"
                                                                Command="{Binding #ChatRoot.DataContext, Converter={StaticResource ChatViewModelDataContextCommandConverter}, ConverterParameter=Suggestion}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                                       FontFamily="{DynamicResource Font.Medium}"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,6,0,0" HorizontalAlignment="Left">
                                                <Button Classes="MessageActionIcon"
                                                        Command="{Binding #ChatRoot.DataContext, Converter={StaticResource ChatViewModelDataContextCommandConverter}, ConverterParameter=Regenerate}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="{markup:T Ns=Chat, Key=Regenerate}">
                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/refresh.svg"
                                                                      Width="18" Height="18"
                                                                      Color="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <Button Classes="MessageActionIcon"
                                                        Command="{Binding #ChatRoot.DataContext, Converter={StaticResource ChatViewModelDataContextCommandConverter}, ConverterParameter=Copy}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="{markup:T Ns=Chat, Key=CopyMessage}"
                                                        IsEnabled="{Binding HasCopiableAssistantContent}">
                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/copy.svg"
                                                                      Width="18" Height="18"
                                                                      Color="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                            </StackPanel>
                                    </Grid>

                                    <!-- User Message -->
                                    <Grid IsVisible="{Binding IsUser}" HorizontalAlignment="Right" MaxWidth="480">
                                        <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                CornerRadius="16,16,4,16"
                                                Padding="16,12"
                                                BorderThickness="0">
                                            <StackPanel Spacing="8">
                                                <ItemsControl ItemsSource="{Binding Attachments}"
                                                             IsVisible="{Binding HasAttachments}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:ChatAttachmentViewModel">
                                                            <Panel Margin="0,0,8,8">
                                                                <!-- Image Attachment (clickable to open overlay preview) -->
                                                                <Button Command="{Binding #ChatRoot.DataContext, Converter={StaticResource ChatViewModelDataContextCommandConverter}, ConverterParameter=OpenImagePreview}"
                                                                        CommandParameter="{Binding Path}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Padding="0"
                                                                        CornerRadius="12"
                                                                        ClipToBounds="True"
                                                                        Cursor="Hand"
                                                                        IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Image}">
                                                                    <Border CornerRadius="12"
                                                                            ClipToBounds="True"
                                                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                            BorderThickness="1"
                                                                            Background="{DynamicResource CardBackgroundPrimaryBrush}">
                                                                        <Image Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}"
                                                                               Stretch="Uniform"
                                                                               MaxWidth="128"
                                                                               MaxHeight="128"
                                                                               MinWidth="32"
                                                                               MinHeight="32"/>
                                                                    </Border>
                                                                </Button>

                                                                <!-- File Attachment -->
                                                                <Border Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="10,8"
                                                                        IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=File}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                        <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                                                CornerRadius="6"
                                                                                Padding="6">
                                                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                                              Width="16" Height="16"
                                                                                              Color="{DynamicResource TextPrimaryBrush}"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   FontFamily="{DynamicResource Font.Medium}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   MaxWidth="200"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>

                                                                <!-- Voice Attachment -->
                                                                 <Border Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="16"
                                                                        Padding="12,8"
                                                                        IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Voice}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                                        <Button Background="{DynamicResource CardAccentBrush}"
                                                                                CornerRadius="10"
                                                                                Width="24" Height="24"
                                                                                Padding="4"
                                                                                Cursor="Hand"
                                                                                BorderThickness="0">
                                                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-play.svg"
                                                                                              Width="14" Height="14"
                                                                                              Color="{DynamicResource AccentButtonIconBrush}"/>
                                                                        </Button>
                                                                         <!-- Waveform visualization (static for now) -->
                                                                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Height="16" Opacity="0.8">
                                                                             <Border Width="2" Height="8" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.6"/>
                                                                             <Border Width="2" Height="12" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.8"/>
                                                                             <Border Width="2" Height="6" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.5"/>
                                                                             <Border Width="2" Height="14" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.9"/>
                                                                             <Border Width="2" Height="10" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.7"/>
                                                                             <Border Width="2" Height="12" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.8"/>
                                                                             <Border Width="2" Height="8" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.6"/>
                                                                             <Border Width="2" Height="4" CornerRadius="1" Background="{DynamicResource TextPrimaryBrush}" Opacity="0.4"/>
                                                                        </StackPanel>
                                                                        
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontSize="{DynamicResource FontSize.Body.Caption}"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   FontFamily="{DynamicResource Font.Medium}"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="4,0,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Panel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding Content}"
                                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"
                                                           LineHeight="20"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Floating Recording UI -->
            <Border IsVisible="{Binding IsRecording}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,12"
                    Background="{DynamicResource CardBackgroundPrimaryBrush}"
                    CornerRadius="24"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1"
                    Padding="16,8"
                    BoxShadow="0 4 16 0 #20000000">
                <Grid ColumnDefinitions="Auto, *, Auto, Auto" VerticalAlignment="Center">
                    <!-- Status & Timer -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Border Width="10" Height="10" CornerRadius="5" Background="#FFEF4444">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Style.Animations>
                                        <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                            <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                            <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                            <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Border.Styles>
                        </Border>
                        <TextBlock Text="{Binding RecordingDurationText}" 
                                   FontSize="{DynamicResource FontSize.Body.Default}"
                                   FontFamily="{DynamicResource Font.Monospace}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Visual Waveform Placeholder -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" Height="20" VerticalAlignment="Center" Margin="0,0,24,0">
                        <Border Width="3" Height="10" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.5"/>
                        <Border Width="3" Height="16" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                        <Border Width="3" Height="12" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                        <Border Width="3" Height="20" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.9"/>
                        <Border Width="3" Height="14" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                        <Border Width="3" Height="18" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="1.0"/>
                        <Border Width="3" Height="12" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                        <Border Width="3" Height="16" CornerRadius="1.5" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.9"/>
                    </StackPanel>

                    <!-- Actions -->
                     <Button Grid.Column="2" 
                            Command="{Binding CancelRecordingCommand}" 
                            Classes="PromptActionButton" 
                            ToolTip.Tip="{markup:T Ns=Common, Key=Cancel}" 
                            Margin="0,0,8,0">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg" 
                                          Width="20" Height="20" 
                                          Color="{DynamicResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Grid.Column="3" 
                            Command="{Binding StopRecordingCommand}" 
                            Background="{DynamicResource CardAccentBrush}" 
                            CornerRadius="12" 
                            Width="36" Height="36" 
                            Padding="8" 
                            BorderThickness="0"
                            ToolTip.Tip="{markup:T Ns=Chat, Key=Stop}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-pause.svg" 
                                          Width="16" Height="16" 
                                          Color="{DynamicResource AccentButtonIconBrush}"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Input area (aligned with messages: 75% width center column) -->
        <Grid Grid.Row="2" RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*,6*,*" MinWidth="0">
            <Button x:Name="ScrollToBottomButton"
                    Classes="ScrollToBottomLink"
                    Grid.Row="0"
                    Grid.Column="1"
                    IsVisible="{Binding ShowScrollToBottomButton}"
                    Command="{Binding ScrollToBottomCommand}"
                    Padding="0,6,0,0"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center">
                <TextBlock Text="{markup:T Ns=Chat, Key=ScrollToBottom}"
                           FontSize="{DynamicResource FontSize.Body.Caption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Button>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    MinWidth="0"
                    Padding="24,16,24,0">
                <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                        CornerRadius="16"
                        BoxShadow="0 2 12 -4 #0D000000"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        Padding="0">
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                        <!-- Pending Attachments -->
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding PendingAttachments}" Margin="14,10,14,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatAttachmentViewModel">
                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,4"
                                            Margin="0,0,6,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="36" Height="36" CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource CardBackgroundPrimaryBrush}">
                                                <Grid>
                                                    <Image Width="36" Height="36"
                                                           Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Image}"/>
                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                      Width="16" Height="16"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Color="{DynamicResource TextSecondaryBrush}"
                                                                      IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=File}"/>
                                                    <Border Background="{DynamicResource CardAccentBrush}"
                                                            IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Voice}">
                                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-play.svg"
                                                                          Width="14" Height="14"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Color="{DynamicResource AccentButtonIconBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       MaxWidth="120"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Command="{Binding RemoveCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="PromptActionButton"
                                                    Padding="2"
                                                    VerticalAlignment="Center">
                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg"
                                                                  Width="12" Height="12"
                                                                  Color="{DynamicResource TextSecondaryBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Text input -->
                        <TextBox x:Name="InputBox"
                                 Grid.Row="1"
                                 Classes="TransparentBackground"
                                 Watermark="{Binding WatermarkText}"
                                 AcceptsReturn="False"
                                 TextWrapping="Wrap"
                                 MinHeight="48"
                                 MaxHeight="140"
                                 BorderThickness="0"
                                 Background="{DynamicResource TextControlTransparentBackgroundBrush}"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsRecording}"
                                 Padding="16,14,16,6"/>

                        <!-- Toolbar row -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto"
                              MinWidth="0" IsEnabled="{Binding !IsRecording}"
                              Margin="8,0,8,10">
                            <Button Grid.Column="0" Classes="PromptActionButton" Margin="0,0,2,0"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=AddAttachment}" Click="AddAttachment_Click">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/upload.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextFadedBrush}"/>
                            </Button>
                            <Button Grid.Column="1" Classes="PromptActionButton" Margin="0,0,2,0"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=AddImage}" Click="AddImage_Click">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/polaroid.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextFadedBrush}"/>
                            </Button>
                            <Button Grid.Column="2" Classes="PromptActionButton" Margin="0,0,4,0"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=AddScreenshot}" Click="AddScreenshot_Click">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/screenshot.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextFadedBrush}"/>
                            </Button>
                            <controls:ModernComboBox Grid.Column="3"
                                                      Classes="PromptPill"
                                                      ItemsSource="{Binding AssistantModes}"
                                                      SelectedItem="{Binding SelectedAssistantMode}"
                                                      MinWidth="80"
                                                      Margin="0,0,6,0"
                                                      ToolTip.Tip="{markup:T Ns=Chat, Key=AssistantMode}">
                                <controls:ModernComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource AssistantModeToLabelConverter}}"
                                                   FontSize="{DynamicResource FontSize.Body.Caption}"
                                                   FontFamily="{DynamicResource Font.Medium}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </controls:ModernComboBox.ItemTemplate>
                            </controls:ModernComboBox>
                            <Border Grid.Column="4" MinWidth="0"/>
                            <Button Grid.Column="5" Classes="PromptActionButton" Margin="0,0,6,0"
                                    ToolTip.Tip="{markup:T Ns=Chat, Key=VoiceInput}"
                                    Command="{Binding StartRecordingCommand}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/microphone.svg"
                                                  Width="16" Height="16"
                                                  Color="{DynamicResource TextFadedBrush}"/>
                            </Button>
                            <Panel Grid.Column="6">
                                <Button Command="{Binding SendMessageCommand}"
                                        IsVisible="{Binding !IsBusy}"
                                        Background="{DynamicResource CardAccentBrush}"
                                        Foreground="{DynamicResource AccentButtonIconBrush}"
                                        Padding="8"
                                        CornerRadius="8"
                                        BorderThickness="0"
                                        Width="32" Height="32"
                                        ToolTip.Tip="{markup:T Ns=Chat, Key=SendEnter}">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                      Width="16" Height="16"
                                                      Color="{DynamicResource AccentButtonIconBrush}">
                                        <controls:SvgIcon.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </controls:SvgIcon.RenderTransform>
                                    </controls:SvgIcon>
                                </Button>
                                <Button Command="{Binding StopCommand}"
                                        IsVisible="{Binding IsBusy}"
                                        Background="{DynamicResource StopButtonBackgroundBrush}"
                                        Foreground="{DynamicResource StopButtonForegroundBrush}"
                                        Padding="8"
                                        CornerRadius="8"
                                        BorderThickness="0"
                                        Width="32" Height="32"
                                        ToolTip.Tip="{markup:T Ns=Chat, Key=Stop}">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-pause.svg"
                                                      Width="16" Height="16"
                                                      Color="{DynamicResource StopButtonForegroundBrush}"/>
                                </Button>
                            </Panel>
                        </Grid>
                    </Grid>
                </Border>
            </Border>

            <!-- Disclaimer -->
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{markup:T Ns=Chat, Key=Disclaimer}"
                       HorizontalAlignment="Center"
                       FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                       Foreground="{DynamicResource TextFadedBrush}"
                       FontFamily="{DynamicResource Font.Medium}"
                       Margin="0,10,0,16"/>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
