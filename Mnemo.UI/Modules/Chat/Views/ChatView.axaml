<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Chat.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:markup="using:Mnemo.UI.Markup"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="Mnemo.UI.Modules.Chat.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             x:Name="ChatRoot">

    <UserControl.Resources>
        <converters:BoolToStreamingIntervalConverter x:Key="BoolToStreamingIntervalConverter"/>
        <converters:AssistantModeToLabelConverter x:Key="AssistantModeToLabelConverter"/>
        <converters:LocalPathToBitmapConverter x:Key="LocalPathToBitmapConverter"/>
        <converters:ChatAttachmentKindToBoolConverter x:Key="ChatAttachmentKindToBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.SuggestionChip">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.PromptActionButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
        </Style>

        <Style Selector="Button.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
            </Style>
        </Style>

        <Style Selector="controls|ModernComboBox.PromptPill">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Caption}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Font.Medium}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="Button.ScrollToBottomLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.ScrollToBottomLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.ScrollToBottomLink:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="40,20,40,40">
        <!-- Header (matches RightSidebar assistant) -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,24">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Background="{DynamicResource CardAccentBrush}"
                        Padding="10" CornerRadius="10"
                        VerticalAlignment="Center"
                        BoxShadow="0 2 8 0 #15000000">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                      Width="22" Height="22"
                                      Color="{DynamicResource AccentButtonIconBrush}"/>
                </Border>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{markup:T Ns=Chat, Key=Atlas}"
                               FontSize="{DynamicResource FontSize.Body.Large}"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{markup:T Ns=Chat, Key=AskAnything}"
                               FontSize="{DynamicResource FontSize.Body.Caption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{Binding NewChatCommand}"
                    Background="Transparent"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardAccentBrush}"
                    CornerRadius="8"
                    Padding="12,6"
                    VerticalAlignment="Center">
                <TextBlock Text="{markup:T Ns=Chat, Key=NewChat}" FontWeight="Medium"/>
            </Button>
        </Grid>

        <!-- Messages (same layout as RightSidebar) -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <Border HorizontalAlignment="Stretch" MinWidth="0" Padding="0,0,16,0">
                <ItemsControl ItemsSource="{Binding Messages}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ChatMessageViewModel">
                            <Panel Margin="0,0,0,24" MinWidth="0">
                                <!-- Assistant Message -->
                                <Grid ColumnDefinitions="Auto, *" IsVisible="{Binding !IsUser}" MinWidth="0">
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                            Background="{DynamicResource CardAccentBrush}"
                                            Margin="0,2,12,0" VerticalAlignment="Top"
                                            BoxShadow="0 2 6 0 #15000000">
                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/chart-bubble.svg"
                                                          Width="14" Height="14"
                                                          Color="{DynamicResource AccentButtonIconBrush}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                        <TextBlock Text="{markup:T Ns=Chat, Key=Atlas}"
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   FontFamily="{DynamicResource Font.SemiBold}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <Expander IsVisible="{Binding IsThinking}"
                                                  Padding="0" MinHeight="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Margin="-12,0,0,0">
                                            <Expander.Header>
                                                <TextBlock Text="{markup:T Ns=Chat, Key=ThoughtProcess}"
                                                           FontSize="{DynamicResource FontSize.Body.Caption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontStyle="Italic"/>
                                            </Expander.Header>
                                            <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                    CornerRadius="8" Padding="12" Margin="12,0,0,0"
                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Thoughts}"
                                                           FontSize="{DynamicResource FontSize.Body.Caption}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </Expander>

                                        <!-- Single MarkdownView: throttled live re-renders while streaming, immediate when done -->
                                        <components:MarkdownView Source="{Binding Content}"
                                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 StreamingUpdateIntervalMs="{Binding IsStreaming, Converter={StaticResource BoolToStreamingIntervalConverter}}"/>

                                        <ItemsControl ItemsSource="{Binding Sources}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="0,0,6,6">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                              Width="12" Height="12"
                                                                              Color="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding Suggestions}" Margin="0,12,0,0" HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}"
                                                            Classes="SuggestionChip" Margin="0,0,8,8"
                                                            Command="{Binding #ChatRoot.DataContext.SuggestionSelectedCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>

                                <!-- User Message -->
                                <Grid IsVisible="{Binding IsUser}" HorizontalAlignment="Right" MaxWidth="400">
                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18,18,4,18"
                                            Padding="14,10"
                                            BoxShadow="0 1 4 0 #05000000">
                                        <StackPanel Spacing="8">
                                            <ItemsControl ItemsSource="{Binding Attachments}"
                                                         IsVisible="{Binding HasAttachments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:ChatAttachmentViewModel">
                                                        <Panel Margin="0,0,8,8">
                                                            <!-- Image Attachment (clickable to open overlay preview) -->
                                                            <Button Command="{Binding #ChatRoot.DataContext.OpenImagePreviewCommand}"
                                                                    CommandParameter="{Binding Path}"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Padding="0"
                                                                    CornerRadius="12"
                                                                    ClipToBounds="True"
                                                                    Cursor="Hand"
                                                                    IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Image}">
                                                                <Border CornerRadius="12"
                                                                        ClipToBounds="True"
                                                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                        BorderThickness="1"
                                                                        Background="{DynamicResource CardBackgroundPrimaryBrush}">
                                                                    <Image Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}"
                                                                           Stretch="Uniform"
                                                                           MaxWidth="128"
                                                                           MaxHeight="128"
                                                                           MinWidth="32"
                                                                           MinHeight="32"/>
                                                                </Border>
                                                            </Button>

                                                            <!-- File Attachment -->
                                                            <Border Background="{DynamicResource CardBackgroundPrimaryBrush}"
                                                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="10,8"
                                                                    IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=File}">
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                                                            CornerRadius="6"
                                                                            Padding="6">
                                                                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                                          Width="16" Height="16"
                                                                                          Color="{DynamicResource TextPrimaryBrush}"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               FontFamily="{DynamicResource Font.Medium}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="200"
                                                                               VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Panel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <!-- Scroll to bottom hint (visible when user has scrolled up) + Input area -->
        <Grid Grid.Row="2" RowDefinitions="Auto, Auto">
            <Button x:Name="ScrollToBottomButton"
                    Classes="ScrollToBottomLink"
                    Grid.Row="0"
                    IsVisible="{Binding ShowScrollToBottomButton}"
                    Command="{Binding ScrollToBottomCommand}"
                    Padding="0,8,0,0"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center">
                <TextBlock Text="{markup:T Ns=Chat, Key=ScrollToBottom}"
                           FontSize="{DynamicResource FontSize.Body.Caption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Button>
            <Border Grid.Row="1" Padding="0,24,0,0" Background="Transparent">
            <Border Background="{DynamicResource CardBackgroundPrimaryBrush}"
                    CornerRadius="16"
                    BoxShadow="0 4 12 0 #10000000"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    Padding="12,12">
                <Grid RowDefinitions="Auto, Auto, Auto">
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding PendingAttachments}" Margin="0,0,0,6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ChatAttachmentViewModel">
                                <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,4"
                                        Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <!-- Image preview for image attachments; file icon for others -->
                                        <Border Width="36" Height="36" CornerRadius="6"
                                                ClipToBounds="True"
                                                Background="{DynamicResource CardBackgroundPrimaryBrush}">
                                            <Grid>
                                                <Image Width="36" Height="36"
                                                       Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=Image}"/>
                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                  Width="16" Height="16"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Color="{DynamicResource TextSecondaryBrush}"
                                                                  IsVisible="{Binding Kind, Converter={StaticResource ChatAttachmentKindToBoolConverter}, ConverterParameter=File}"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   MaxWidth="120"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button Command="{Binding RemoveCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="PromptActionButton"
                                                Padding="2"
                                                VerticalAlignment="Center">
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg"
                                                              Width="12" Height="12"
                                                              Color="{DynamicResource TextSecondaryBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox x:Name="InputBox"
                             Grid.Row="1"
                             Classes="TransparentBackground"
                             Watermark="{markup:T Ns=Chat, Key=AskPlaceholder}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="40"
                             MaxHeight="120"
                             BorderThickness="0"
                             Background="{DynamicResource TextControlTransparentBackgroundBrush}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="InputBox_KeyDown"
                             Padding="4"
                             Margin="0,0,0,8"/>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto" MinWidth="0">
                        <Button Grid.Column="0" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=AddAttachment}" Click="AddAttachment_Click">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/upload.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Grid.Column="1" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=AddImage}" Click="AddImage_Click">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/polaroid.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Grid.Column="2" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=AddScreenshot}" Click="AddScreenshot_Click">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/screenshot.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <controls:ModernComboBox Grid.Column="3"
                                                  Classes="PromptPill"
                                                  ItemsSource="{Binding AssistantModes}"
                                                  SelectedItem="{Binding SelectedAssistantMode}"
                                                  MinWidth="80"
                                                  Margin="0,0,6,0"
                                                  ToolTip.Tip="{markup:T Ns=Chat, Key=AssistantMode}">
                            <controls:ModernComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource AssistantModeToLabelConverter}}"
                                               FontSize="{DynamicResource FontSize.Body.Caption}"
                                               FontFamily="{DynamicResource Font.Medium}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </controls:ModernComboBox.ItemTemplate>
                        </controls:ModernComboBox>
                        <Border Grid.Column="4" MinWidth="0"/>
                        <Button Grid.Column="5" Classes="PromptActionButton" Margin="0,0,6,0" ToolTip.Tip="{markup:T Ns=Chat, Key=VoiceInput}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/microphone.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Grid.Column="6"
                                Command="{Binding SendMessageCommand}"
                                IsVisible="{Binding !IsBusy}"
                                Background="{DynamicResource CardAccentBrush}"
                                Foreground="{DynamicResource AccentButtonIconBrush}"
                                Padding="8"
                                CornerRadius="10"
                                BorderThickness="0"
                                Width="32" Height="32"
                                ToolTip.Tip="{markup:T Ns=Chat, Key=SendEnter}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource AccentButtonIconBrush}">
                                <controls:SvgIcon.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </controls:SvgIcon.RenderTransform>
                            </controls:SvgIcon>
                        </Button>
                        <Button Grid.Column="5"
                                Command="{Binding StopCommand}"
                                IsVisible="{Binding IsBusy}"
                                Background="{DynamicResource StopButtonBackgroundBrush}"
                                Foreground="{DynamicResource StopButtonForegroundBrush}"
                                Padding="8"
                                CornerRadius="10"
                                BorderThickness="0"
                                Width="32" Height="32"
                                ToolTip.Tip="{markup:T Ns=Chat, Key=Stop}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-pause.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource StopButtonForegroundBrush}"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
