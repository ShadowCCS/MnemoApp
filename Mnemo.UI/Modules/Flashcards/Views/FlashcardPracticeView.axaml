<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Flashcards.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:blockEditor="using:Mnemo.UI.Components.BlockEditor"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:conv="using:Mnemo.UI.Converters"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="Mnemo.UI.Modules.Flashcards.Views.FlashcardPracticeView"
             x:DataType="vm:FlashcardPracticeViewModel"
             Foreground="{DynamicResource TextPrimaryBrush}"
             Focusable="True">

    <UserControl.Resources>
        <conv:LocalPathToBitmapConverter x:Key="LocalPathToBitmapConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.hotkeyChip">
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
        <Style Selector="Border.hotkeyChipWide">
            <Setter Property="Padding" Value="12,1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
        <Style Selector="TextBlock.practiceFieldLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.6" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
    </UserControl.Styles>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Space" Command="{Binding FlipCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding ExitToDeckCommand}"/>
        <KeyBinding Gesture="D1" Command="{Binding GradeAgainCommand}"/>
        <KeyBinding Gesture="D2" Command="{Binding GradeHardCommand}"/>
        <KeyBinding Gesture="D3" Command="{Binding GradeGoodCommand}"/>
        <KeyBinding Gesture="D4" Command="{Binding GradeEasyCommand}"/>
        <KeyBinding Gesture="NumPad1" Command="{Binding QuickGradeLearningHotkeyCommand}"/>
        <KeyBinding Gesture="NumPad2" Command="{Binding QuickGradeGotItHotkeyCommand}"/>
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="20,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource CardBackgroundSecondaryBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Command="{Binding ExitToLibraryCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="{Binding FolderName}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="{DynamicResource Font.SemiBold}" />
                    </Button>
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                      Color="{DynamicResource TextTertiaryBrush}"
                                      Width="12"
                                      Height="12"
                                      VerticalAlignment="Center" />
                    <Button Command="{Binding ExitToDeckCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="{Binding DeckName}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="{DynamicResource Font.SemiBold}" />
                    </Button>
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                      Color="{DynamicResource TextTertiaryBrush}"
                                      Width="12"
                                      Height="12"
                                      VerticalAlignment="Center" />
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionReview}" IsVisible="{Binding IsReviewSession}" FontFamily="{DynamicResource Font.SemiBold}"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionQuick}" IsVisible="{Binding IsQuickSession}" FontFamily="{DynamicResource Font.SemiBold}"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionFocused}" IsVisible="{Binding IsFocusedSession}" FontFamily="{DynamicResource Font.SemiBold}"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionCram}" IsVisible="{Binding IsCramSession}" FontFamily="{DynamicResource Font.SemiBold}"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionTest}" IsVisible="{Binding IsTestSession}" FontFamily="{DynamicResource Font.SemiBold}"/>
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                      Color="{DynamicResource TextTertiaryBrush}"
                                      Width="12"
                                      Height="12"
                                      VerticalAlignment="Center"
                                      IsVisible="{Binding IsReviewSession}" />
                    <TextBlock Text="{Binding SchedulingEngineLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSize.Body.Small}"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               IsVisible="{Binding IsReviewSession}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <ProgressBar Width="200" Height="6" Maximum="100" Value="{Binding ProgressPercent}"/>
                    <TextBlock Text="{Binding ProgressText}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="2" Classes="ghost" Command="{Binding ExitToDeckCommand}" Padding="12,8" CornerRadius="10">
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=ExitPractice}"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <Panel Margin="24">
                <!-- Nothing to study -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20"
                            IsVisible="{Binding ShowEmptyQueue}">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Flashcard/Practice/award.svg"
                                      Width="64" Height="64" Color="{DynamicResource AccentPrimaryBrush}"
                                      HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeEmptyTitle}"
                               FontSize="{DynamicResource FontSize.Heading1}" FontFamily="{DynamicResource Font.Bold}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeEmptyDesc}"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="420"
                               HorizontalAlignment="Center" TextAlignment="Center" FontSize="{DynamicResource FontSize.Body.Medium}"/>
                    <Button HorizontalAlignment="Center" Command="{Binding ExitToDeckCommand}" Classes="accent" MinHeight="48" MinWidth="160" CornerRadius="10" Margin="0,12,0,0">
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=BackToDeck}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                    </Button>
                </StackPanel>

                <!-- Session summary -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" MaxWidth="500"
                            IsVisible="{Binding ShowSummary}">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Flashcard/Practice/award.svg"
                                      Width="64" Height="64" Color="{DynamicResource AccentPrimaryBrush}"
                                      HorizontalAlignment="Center" Opacity="0.8"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeCompleteTitle}"
                                   FontSize="{DynamicResource FontSize.Heading1}" FontFamily="{DynamicResource Font.Bold}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeCompleteDesc}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center" FontSize="{DynamicResource FontSize.Body.Medium}"/>
                    </StackPanel>
                    <UniformGrid Columns="2" Margin="0,8" IsVisible="{Binding ShowCorrectIncorrectSummary}">
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding CorrectCount}" FontSize="36" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource SystemSuccessBackgroundBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=CorrectLabel}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding IncorrectCount}" FontSize="36" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource DestructiveButtonColorBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=IncorrectLabel}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <UniformGrid Columns="4" Margin="0,8" IsVisible="{Binding ShowGradeDistributionSummary}">
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding AgainCount}" FontSize="30" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource DestructiveButtonColorBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeAgain}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding HardCount}" FontSize="30" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeHard}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding GoodCount}" FontSize="30" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeGood}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="8" Padding="20" CornerRadius="16"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                BoxShadow="0 4 12 0 #1A000000">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding EasyCount}" FontSize="30" FontFamily="{DynamicResource Font.Bold}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource SystemSuccessBackgroundBrush}"/>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeEasy}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Padding="12" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource WorkspaceBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=SummaryDurationLabel}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding SummaryDuration}" FontFamily="{DynamicResource Font.SemiBold}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Padding="12" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource WorkspaceBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=SummaryAccuracyLabel}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding SummaryAccuracy}" FontFamily="{DynamicResource Font.SemiBold}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="12" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Background="{DynamicResource WorkspaceBackgroundBrush}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=SummaryNextDueLabel}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding SummaryNextDue}" FontFamily="{DynamicResource Font.SemiBold}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <Button Command="{Binding ExitToDeckCommand}" MinHeight="48" MinWidth="160" CornerRadius="10" Classes="secondary">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=BackToDeck}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                        </Button>
                        <Button Command="{Binding RestartSessionCommand}" MinHeight="48" MinWidth="160" CornerRadius="10" Classes="accent">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=StudyAgain}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Active card -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20"
                            IsVisible="{Binding ShowActivePractice}">
                    <Border Background="{DynamicResource CardBackgroundSecondaryBrush}" CornerRadius="22"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0"
                            MinWidth="620" Width="760" MinHeight="320" MaxHeight="420"
                            BoxShadow="0 16 40 -24 #45000000">
                        <Grid RowDefinitions="*,Auto">
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="32">
                        <StackPanel Spacing="0">
                            <!-- Front side: always visible while the card is active. Markdown view + image carousel
                                 live in the same stack so spacing is consistent whether the card has text, images,
                                 or both. -->
                            <StackPanel Spacing="16" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <TextBlock Classes="practiceFieldLabel"
                                           Text="{markup:T Ns=Flashcards, Key=FieldFront}"
                                           Foreground="{DynamicResource DestructiveButtonColorBrush}" />
                                <blockEditor:RichTextEditor IsReadOnly="True"
                                                            IsHitTestVisible="False"
                                                            Cursor="Arrow"
                                                            Spans="{Binding CurrentFrontSpans}"
                                                            HorizontalAlignment="Stretch" />
                                <ItemsControl ItemsSource="{Binding CurrentFrontImages}"
                                              IsVisible="{Binding HasFrontImages}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:FlashcardPracticeImage">
                                            <Image MaxHeight="180" MaxWidth="660" Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Reveal divider + back side. Wrapping both in an outer container bound to IsFlipped
                                 guarantees the back never paints or measures until the user has explicitly flipped;
                                 we do not just hide the inner Border so that the practice UX cannot briefly flash
                                 the answer during rebinds/data-context swaps. -->
                            <StackPanel Spacing="0" IsVisible="{Binding IsFlipped}">
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,32" />
                                <StackPanel Spacing="16" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                    <TextBlock Classes="practiceFieldLabel"
                                               Text="{markup:T Ns=Flashcards, Key=FieldBack}"
                                               Foreground="{DynamicResource SystemSuccessBackgroundBrush}" />
                                    <blockEditor:RichTextEditor IsReadOnly="True"
                                                                IsHitTestVisible="False"
                                                                Cursor="Arrow"
                                                                Spans="{Binding CurrentBackSpans}"
                                                                HorizontalAlignment="Stretch" />
                                    <ItemsControl ItemsSource="{Binding CurrentBackImages}"
                                                  IsVisible="{Binding HasBackImages}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="12" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:FlashcardPracticeImage">
                                                <Image MaxHeight="180" MaxWidth="660" Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       Source="{Binding Path, Converter={StaticResource LocalPathToBitmapConverter}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0"
                                Padding="20,6"
                                IsVisible="{Binding !IsTestSession}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeRevealPrefix}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                           FontFamily="{DynamicResource Font.SemiBold}" />
                                <Border Classes="hotkeyChipWide">
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeRevealSpacebar}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource Font.SemiBold}" />
                                </Border>
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeRevealSuffix}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                           FontFamily="{DynamicResource Font.SemiBold}" />
                            </StackPanel>
                        </Border>
                        </Grid>
                    </Border>

                    <!-- Test: answer before reveal -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsTestSession}" MaxWidth="620" HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsFlipped}" Margin="0,10,0,0">
                            <TextBox Grid.Column="0" MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap"
                                     Watermark="{markup:T Ns=Flashcards, Key=TestAnswerPlaceholder}"
                                     Text="{Binding TestAnswer}"
                                     CornerRadius="8"
                                     Margin="0,0,16,0"
                                     FontSize="{DynamicResource FontSize.Body.Medium}"/>
                            <Button Grid.Column="1" VerticalAlignment="Stretch" Command="{Binding RevealTestCommand}" Classes="accent" CornerRadius="8">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=TestReveal}" VerticalAlignment="Center" Margin="16,0" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </Button>
                        </Grid>
                        <Border IsVisible="{Binding IsFlipped}" Background="{DynamicResource WidgetBackgroundPrimaryBrush}" 
                                CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=TestYourAnswer}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSize.Body.Small}"/>
                                <TextBlock Text="{Binding TestAnswer}" TextWrapping="Wrap"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           FontSize="{DynamicResource FontSize.Body.Medium}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <Button MinWidth="240" MinHeight="48" Command="{Binding FlipCommand}" IsVisible="{Binding ShowFlipButton}" Classes="accent">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=Flip}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                        </Button>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center"
                                    IsVisible="{Binding ShowQuickGrades}">
                            <Button MinWidth="140" MinHeight="48" Command="{Binding GradeLearningCommand}" Classes="secondary">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeLearning}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </Button>
                            <Button MinWidth="140" MinHeight="48" Command="{Binding GradeGotItCommand}" Classes="accent">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeGotIt}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center"
                                    IsVisible="{Binding ShowStandardGrades}">
                            <Button MinWidth="110" MinHeight="48" Command="{Binding GradeAgainCommand}" Classes="secondary" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}">
                                <StackPanel>
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeAgain}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding NextAgainInterval}" HorizontalAlignment="Center" FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </Button>
                            <Button MinWidth="110" MinHeight="48" Command="{Binding GradeHardCommand}" Classes="secondary" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}">
                                <StackPanel>
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeHard}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding NextHardInterval}" HorizontalAlignment="Center" FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </Button>
                            <Button MinWidth="110" MinHeight="48" Command="{Binding GradeGoodCommand}" Classes="secondary" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}">
                                <StackPanel>
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeGood}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding NextGoodInterval}" HorizontalAlignment="Center" FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </Button>
                            <Button MinWidth="110" MinHeight="48" Command="{Binding GradeEasyCommand}" Classes="accent" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}">
                                <StackPanel>
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeEasy}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding NextEasyInterval}" HorizontalAlignment="Center" FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center"
                                    IsVisible="{Binding ShowTestGrades}">
                            <Button MinWidth="140" MinHeight="48" Command="{Binding TestIncorrectCommand}" Classes="secondary">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=TestIncorrect}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </Button>
                            <Button MinWidth="140" MinHeight="48" Command="{Binding TestCorrectCommand}" Classes="accent">
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=TestCorrect}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.SemiBold}"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"
                                    IsVisible="{Binding ShowStandardGrades}">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeKeyboardShortcutsLabel}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="1" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeAgain}" VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="2" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeHard}" VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="3" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeGood}" VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="4" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeEasy}" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"
                                    IsVisible="{Binding ShowQuickGrades}">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=PracticeKeyboardShortcutsLabel}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="1" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeLearning}" VerticalAlignment="Center" />
                            <Border Classes="hotkeyChip">
                                <TextBlock Text="2" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=GradeGotIt}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>
