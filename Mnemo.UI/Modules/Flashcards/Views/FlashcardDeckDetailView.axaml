<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Flashcards.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:models="using:Mnemo.Core.Models.Flashcards"
             xmlns:conv="using:Mnemo.UI.Converters"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="Mnemo.UI.Modules.Flashcards.Views.FlashcardDeckDetailView"
             x:DataType="vm:FlashcardDeckDetailViewModel"
             Foreground="{DynamicResource TextPrimaryBrush}"
             x:Name="root">

    <UserControl.Resources>
        <conv:FlashcardDueDateIsDueConverter x:Key="FlashcardDueIsDueConverter" />
        <conv:FlashcardDueDateIsFutureDayConverter x:Key="FlashcardDueIsFutureDayConverter" />
        <conv:FlashcardDueDateToShortDateConverter x:Key="FlashcardDueShortDateConverter" />
        <conv:FlashcardTypeToBadgeConverter x:Key="FlashcardTypeBadgeConverter" />
        <conv:FlashcardHasClozeMarkersConverter x:Key="FlashcardHasClozeMarkersConverter" />
        <conv:FlashcardCollapsedPreviewConverter x:Key="FlashcardCollapsedPreviewConverter" />
        <conv:FlashcardRowIsExpandedMultiConverter x:Key="FlashcardRowExpandedConverter" />
        <conv:FlashcardRowIsCollapsedMultiConverter x:Key="FlashcardRowCollapsedConverter" />
        <conv:BoolNegationConverter x:Key="BoolNegateConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>
        <Style Selector="Slider">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>

        <!-- Floating cards list -->
        <Style Selector="ListBox.flashcard-deck-list">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
        </Style>
        <Style Selector="ListBox.flashcard-deck-list ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <!-- Let nested editors (RichTextEditor) receive focus/pointer; the item stays selected via content interaction. -->
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="ListBox.flashcard-deck-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.flashcard-deck-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.flashcard-deck-list ListBoxItem Border.card-row-host">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 6 0 #08000000" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.flashcard-deck-list ListBoxItem:selected Border.card-row-host">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="BoxShadow" Value="0 4 14 0 #15000000" />
        </Style>
        <Style Selector="ListBox.flashcard-deck-list ListBoxItem:pointerover Border.card-row-host">
            <Setter Property="BoxShadow" Value="0 4 14 0 #15000000" />
        </Style>

        <Style Selector="Border.fc-pill-track">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style Selector="Button.fc-pill-segment">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}" />
        </Style>
        <Style Selector="Button.fc-pill-segment:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundHoverBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.fc-pill-segment.selected">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.fc-pill-segment.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.fc-pill-segment TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Regular}" />
        </Style>
        <Style Selector="Button.fc-pill-segment.selected TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
        <Style Selector="TextBox.fc-editor-multiline">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="96" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}" />
        </Style>
        <Style Selector="TextBox.fc-editor-tags">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}" />
        </Style>
        <Style Selector="TextBlock.fc-field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.6" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
        <Style Selector="Border.fc-preview-panel">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Border.fc-preview-panel TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Border.fc-preview-panel components|MarkdownView">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="MenuFlyout MenuItem">
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Animated editor container: appears via opacity fade + a brief downward slide. MaxHeight is large enough to fit any realistic card editor; bounding is handled by the outer ScrollViewer. -->
        <Style Selector="Border.fc-editor-reveal">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(-6px)" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.fc-editor-reveal.is-expanded">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0px)" />
        </Style>

        <!-- Small derived "Cloze" chip shown only when the card's Front contains {{cN::…}} markers. -->
        <Style Selector="Border.fc-cloze-chip">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
        </Style>
        <Style Selector="Border.fc-cloze-chip TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.4" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <Border Margin="32,24,32,120" MaxWidth="880" HorizontalAlignment="Stretch">
                <StackPanel Spacing="24" HorizontalAlignment="Stretch">

                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <Button Grid.Column="0" Classes="ghost" Command="{Binding GoBackCommand}"
                            Padding="4" VerticalAlignment="Center" ToolTip.Tip="{markup:T Ns=Common, Key=Back}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-left.svg"
                                          Width="20" Height="20" Color="{DynamicResource TextSecondaryBrush}" />
                    </Button>
                    <Border Grid.Column="1"
                            Margin="4,0,16,0"
                            Padding="6,2"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,1">
                        <Border.Styles>
                            <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="{DynamicResource WidgetBackgroundHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Style>
                            <Style Selector="Border:focus-within">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
                            </Style>
                        </Border.Styles>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0" Text="{Binding DeckName}"
                                     Watermark="{markup:T Ns=Flashcards, Key=DefaultDeckName}"
                                     FontSize="{DynamicResource FontSize.Heading3}" FontFamily="{DynamicResource Font.Bold}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalAlignment="Center" />
                            <controls:SvgIcon Grid.Column="1"
                                              SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/pencil.svg"
                                              Width="14"
                                              Height="14"
                                              Opacity="0.7"
                                              Color="{DynamicResource TextSecondaryBrush}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border CornerRadius="12" BoxShadow="0 4 12 0 #20000000">
                            <Button Classes="accent" Command="{Binding OpenStudyLauncherCommand}"
                                    BorderThickness="0" Padding="16,10" CornerRadius="12">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-play.svg"
                                                      Width="16" Height="16"
                                                      Color="{DynamicResource AccentButtonForegroundBrush}" />
                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=Practice}"
                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                               FontFamily="{DynamicResource Font.SemiBold}"
                                               Foreground="{DynamicResource AccentButtonForegroundBrush}" />
                                </StackPanel>
                            </Button>
                        </Border>
                        <Button Background="{DynamicResource WorkspaceBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="12" Padding="10,8"
                                ToolTip.Tip="{markup:T Ns=Flashcards, Key=DeckMenu}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/dots-vertical.svg"
                                              Width="18" Height="18" Color="{DynamicResource TextSecondaryBrush}" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="{markup:T Ns=Flashcards, Key=RenameDeck}" Command="{Binding RenameDeckCommand}">
                                        <MenuItem.Icon>
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg" Width="16" Height="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{markup:T Ns=Flashcards, Key=DuplicateDeck}" Command="{Binding DuplicateDeckCommand}">
                                        <MenuItem.Icon>
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/copy.svg" Width="16" Height="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Classes="danger" Header="{markup:T Ns=Flashcards, Key=DeleteDeck}" Command="{Binding DeleteDeckCommand}">
                                        <MenuItem.Icon>
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/trashbin.svg" Width="16" Height="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16" MinHeight="80">
                    <Border Grid.Column="0" Padding="16,14" CornerRadius="16"
                            Background="{DynamicResource WorkspaceBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            BoxShadow="0 2 8 0 #04000000">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalCardsCount}"
                                       FontSize="28" FontFamily="{DynamicResource Font.Bold}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=MetricTotalCards}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{DynamicResource Font.SemiBold}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16,14" CornerRadius="16"
                            Background="{DynamicResource WorkspaceBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            BoxShadow="0 2 8 0 #04000000">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DueTodayCount}"
                                       FontSize="28" FontFamily="{DynamicResource Font.Bold}"
                                       Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=MetricDueToday}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{DynamicResource Font.SemiBold}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="16,14" CornerRadius="16"
                            Background="{DynamicResource WorkspaceBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            BoxShadow="0 2 8 0 #04000000">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RetentionPercent, StringFormat={}{0}%}"
                                       FontSize="28" FontFamily="{DynamicResource Font.Bold}"
                                       Foreground="{DynamicResource SystemSuccessBackgroundBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=MetricRetention}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{DynamicResource Font.SemiBold}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{DynamicResource WorkspaceBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18,14">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{markup:T Ns=Flashcards, Key=RetentionTrend}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{markup:T Ns=Flashcards, Key=RetentionTrendRangeLast14}"
                                       FontSize="11" LetterSpacing="0.4"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Opacity="0.7" />
                        </Grid>
                        <!-- Chart: 100/50/0 guide lines behind, bars in front. UniformGrid Columns=14 stretches bars to full card width.
                             Bar heights are driven by a percent→pixel proxy on the code-behind (0-100 → 0-100px).
                             A subtle accent gradient fill gives the bars visual weight without a sparkline control dependency. -->
                        <Grid Height="120" ClipToBounds="True">
                            <!-- Horizontal guide lines at 0/50/100%. -->
                            <Grid RowDefinitions="*,*,Auto" IsHitTestVisible="False">
                                <Border Grid.Row="0" VerticalAlignment="Top"
                                        Height="1" HorizontalAlignment="Stretch"
                                        Background="{DynamicResource BorderBrush}" Opacity="0.35" />
                                <Border Grid.Row="1" VerticalAlignment="Center"
                                        Height="1" HorizontalAlignment="Stretch"
                                        Background="{DynamicResource BorderBrush}" Opacity="0.2" />
                                <Border Grid.Row="2" VerticalAlignment="Bottom"
                                        Height="1" HorizontalAlignment="Stretch"
                                        Background="{DynamicResource BorderBrush}" Opacity="0.6" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RetentionTrendPointsProxy, ElementName=root}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" Columns="14" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="3,0"
                                                Height="{Binding}"
                                                MinHeight="3"
                                                CornerRadius="3,3,0,0"
                                                VerticalAlignment="Bottom"
                                                Background="{DynamicResource AccentPrimaryBrush}"
                                                Opacity="0.85"
                                                ToolTip.Tip="{Binding StringFormat='{}{0}%'}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,8,0,0"
                      VerticalAlignment="Center">
                    <TextBlock Grid.Column="0"
                               Text="{markup:T Ns=Flashcards, Key=Cards}"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSize.Heading4}"
                               FontFamily="{DynamicResource Font.Bold}" />
                    <Button Grid.Column="1"
                            Classes="accent"
                            Command="{Binding AddCardCommand}"
                            BorderThickness="0"
                            Padding="16,10"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=AddCard}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       Foreground="{DynamicResource AccentButtonForegroundBrush}" />
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/plus.svg"
                                              Width="18"
                                              Height="18"
                                              Color="{DynamicResource AccentButtonForegroundBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Background="Transparent" ClipToBounds="False">
                    <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                    <ListBox x:Name="CardList" Classes="flashcard-deck-list"
                             ItemsSource="{Binding Cards}" SelectedItem="{Binding SelectedCard}"
                             MinHeight="160">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Flashcard">
                                <Border Classes="card-row-host">
                                    <StackPanel Spacing="0" HorizontalAlignment="Stretch">

                                        <Button Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="12"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                Command="{Binding ToggleCardRowCommandProxy, ElementName=root}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{markup:T Ns=Flashcards, Key=EditCard}">
                                            <Button.IsVisible>
                                                <MultiBinding Converter="{StaticResource FlashcardRowCollapsedConverter}">
                                                    <Binding ElementName="root" Path="ExpandedCardIdProxy" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                    <Binding Path="Id" />
                                                </MultiBinding>
                                            </Button.IsVisible>
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="Transparent" />
                                                </Style>
                                                <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="Transparent" />
                                                </Style>
                                            </Button.Styles>

                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="16,16,20,16" VerticalAlignment="Center">
                                                <controls:SvgIcon Grid.Column="0" SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                                  Width="20" Height="20" Margin="4,0,16,0"
                                                                  Color="{DynamicResource TextSecondaryBrush}" />

                                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,16,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Front, Converter={StaticResource FlashcardCollapsedPreviewConverter}}" TextTrimming="CharacterEllipsis"
                                                               FontFamily="{DynamicResource Font.SemiBold}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="{DynamicResource FontSize.Body.Medium}" />
                                                    <TextBlock Text="{Binding Back, Converter={StaticResource FlashcardCollapsedPreviewConverter}}" TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{DynamicResource FontSize.Body.Small}" MaxLines="1" Opacity="0.8" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <Border Classes="fc-cloze-chip"
                                                            IsVisible="{Binding Front, Converter={StaticResource FlashcardHasClozeMarkersConverter}}"
                                                            ToolTip.Tip="{markup:T Ns=Flashcards, Key=ClozeBadgeTooltip}">
                                                        <TextBlock Text="{markup:T Ns=Flashcards, Key=ClozeBadge}" />
                                                    </Border>
                                                    <Border CornerRadius="6"
                                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8,4"
                                                            Background="{DynamicResource CardBackgroundSecondaryBrush}">
                                                        <TextBlock Text="{Binding Type, Converter={StaticResource FlashcardTypeBadgeConverter}}"
                                                                   FontSize="11" LetterSpacing="0.4"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontFamily="{DynamicResource Font.SemiBold}" />
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="76">
                                                    <TextBlock HorizontalAlignment="Right" FontFamily="{DynamicResource Font.SemiBold}"
                                                               FontSize="{DynamicResource FontSize.Body.Small}" Foreground="{DynamicResource AccentPrimaryBrush}"
                                                               Text="{Binding LocalizedCardDueProxy, ElementName=root, FallbackValue='Due', TargetNullValue='Due'}"
                                                               IsVisible="{Binding DueDate, Converter={StaticResource FlashcardDueIsDueConverter}}" />
                                                    <TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                                               Text="{Binding DueDate, Converter={StaticResource FlashcardDueShortDateConverter}}"
                                                               IsVisible="{Binding DueDate, Converter={StaticResource FlashcardDueIsFutureDayConverter}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>

                                        <Border Classes="fc-editor-reveal" Background="Transparent" Padding="0">
                                            <Border.IsVisible>
                                                <MultiBinding Converter="{StaticResource FlashcardRowExpandedConverter}">
                                                    <Binding ElementName="root" Path="ExpandedCardIdProxy" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                    <Binding Path="Id" />
                                                </MultiBinding>
                                            </Border.IsVisible>
                                            <Classes.is-expanded>
                                                <MultiBinding Converter="{StaticResource FlashcardRowExpandedConverter}">
                                                    <Binding ElementName="root" Path="ExpandedCardIdProxy" FallbackValue="{x:Null}" TargetNullValue="{x:Null}" />
                                                    <Binding Path="Id" />
                                                </MultiBinding>
                                            </Classes.is-expanded>

                                            <Border Classes="fc-card-editor-shell" Padding="20,16,20,20">
                                                <StackPanel Spacing="14">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <TextBlock Classes="fc-field-label" Text="{markup:T Ns=Flashcards, Key=CardTypeLabel}" VerticalAlignment="Center" />
                                                        <Border Classes="fc-pill-track">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <Button Classes="fc-pill-segment"
                                                                        Classes.selected="{Binding IsEditorClozeProxy, ElementName=root, Converter={StaticResource BoolNegateConverter}}"
                                                                        Command="{Binding SetEditorClassicTypeCommandProxy, ElementName=root}">
                                                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=TypeClassic}" />
                                                                </Button>
                                                                <Button Classes="fc-pill-segment"
                                                                        Classes.selected="{Binding IsEditorClozeProxy, ElementName=root}"
                                                                        Command="{Binding SetEditorClozeTypeCommandProxy, ElementName=root}">
                                                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=TypeCloze}" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Classes="fc-field-label" Text="{markup:T Ns=Flashcards, Key=FieldFront}" />
                                                        <controls:RichDocumentEditor x:Name="FrontRichEditor"
                                                                                     Tag="{Binding Id}"
                                                                                     AttachedToVisualTree="OnFrontEditorAttached"
                                                                                     DetachedFromVisualTree="OnEditorDetached"
                                                                                     Spans="{Binding EditorFrontSpansProxy, ElementName=root, Mode=OneWay}"
                                                                                     Watermark="{markup:T Ns=Flashcards, Key=Front}"
                                                                                     ShowModeToggle="False"
                                                                                     WriteLabel="{markup:T Ns=Flashcards, Key=Write}"
                                                                                     PreviewLabel="{markup:T Ns=Flashcards, Key=Preview}"
                                                                                     KeyDown="OnEditorKeyDown" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Classes="fc-field-label" Text="{markup:T Ns=Flashcards, Key=FieldBack}" />
                                                        <controls:RichDocumentEditor x:Name="BackRichEditor"
                                                                                     Tag="{Binding Id}"
                                                                                     AttachedToVisualTree="OnBackEditorAttached"
                                                                                     DetachedFromVisualTree="OnEditorDetached"
                                                                                     Spans="{Binding EditorBackSpansProxy, ElementName=root, Mode=OneWay}"
                                                                                     Watermark="{markup:T Ns=Flashcards, Key=Back}"
                                                                                     ShowModeToggle="False"
                                                                                     IsReadOnly="{Binding IsEditorBackEditableProxy, ElementName=root, Converter={StaticResource BoolNegateConverter}}"
                                                                                     WriteLabel="{markup:T Ns=Flashcards, Key=Write}"
                                                                                     PreviewLabel="{markup:T Ns=Flashcards, Key=Preview}"
                                                                                     KeyDown="OnEditorKeyDown" />
                                                    </StackPanel>

                                                    <StackPanel Spacing="6">
                                                        <TextBlock Classes="fc-field-label" Text="{markup:T Ns=Flashcards, Key=TagsLabel}" />
                                                        <controls:TagChipInput
                                                            TagsText="{Binding EditorTagsProxy, ElementName=root, Mode=TwoWay, FallbackValue='', TargetNullValue=''}"
                                                            Placeholder="{markup:T Ns=Flashcards, Key=TagAddPlaceholder}" />
                                                    </StackPanel>

                                                    <!-- Single consolidated footer. Fitts's Law: grouping the three primary exit paths (Revert, Done, Cloze helper)
                                                         on the right puts them within short mouse travel of each other; Delete stays on the far left with visual
                                                         separation so destructive and non-destructive actions are not adjacent. -->
                                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
                                                        <Button Grid.Column="0" Classes="ghost" Padding="8,6" HorizontalAlignment="Left"
                                                                Command="{Binding DeleteCardCommandProxy, ElementName=root, FallbackValue={x:Null}, TargetNullValue={x:Null}}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/trashbin.svg"
                                                                                  Width="16" Height="16"
                                                                                  Color="{DynamicResource DestructiveButtonColorBrush}" />
                                                                <TextBlock Text="{markup:T Ns=Flashcards, Key=DeleteCard}"
                                                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                                                           Foreground="{DynamicResource DestructiveButtonColorBrush}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                            <!-- Focusable=False keeps keyboard focus on the RichTextEditor so the click handler can read the live selection before wrapping it in {{cN::…}}. -->
                                                            <Button Classes="ghost" Padding="10,6"
                                                                    Focusable="False"
                                                                    Click="OnInsertClozeClick"
                                                                    IsVisible="{Binding IsEditorClozeProxy, ElementName=root}"
                                                                    ToolTip.Tip="{markup:T Ns=Flashcards, Key=MakeClozeTooltip}">
                                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                    <TextBlock Text="[…]"
                                                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                                                               FontFamily="{DynamicResource Font.SemiBold}"
                                                                               Foreground="{DynamicResource AccentPrimaryBrush}" />
                                                                    <TextBlock Text="{markup:T Ns=Flashcards, Key=InsertCloze}"
                                                                               FontSize="{DynamicResource FontSize.Body.Small}"
                                                                               Foreground="{DynamicResource AccentPrimaryBrush}" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="ghost" Padding="10,6"
                                                                    Command="{Binding RevertEditCommandProxy, ElementName=root, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    ToolTip.Tip="{markup:T Ns=Flashcards, Key=RevertTooltip}">
                                                                <TextBlock Text="{markup:T Ns=Flashcards, Key=Revert}"
                                                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            </Button>
                                                            <Button Classes="accent" Padding="14,6" CornerRadius="10"
                                                                    Command="{Binding CloseExpandedCardCommandProxy, ElementName=root, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                                                    ToolTip.Tip="{markup:T Ns=Flashcards, Key=DoneCardTooltip}">
                                                                <TextBlock Text="{markup:T Ns=Flashcards, Key=DoneCard}"
                                                                           FontSize="{DynamicResource FontSize.Body.Small}"
                                                                           FontFamily="{DynamicResource Font.SemiBold}"
                                                                           Foreground="{DynamicResource AccentButtonForegroundBrush}" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Persistent "Add another card" row — fixed to the end of the list so users authoring many cards never need to scroll back up. -->
                    <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            Padding="16,12" CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="{DynamicResource WorkspaceBackgroundBrush}"
                            Command="{Binding AddCardCommand}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <controls:SvgIcon Grid.Column="0"
                                              SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/plus.svg"
                                              Width="18" Height="18"
                                              Color="{DynamicResource AccentPrimaryBrush}"
                                              VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{markup:T Ns=Flashcards, Key=AddAnotherCard}"
                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    </StackPanel>
                </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

    </Panel>
</UserControl>
