<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Flashcards.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="760"
             d:DesignHeight="560"
             x:Class="Mnemo.UI.Modules.Flashcards.Views.StudySessionLauncherOverlay"
             x:DataType="vm:FlashcardDeckDetailViewModel">
    <UserControl.Styles>
        <Style Selector="Border.sessionCard">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="MinHeight" Value="186" />
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.sessionCardPrimary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}" />
            <Setter Property="MinHeight" Value="126" />
        </Style>
        <Style Selector="TextBlock.sessionTitle">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Heading4}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
        <Style Selector="TextBlock.sessionDescription">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}" />
        </Style>
        <Style Selector="Button.sessionAction">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="TextBlock.sectionLabel">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Heading4}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
    </UserControl.Styles>

    <Border MaxWidth="860"
            Margin="24"
            Padding="30"
            CornerRadius="24"
            Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            BoxShadow="0 18 44 0 #42000000">
        <StackPanel Spacing="22">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{markup:T Ns=Flashcards, Key=SessionTitle}"
                           FontSize="{DynamicResource FontSize.Heading1}"
                           FontFamily="{DynamicResource Font.Bold}" />
                <Button Grid.Column="1"
                        Classes="ghost"
                        Command="{Binding CloseStudyLauncherCommand}"
                        Padding="8">
                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg"
                                      Width="20"
                                      Height="20"
                                      Color="{DynamicResource TextSecondaryBrush}" />
                </Button>
            </Grid>
            <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionModesHelp}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="{DynamicResource FontSize.Body.Medium}" />

            <Border Classes="sessionCard sessionCardPrimary" Padding="20,16">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionPrimaryBadge}"
                               Foreground="{DynamicResource AccentPrimaryBrush}"
                               FontFamily="{DynamicResource Font.SemiBold}"
                               FontSize="12"
                               LetterSpacing="0.4" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <TextBlock Grid.Column="0"
                                   Text="{markup:T Ns=Flashcards, Key=SessionReview}"
                                   FontSize="{DynamicResource FontSize.Heading2}"
                                   FontFamily="{DynamicResource Font.Bold}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Classes="accent"
                                MinWidth="154"
                                MinHeight="40"
                                Padding="18,8"
                                Command="{Binding StartReviewSessionCommand}"
                                CornerRadius="12"
                                VerticalAlignment="Center">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionReviewStart}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       Foreground="{DynamicResource AccentButtonForegroundBrush}" />
                        </Button>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Text="{Binding ReviewSessionDescription}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               FontSize="{DynamicResource FontSize.Body.Medium}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="sectionLabel"
                           Text="{markup:T Ns=Flashcards, Key=Practice}" />
                <TextBlock Grid.Column="1"
                           Text="{markup:T Ns=Flashcards, Key=SessionPracticeNoSchedule}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSize.Body.Small}"
                           VerticalAlignment="Center" />
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                <Border Grid.Column="0" Classes="sessionCard">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <TextBlock Classes="sessionTitle"
                                   Text="{markup:T Ns=Flashcards, Key=SessionQuick}" />
                        <TextBlock Grid.Row="1"
                                   Classes="sessionDescription"
                                   Text="{markup:T Ns=Flashcards, Key=SessionQuickDesc}" />
                        <Button Grid.Row="2"
                                Classes="sessionAction secondary"
                                Command="{Binding StartQuickSessionCommand}">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionQuickStart}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource Font.SemiBold}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="sessionCard">
                    <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="12">
                        <TextBlock Classes="sessionTitle"
                                   Text="{markup:T Ns=Flashcards, Key=SessionCram}" />
                        <TextBlock Grid.Row="1"
                                   Classes="sessionDescription"
                                   Text="{markup:T Ns=Flashcards, Key=SessionCramDesc}" />
                        <CheckBox Grid.Row="2"
                                  Content="{markup:T Ns=Flashcards, Key=Shuffle}"
                                  IsChecked="{Binding CramShuffle}"
                                  Margin="0,2,0,0" />
                        <Button Grid.Row="3"
                                Classes="sessionAction secondary"
                                Command="{Binding StartCramSessionCommand}">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionCramStart}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource Font.SemiBold}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Classes="sessionCard">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <TextBlock Classes="sessionTitle"
                                   Text="{markup:T Ns=Flashcards, Key=SessionTest}" />
                        <TextBlock Grid.Row="1"
                                   Classes="sessionDescription"
                                   Text="{markup:T Ns=Flashcards, Key=SessionTestDesc}" />
                        <Button Grid.Row="2"
                                Classes="sessionAction secondary"
                                Command="{Binding StartTestSessionCommand}">
                            <TextBlock Text="{markup:T Ns=Flashcards, Key=SessionTestStart}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource Font.SemiBold}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
