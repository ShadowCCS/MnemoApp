<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Flashcards.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:models="using:Mnemo.Core.Models.Flashcards"
             xmlns:flashcardsVm="using:Mnemo.UI.Modules.Flashcards.ViewModels"
             xmlns:views="using:Mnemo.UI.Modules.Flashcards.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="Mnemo.UI.Modules.Flashcards.Views.FlashcardsView"
             x:DataType="vm:FlashcardsViewModel"
             Foreground="{DynamicResource TextPrimaryBrush}"
             x:Name="root"
             ClipToBounds="False">

    <UserControl.Styles>
        <Style Selector="Border.library-pane">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style Selector="Button.library-nav">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.library-nav:pointerover">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style Selector="Button.library-nav:pressed">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>

        <Style Selector="TextBlock.library-section">
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.ExtraSmall}" />
            <Setter Property="Margin" Value="12,10,0,8" />
        </Style>

        <Style Selector="Border.library-divider">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Margin" Value="12,10" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Border.search-surface">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style Selector="TextBox.deck-search">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,2,0,2" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Medium}" />
        </Style>

        <!-- Deck cards: Border only (no Button / ContentPresenter theme = no square grey plate) -->
        <Style Selector="Border.deck-card">
            <Setter Property="Width" Value="280" />
            <Setter Property="MinHeight" Value="168" />
            <Setter Property="Margin" Value="0,0,20,20" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BoxShadow" Value="0 6 18 -10 #3A000000" />
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.deck-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="BoxShadow" Value="0 18 36 -8 #46000000" />
        </Style>
        <Style Selector="Border.deck-card:pressed">
            <Setter Property="BoxShadow" Value="0 10 22 -8 #3A000000" />
        </Style>

        <Style Selector="ItemsControl.deck-library-grid WrapPanel > ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Border.deck-due-pill">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <SplitView DisplayMode="Inline"
                   IsPaneOpen="{Binding IsSidebarOpen}"
                   OpenPaneLength="280"
                   CompactPaneLength="0"
                   Background="Transparent">
            <SplitView.Pane>
                <!-- Library sidebar -->
                <Border Classes="library-pane">
                    <ScrollViewer>
                        <StackPanel Margin="16,20,16,16" Spacing="4">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                            <TextBlock Grid.Column="0"
                                       Classes="library-section"
                                       Text="{markup:T Ns=Flashcards, Key=Title}" />
                            <Button Grid.Column="1"
                                    Command="{Binding ToggleSidebarCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6"
                                    CornerRadius="8"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{markup:T Ns=Flashcards, Key=ToggleSidebar}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                                  Width="18"
                                                  Height="18"
                                                  Color="{DynamicResource TextSecondaryBrush}" />
                            </Button>
                        </Grid>

                        <Button Classes="ghost library-nav"
                                Command="{Binding SelectAllDecksCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/book.svg"
                                                  Width="18" Height="18" Color="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=AllDecks}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Classes="ghost library-nav"
                                Command="{Binding SelectDueDecksCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/bell.svg"
                                                  Width="18" Height="18" Color="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=DueToday}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Border Classes="library-divider" />

                        <Grid ColumnDefinitions="*,Auto" Margin="12,4,8,4">
                            <TextBlock Grid.Column="0"
                                       Text="{markup:T Ns=Flashcards, Key=Folders}"
                                       FontFamily="{DynamicResource Font.SemiBold}"
                                       FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding CreateFolderCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4"
                                    ToolTip.Tip="{markup:T Ns=Flashcards, Key=NewFolder}">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/folder-plus-corner.svg"
                                                  Width="16"
                                                  Height="16"
                                                  Color="{DynamicResource TextSecondaryBrush}" />
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding FlatFolderItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="flashcardsVm:FlashcardFolderItemViewModel">
                                    <views:FlashcardFolderRow />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </SplitView.Pane>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" ClipToBounds="False">
                <StackPanel Margin="36,28,36,32" Spacing="28" ClipToBounds="False">

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Command="{Binding ToggleSidebarCommand}"
                            IsVisible="{Binding !IsSidebarOpen}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="6"
                            CornerRadius="8"
                            VerticalAlignment="Top"
                            ToolTip.Tip="{markup:T Ns=Flashcards, Key=ToggleSidebar}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                          Width="20"
                                          Height="20"
                                          Color="{DynamicResource TextSecondaryBrush}" />
                    </Button>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=Title}"
                                   FontSize="{DynamicResource FontSize.Heading1}"
                                   FontFamily="{DynamicResource Font.Bold}" />
                        <TextBlock Text="{markup:T Ns=Flashcards, Key=Subtitle}"
                                   FontSize="{DynamicResource FontSize.Body.Medium}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="ghost"
                                Padding="10,8"
                                Click="OnTransferClick"
                                Tag="transfer">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/upload.svg"
                                                  Width="16" Height="16" />
                                <TextBlock Text="Transfer" />
                            </StackPanel>
                        </Button>
                        <Button VerticalAlignment="Center"
                                Classes="accent"
                                Command="{Binding CreateDeckCommand}"
                                BorderThickness="0"
                                Padding="16,10" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/plus.svg"
                                                  Width="18" Height="18"
                                                  Color="{DynamicResource AccentButtonForegroundBrush}" />
                                <TextBlock Text="{markup:T Ns=Flashcards, Key=NewDeck}"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           Foreground="{DynamicResource AccentButtonForegroundBrush}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Classes="search-surface" Width="420" MaxWidth="560" HorizontalAlignment="Left">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <controls:SvgIcon Grid.Column="0"
                                          SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/search.svg"
                                          Width="18" Height="18"
                                          VerticalAlignment="Center"
                                          Color="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Grid.Column="1"
                                 Classes="deck-search"
                                 Text="{Binding SearchText}"
                                 HorizontalAlignment="Stretch"
                                 Watermark="{markup:T Ns=Flashcards, Key=SearchPlaceholder}" />
                    </Grid>
                </Border>

                <ItemsControl Classes="deck-library-grid" ItemsSource="{Binding FilteredDecks}" ClipToBounds="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ClipToBounds="False" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FlashcardDeckRowViewModel">
                            <Border Classes="deck-card"
                                    PointerPressed="OnDeckCardPointerPressed"
                                    PointerMoved="OnDeckCardPointerMoved"
                                    PointerReleased="OnDeckCardPointerReleased">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Border Width="24" Height="24"
                                                    Background="{DynamicResource WidgetBackgroundPrimaryBrush}"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Top">
                                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/file-text.svg"
                                                                  Width="14" Height="14"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Color="{DynamicResource TextSecondaryBrush}" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}" TextWrapping="Wrap"
                                                       FontFamily="{DynamicResource Font.SemiBold}"
                                                       FontSize="{DynamicResource FontSize.Heading3}"
                                                       MaxLines="2" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Top" Margin="0,0,8,0" />
                                        </Grid>
                                        <Button Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Command="{Binding #root.StartQuickSessionCommandProxy}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding ShowDueBadge}"
                                                ToolTip.Tip="{markup:T Ns=Flashcards, Key=SessionQuickStart}">
                                            <Border Classes="deck-due-pill"
                                                    VerticalAlignment="Top">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/player-play.svg"
                                                                      Width="12" Height="12" Color="{DynamicResource AccentPrimaryBrush}" />
                                                    <TextBlock Text="{Binding DueBadgeText}"
                                                               FontSize="12"
                                                               FontFamily="{DynamicResource Font.SemiBold}"
                                                               Foreground="{DynamicResource AccentPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                        <Button Grid.Column="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4"
                                                CornerRadius="8">
                                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/dots-vertical.svg"
                                                              Width="16" Height="16"
                                                              Color="{DynamicResource TextSecondaryBrush}" />
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuItem Header="{markup:T Ns=Flashcards, Key=OpenDeck}"
                                                              Command="{Binding #root.OpenDeckCommandProxy}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="{markup:T Ns=Flashcards, Key=Practice}"
                                                              Command="{Binding #root.StartQuickSessionCommandProxy}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="Rename"
                                                              Tag="{Binding}"
                                                              Click="OnDeckRenameClick" />
                                                    <MenuItem Header="Duplicate"
                                                              Tag="{Binding}"
                                                              Click="OnDeckDuplicateClick" />
                                                    <MenuItem Header="Export"
                                                              Tag="{Binding}"
                                                              Click="OnDeckExportClick" />
                                                    <MenuItem Header="Settings"
                                                              Command="{Binding #root.OpenDeckSettingsCommandProxy}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Classes="danger"
                                                              Header="{markup:T Ns=Flashcards, Key=DeleteDeck}"
                                                              Command="{Binding #root.DeleteDeckCommandProxy}"
                                                              CommandParameter="{Binding}" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="8" Margin="0,12,0,12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{markup:T Ns=Flashcards, Key=DeckRetentionLabel}"
                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding RetentionScore, StringFormat={}{0}%}"
                                                       FontSize="{DynamicResource FontSize.Body.Small}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </Grid>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding #root.StartQuickSessionCommandProxy}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{markup:T Ns=Flashcards, Key=SessionQuickStart}">
                                            <ProgressBar Minimum="0" Maximum="100"
                                                         Value="{Binding RetentionPercent}"
                                                         Height="6" CornerRadius="3"
                                                         Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Button>
                                    </StackPanel>

                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding CardCountLine}"
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding LastStudiedLine}"
                                                   FontSize="{DynamicResource FontSize.Body.Small}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </SplitView>

        <Canvas x:Name="DragOverlayCanvas" IsHitTestVisible="False" ZIndex="999" />
    </Panel>
</UserControl>
