<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Notes.ViewModels"
             xmlns:models="using:Mnemo.Core.Models"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:blockEditor="using:Mnemo.UI.Components.BlockEditor"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:views="using:Mnemo.UI.Modules.Notes.Views"
             xmlns:markup="using:Mnemo.UI.Markup"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Mnemo.UI.Modules.Notes.Views.NotesView"
             x:DataType="vm:NotesViewModel"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextSecondaryBrush}">

    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolInvertedConverter" Invert="True" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
    </UserControl.Resources>

    <!-- DataTemplate for note/folder rows — used by TreeView ItemTemplate (drag-drop and folder icons in NoteTreeRow) -->
    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:NoteTreeItemViewModel">
            <views:NoteTreeRow />
        </DataTemplate>
    </UserControl.DataTemplates>

    <SplitView DisplayMode="Inline"
               IsPaneOpen="{Binding IsSidebarOpen}"
               OpenPaneLength="280"
               Background="Transparent"
               IsVisible="{Binding !IsLoading}"
               PaneBackground="{DynamicResource NotesPaneBackgroundBrush}">
        <SplitView.Pane>
            <Border BorderThickness="0,0,1,0" BorderBrush="{DynamicResource NotesPaneDividerBrush}"
                    HorizontalAlignment="Stretch" x:Name="SidebarPaneBorder" ClipToBounds="True">
                <!-- Panel stacks pane content + drag overlay canvas -->
                <Panel>
                <Grid RowDefinitions="Auto,*" x:Name="SidebarPaneGrid">
                    <Grid.Resources>
                        <x:Double x:Key="TreeViewItemIndent">8</x:Double>
                        <x:Double x:Key="TreeViewItemMinHeight">28</x:Double>
                    </Grid.Resources>
                    <Grid.Styles>
                        <Style Selector="controls|MnemoTreeViewItem /template/ Panel#PART_ExpandCollapseChevronContainer">
                            <Setter Property="Margin" Value="2,0,4,0"/>
                        </Style>
                        <Style Selector="controls|MnemoTreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                        <Style Selector="controls|MnemoTreeViewItem /template/ Grid#PART_Header">
                            <Setter Property="MinWidth" Value="0"/>
                        </Style>
                        <Style Selector="controls|MnemoTreeViewItem /template/ Border#PART_LayoutRoot">
                            <Setter Property="MinWidth" Value="0"/>
                        </Style>
                    </Grid.Styles>
                    <!-- Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,12,10,8">
                        <TextBlock Text="{markup:T Ns=Notes, Key=Notes}"
                                   FontSize="{DynamicResource FontSize.Heading2}"
                                   FontFamily="{DynamicResource Font.Bold}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <!-- Collapse Button -->
                        <Button Grid.Column="1" Command="{Binding ToggleSidebarCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6"
                                Cursor="Hand" ToolTip.Tip="{markup:T Ns=Notes, Key=ToggleSidebar}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                              Width="20" Height="20"
                                              Color="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" x:Name="SidebarScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="6,0,6,8" Spacing="4">
                            <!-- Favorites -->
                            <StackPanel IsVisible="{Binding FavouriteNotes.Count}">
                                <TextBlock Text="{markup:T Ns=Notes, Key=Favourites}" 
                                           Margin="4,4,4,2"
                                           FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <controls:MnemoTreeView ItemsSource="{Binding FavouriteNotes}"
                                          SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          Background="Transparent" BorderThickness="0">
                                    <controls:MnemoTreeView.Styles>
                                        <Style Selector="controls|MnemoTreeViewItem">
                                            <Setter Property="ExpandOnHeaderClick" Value="False"/>
                                        </Style>
                                    </controls:MnemoTreeView.Styles>
                                </controls:MnemoTreeView>
                                <Rectangle Height="1" Fill="{DynamicResource NotesPaneDividerBrush}" Margin="2,6,2,6" Opacity="0.5"/>
                            </StackPanel>

                            <!-- My Notes (Folders + Notes) -->
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4,2,4,2">
                                <TextBlock Text="{markup:T Ns=Notes, Key=MyNotes}"
                                           FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                           FontFamily="{DynamicResource Font.SemiBold}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Command="{Binding NewNoteCommand}"
                                        Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,2,0"
                                        Cursor="Hand" ToolTip.Tip="{markup:T Ns=Notes, Key=NewNote}">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/circle-plus.svg"
                                                      Width="16" Height="16"
                                                      Color="{DynamicResource TextTertiaryBrush}"/>
                                </Button>
                                <Button Grid.Column="2" Command="{Binding NewFolderCommand}"
                                        Background="Transparent" BorderThickness="0" Padding="4"
                                        Cursor="Hand" ToolTip.Tip="{markup:T Ns=Notes, Key=NewFolder}">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/folder-plus-corner.svg"
                                                      Width="16" Height="16"
                                                      Color="{DynamicResource TextTertiaryBrush}"/>
                                </Button>
                            </Grid>
                            
                            <!-- My Notes tree area (drop on tree or empty space below = move to root) -->
                            <Border x:Name="MyNotesTreeArea" Background="Transparent" MinHeight="80">
                                <controls:MnemoTreeView x:Name="MyNotesTreeView"
                                          ItemsSource="{Binding RootTreeItems}"
                                          SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          Background="Transparent"
                                          BorderThickness="0">
                                    <controls:MnemoTreeView.Styles>
                                        <Style Selector="controls|MnemoTreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <Setter Property="ExpandOnHeaderClick" Value="False"/>
                                        </Style>
                                        <!-- Folders are not selectable: folder-item never shows selected appearance -->
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="{DynamicResource TreeViewItemBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource TreeViewItemBorderBrush}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ Border#PART_LayoutRoot > ContentPresenter#PART_HeaderPresenter">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForeground}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ ContentPresenter#PART_HeaderPresenter TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForeground}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ ContentPresenter#PART_HeaderPresenter controls|SvgIcon">
                                            <Setter Property="Color" Value="{DynamicResource TreeViewItemForeground}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ Border#PART_LayoutRoot:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundPointerOver}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource TreeViewItemBorderBrushPointerOver}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected /template/ Border#PART_LayoutRoot:pointerover > ContentPresenter#PART_HeaderPresenter">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForegroundPointerOver}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected:pointerover /template/ ContentPresenter#PART_HeaderPresenter TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForegroundPointerOver}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:selected:pointerover /template/ ContentPresenter#PART_HeaderPresenter controls|SvgIcon">
                                            <Setter Property="Color" Value="{DynamicResource TreeViewItemForegroundPointerOver}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:pressed:selected /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundPressed}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource TreeViewItemBorderBrushPressed}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:pressed:selected /template/ Border#PART_LayoutRoot > ContentPresenter#PART_HeaderPresenter">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForegroundPressed}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:pressed:selected /template/ ContentPresenter#PART_HeaderPresenter TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForegroundPressed}"/>
                                        </Style>
                                        <Style Selector="controls|MnemoTreeViewItem.folder-item:pressed:selected /template/ ContentPresenter#PART_HeaderPresenter controls|SvgIcon">
                                            <Setter Property="Color" Value="{DynamicResource TreeViewItemForegroundPressed}"/>
                                        </Style>
                                    </controls:MnemoTreeView.Styles>
                                    <controls:MnemoTreeView.ItemTemplate>
                                        <TreeDataTemplate DataType="vm:NoteTreeItemViewModel" ItemsSource="{Binding Children}">
                                            <ContentPresenter Content="{Binding}"/>
                                        </TreeDataTemplate>
                                    </controls:MnemoTreeView.ItemTemplate>
                                </controls:MnemoTreeView>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <!-- Drag overlay: ZIndex ensures it sits above everything in the pane; IsHitTestVisible=False so rows remain interactive -->
                <Canvas x:Name="DragOverlayCanvas" IsHitTestVisible="False" ZIndex="999"/>
                </Panel>
            </Border>
        </SplitView.Pane>

        <ScrollViewer x:Name="EditorScrollViewer" IsVisible="{Binding !IsLoading}">
            <StackPanel Margin="32,24,32,32" Spacing="0" MaxWidth="{Binding EditorMaxWidth}" HorizontalAlignment="Stretch">
                <!-- Top Bar with Sidebar Toggle and Breadcrumbs -->
                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                    <Button Grid.Column="0" Command="{Binding ToggleSidebarCommand}"
                            IsVisible="{Binding !IsSidebarOpen}"
                            Background="Transparent" BorderThickness="0"
                            Padding="6" Margin="0,0,12,0"
                            Cursor="Hand" ToolTip.Tip="{markup:T Ns=Notes, Key=ToggleSidebar}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout-sidebar.svg"
                                          Width="20" Height="20"
                                          Color="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    
                    <TextBlock Grid.Column="1" Text="{Binding BreadcrumbText}"
                               FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               IsVisible="{Binding BreadcrumbText, Converter={StaticResource NullToBoolConverter}}"/>
                </Grid>

                <!-- Title, metadata, separator and content (visible when a note is selected) -->
                <StackPanel IsVisible="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}" Spacing="0">
                    <!-- Title row with favorite star -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBox Grid.Column="0" Text="{Binding SelectedNoteTitle, Mode=TwoWay}"
                                 MinWidth="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ToolTip.Tip="{Binding SelectedNoteTitle}"
                                 FontSize="{DynamicResource FontSize.Heading1}"
                                 FontFamily="{DynamicResource Font.Bold}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Watermark="{markup:T Ns=Notes, Key=NoteTitlePlaceholder}"
                                 x:Name="NoteTitleBox"/>
                        <Button Grid.Column="1" Command="{Binding ToggleFavoriteCommand}"
                                Background="Transparent" BorderThickness="0" Padding="8,4"
                                Cursor="Hand" ToolTip.Tip="{markup:T Ns=Notes, Key=ToggleFavorite}">
                            <Grid>
                                <controls:SvgIcon x:Name="StarOutline" SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/star.svg"
                                                  Width="22" Height="22" Color="{DynamicResource TextTertiaryBrush}"
                                                  IsVisible="{Binding IsFavorite, Converter={StaticResource BoolNegationConverter}}"/>
                                <controls:SvgIcon x:Name="StarFilled" SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/star.svg"
                                                  Width="22" Height="22" Color="{DynamicResource AccentPrimary}"
                                                  IsVisible="{Binding IsFavorite}"/>
                            </Grid>
                        </Button>
                    </Grid>

                    <!-- Created and last modified -->
                    <TextBlock FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,0,0,16">
                        <Run Text="{Binding CreatedText}"/>
                        <Run Text=" • "/>
                        <Run Text="{Binding ModifiedText}"/>
                    </TextBlock>

                    <!-- Separation line -->
                    <Rectangle Height="1"
                               Fill="{DynamicResource NotesEditorSeparatorBrush}"
                               Margin="0,0,0,24"/>

                    <!-- Editable block content: negative margin so editor receives pointer events in page margins (drag-box start) -->
                    <blockEditor:BlockEditor x:Name="NoteBlockEditor" Margin="-32,0,-32,0"/>
                </StackPanel>

                <!-- Empty state when no note selected -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,48,0,0"
                            Spacing="12">
                    <StackPanel.IsVisible>
                        <Binding Path="SelectedNote" Converter="{StaticResource NullToBoolInvertedConverter}"/>
                    </StackPanel.IsVisible>
                    <TextBlock Text="{markup:T Ns=Notes, Key=SelectOrCreateNote}"
                               FontSize="{DynamicResource FontSize.Body.Medium}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </SplitView>
</UserControl>