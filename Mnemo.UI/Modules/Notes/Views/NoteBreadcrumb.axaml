<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Notes.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="40"
             x:Class="Mnemo.UI.Modules.Notes.Views.NoteBreadcrumb"
             x:DataType="vm:NoteBreadcrumbViewModel"
             IsVisible="{Binding IsVisible}">

    <ItemsControl ItemsSource="{Binding Pieces}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="0"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:NoteBreadcrumbPieceBase">
                <ContentControl Content="{Binding}">
                    <ContentControl.DataTemplates>
                        <!-- Crumb piece (regular breadcrumb item) -->
                        <DataTemplate DataType="vm:NoteBreadcrumbCrumbPieceVm">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <!-- Leading separator -->
                                <controls:SvgIcon IsVisible="{Binding ShowLeadingSeparator}"
                                                  SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                  Color="{DynamicResource TextTertiaryBrush}"
                                                  Width="12"
                                                  Height="12"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0,4,0"/>

                                <!-- Clickable crumb -->
                                <Button Content="{Binding Text}"
                                        Command="{Binding NavigateCommand}"
                                        IsEnabled="{Binding IsClickable}"
                                        ToolTip.Tip="{Binding ToolTipTip}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,2"
                                        MaxWidth="240"
                                        FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                        FontFamily="{DynamicResource Font.SemiBold}">
                                    <Button.Styles>
                                        <Style Selector="Button">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                        <Style Selector="Button:disabled">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </Button.Styles>
                                    <Button.Tag>
                                        <Binding Path="IsClickable"/>
                                    </Button.Tag>
                                </Button>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Ellipsis piece with dropdown -->
                        <DataTemplate DataType="vm:NoteBreadcrumbEllipsisPieceVm">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <!-- Leading separator -->
                                <controls:SvgIcon IsVisible="{Binding ShowLeadingSeparator}"
                                                  SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                  Color="{DynamicResource TextTertiaryBrush}"
                                                  Width="12"
                                                  Height="12"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0,4,0"/>

                                <!-- Ellipsis button with flyout -->
                                <Button Content="..."
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,2"
                                        FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                        FontFamily="{DynamicResource Font.SemiBold}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Cursor="Hand">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </Button.Styles>
                                    <Button.Flyout>
                                        <!-- MenuFlyout + ItemsControl merges items; use Flyout + Buttons for one row per ancestor. -->
                                        <Flyout Placement="BottomEdgeAlignedLeft">
                                            <Border Padding="4,2" MinWidth="120" MaxHeight="280">
                                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding HiddenItems}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Spacing="0"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="vm:NoteBreadcrumbHiddenItemVm">
                                                                <Button Content="{Binding Text}"
                                                                        Command="{Binding NavigateCommand}"
                                                                        IsEnabled="{Binding IsNavigable}"
                                                                        ToolTip.Tip="{Binding ToolTipTip}"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Left"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Padding="10,6"
                                                                        MaxWidth="320"
                                                                        Cursor="Hand"
                                                                        FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                                                                        Foreground="{DynamicResource TextPrimaryBrush}">
                                                                    <Button.Styles>
                                                                        <Style Selector="Button:pointerover">
                                                                            <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundPointerOver}"/>
                                                                        </Style>
                                                                    </Button.Styles>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
