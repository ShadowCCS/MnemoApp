<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mnemo.UI.Modules.Mindmap.ViewModels"
             xmlns:local="using:Mnemo.UI.Modules.Mindmap"
             xmlns:markup="using:Mnemo.UI.Markup"
             xmlns:converters="using:Mnemo.UI.Converters"
             xmlns:controls="using:Mnemo.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Mnemo.UI.Modules.Mindmap.Views.MindmapView"
             x:DataType="vm:MindmapViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.node-editor">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.node-editor:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Node Hover/Selected States -->
        <Style Selector="Border.node-container:pointerover">
            <Setter Property="Background" Value="{DynamicResource MindmapNodeBackgroundHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MindmapNodeBorderHoverBrush}"/>
            <Setter Property="BoxShadow" Value="{DynamicResource MindmapNodeBoxShadowHover}"/>
        </Style>
        <Style Selector="Border.node-container.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource MindmapNodeBorderSelectedBrush}"/>
            <Setter Property="BorderThickness" Value="2.5"/>
            <Setter Property="BoxShadow" Value="{DynamicResource MindmapNodeBoxShadowSelected}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundSecondaryBrush}"/>
        </Style>
        <Style Selector="Border.node-container.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource MindmapNodeBackgroundHoverBrush}"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <local:MindmapContentToTextConverter x:Key="MindmapContentToTextConverter"/>
        <local:NodeToCenterPointConverter x:Key="NodeToCenterPointConverter"/>
        <local:EdgeKindToStrokeDashArrayConverter x:Key="EdgeKindToStrokeDashArrayConverter"/>
        <converters:BoolToBrushConverter x:Key="SelectionBrushConverter" 
                                        TrueBrush="{DynamicResource AccentPrimaryBrush}" 
                                        FalseBrush="Transparent"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <converters:StringToBrushWithFallbackConverter x:Key="MindmapColorToBrushConverter"/>
        <local:MindmapMinSizeConverter x:Key="MindmapMinSizeConverter"/>
        <local:DoubleToCornerRadiusConverter x:Key="DoubleToCornerRadiusConverter"/>
        <local:LayoutAlgorithmToDisplayNameConverter x:Key="LayoutAlgorithmToDisplayNameConverter"/>
        <converters:NullableDoubleToNaNConverter x:Key="NullableDoubleToNaNConverter"/>

        <!-- Node Templates -->
        <DataTemplate x:Key="TextNodeTemplate" DataType="vm:NodeViewModel">
            <Border Name="NodeBorder"
                    Classes="node-container"
                    Classes.selected="{Binding IsSelected}"
                    Background="{DynamicResource CardBackgroundSecondaryBrush}"
                    BorderThickness="1.5"
                    CornerRadius="{Binding CornerRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}"
                    MinWidth="{Binding EffectiveMinSize, Converter={StaticResource MindmapMinSizeConverter}, ConverterParameter=80}"
                    MinHeight="{Binding EffectiveMinSize, Converter={StaticResource MindmapMinSizeConverter}, ConverterParameter=40}"
                    Padding="12,6"
                    Cursor="Hand"
                    BoxShadow="{DynamicResource MindmapNodeBoxShadow}">
                <Border.Styles>
                    <Style Selector="Border#NodeBorder">
                        <Setter Property="BorderBrush" Value="{Binding Color, Converter={StaticResource MindmapColorToBrushConverter}, ConverterParameter=MindmapNodeBorderBrush}"/>
                    </Style>
                    <Style Selector="Border#NodeBorder.selected">
                        <Setter Property="BorderBrush" Value="{DynamicResource MindmapNodeBorderSelectedBrush}"/>
                        <Setter Property="BorderThickness" Value="2.5"/>
                        <Setter Property="BoxShadow" Value="{DynamicResource MindmapNodeBoxShadowSelected}"/>
                    </Style>
                    <Style Selector="Border#NodeBorder:pointerover">
                        <Setter Property="Background" Value="{DynamicResource MindmapNodeBackgroundHoverBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MindmapNodeBorderHoverBrush}"/>
                        <Setter Property="BoxShadow" Value="{DynamicResource MindmapNodeBoxShadowHover}"/>
                    </Style>
                    <Style Selector="Border#NodeBorder.selected:pointerover">
                        <Setter Property="Background" Value="{DynamicResource MindmapNodeBackgroundHoverBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MindmapNodeBorderSelectedBrush}"/>
                    </Style>
                </Border.Styles>
                <TextBox Text="{Binding Text}"
                         Classes="node-editor"
                         IsReadOnly="{Binding IsSelected, Converter={StaticResource BoolNegationConverter}}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         TextWrapping="NoWrap"
                         AcceptsReturn="False"
                         FontSize="14"
                         FontWeight="Medium"
                         LostFocus="OnNodeTextBoxLostFocus"
                         TextChanged="OnNodeTextBoxTextChanged"
                         IsHitTestVisible="{Binding IsSelected}"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <!-- Mindmap Canvas Area -->
    <Panel Grid.Row="0" Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Panel Background="Transparent" 
               Name="MainCanvas"
               ClipToBounds="True"
               Focusable="True"
               PointerPressed="OnCanvasPointerPressed"
               PointerMoved="OnNodePointerMoved"
               PointerReleased="OnNodePointerReleased">
            
            <!-- Background Grid -->
            <Canvas Name="GridCanvas" Background="Transparent" IsHitTestVisible="False">
                <Canvas.RenderTransform>
                    <MatrixTransform />
                </Canvas.RenderTransform>
            </Canvas>

            <Panel Name="TransformCanvas" Background="Transparent" ClipToBounds="False" RenderTransformOrigin="0,0">
                <Panel.RenderTransform>
                    <MatrixTransform />
                </Panel.RenderTransform>
                
                    <ItemsControl ItemsSource="{Binding Edges}" ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent" ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:EdgeViewModel">
                                <Path Stroke="{Binding Color, Converter={StaticResource MindmapColorToBrushConverter}, ConverterParameter=MindmapEdgeStrokeBrush}"
                                      StrokeThickness="1.5"
                                      StrokeDashArray="{Binding Kind, Converter={StaticResource EdgeKindToStrokeDashArrayConverter}}"
                                      IsHitTestVisible="False">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="{Binding StartPoint}" IsClosed="False">
                                                <BezierSegment Point1="{Binding ControlPoint1}"
                                                               Point2="{Binding ControlPoint2}"
                                                               Point3="{Binding EndPoint}"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Nodes}" ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent" ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter" x:DataType="vm:NodeViewModel">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NodeViewModel">
                                <ContentControl Content="{Binding}" 
                                                ContentTemplate="{StaticResource TextNodeTemplate}"
                                                Width="{Binding Width, Converter={StaticResource NullableDoubleToNaNConverter}}"
                                                Height="{Binding Height, Converter={StaticResource NullableDoubleToNaNConverter}}"
                                                PointerPressed="OnNodePointerPressed"
                                                PointerMoved="OnNodePointerMoved"
                                                PointerReleased="OnNodePointerReleased"
                                                SizeChanged="OnNodeSizeChanged"
                                                Background="Transparent"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Panel>
            </Panel>

            <!-- Floating Toolbar -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16" 
                    Background="{DynamicResource CardBackgroundSecondaryBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10" Padding="8" 
                    BoxShadow="{DynamicResource MindmapToolbarBoxShadow}">
                <StackPanel Spacing="6">
                    <!-- Layout -->
                    <TextBlock Text="{markup:T Ns=Mindmap, Key=Layout}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding LayoutAlgorithmIds}"
                              SelectedItem="{Binding SelectedLayoutAlgorithm}"
                              Width="140"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource LayoutAlgorithmToDisplayNameConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Separator Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                    <!-- Edit -->
                    <TextBlock Text="{markup:T Ns=Mindmap, Key=Edit}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,2"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Command="{Binding AddNodeCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=AddNodeTooltip}" Width="36" Height="36" Padding="0" Foreground="{DynamicResource ButtonForegroundBrush}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/circle-plus.svg" Width="18" Height="18" Color="{DynamicResource CardIconColorBrush}"/>
                        </Button>
                        <Button Command="{Binding ConnectSelectedCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ConnectSelectedTooltip}" Width="36" Height="36" Padding="0" Foreground="{DynamicResource ButtonForegroundBrush}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/link.svg" Width="18" Height="18" Color="{DynamicResource CardIconColorBrush}"/>
                        </Button>
                        <Button Command="{Binding DetachSelectedCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=DetachSelectedTooltip}" Width="36" Height="36" Padding="0" Foreground="{DynamicResource ButtonForegroundBrush}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/link-off.svg" Width="18" Height="18" Color="{DynamicResource CardIconColorBrush}"/>
                        </Button>
                        <Button Command="{Binding AutoLayoutCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=AutoLayoutTooltip}" Width="36" Height="36" Padding="0" Foreground="{DynamicResource ButtonForegroundBrush}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/layout.svg" Width="18" Height="18" Color="{DynamicResource CardIconColorBrush}"/>
                        </Button>
                    </StackPanel>
                    <Separator Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                    <!-- View -->
                    <TextBlock Text="{markup:T Ns=Mindmap, Key=View}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,2"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Command="{Binding RecenterCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=RecenterViewTooltip}" Width="36" Height="36" Padding="0" Foreground="{DynamicResource ButtonForegroundBrush}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/home.svg" Width="18" Height="18" Color="{DynamicResource CardIconColorBrush}"/>
                        </Button>
                    </StackPanel>
                    <Separator Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                    <!-- Delete -->
                    <Button Command="{Binding DeleteSelectedCommand}" ToolTip.Tip="{markup:T Ns=Mindmap, Key=DeleteSelectedTooltip}" Width="36" Height="36" Padding="0" Classes="Danger" HorizontalAlignment="Left" Foreground="{DynamicResource DestructiveButtonColorBrush}">
                        <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/x.svg" Width="18" Height="18" Color="{DynamicResource DestructiveButtonColorBrush}"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Node properties panel (when nodes selected) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="15"
                    Background="{DynamicResource CardBackgroundSecondaryBrush}"
                    CornerRadius="8" Padding="10"
                    BoxShadow="{DynamicResource MindmapToolbarBoxShadow}"
                    IsVisible="{Binding HasSelectedNodes}">
                <StackPanel Spacing="8" MinWidth="140">
                    <TextBlock Text="Node style" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="Color" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <WrapPanel>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="{x:Null}" ToolTip.Tip="Theme default" Width="24" Height="24" Padding="0" Margin="0,0,4,4"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2" Fill="{DynamicResource MindmapNodeBorderBrush}"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="#e95b45" Width="24" Height="24" Padding="0" Margin="0,0,4,4" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ColorCoral}" BorderThickness="0" CornerRadius="4">
                            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="#e95b45"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="#2686C2" Width="24" Height="24" Padding="0" Margin="0,0,4,4" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ColorBlue}" BorderThickness="0" CornerRadius="4">
                            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="#2686C2"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="#6DA861" Width="24" Height="24" Padding="0" Margin="0,0,4,4" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ColorGreen}" BorderThickness="0" CornerRadius="4">
                            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="#6DA861"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="#EAB308" Width="24" Height="24" Padding="0" Margin="0,0,4,4" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ColorAmber}" BorderThickness="0" CornerRadius="4">
                            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="#EAB308"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesColorCommand}" CommandParameter="#886ce4" Width="24" Height="24" Padding="0" Margin="0,0,4,4" ToolTip.Tip="{markup:T Ns=Mindmap, Key=ColorPurple}" BorderThickness="0" CornerRadius="4">
                            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="#886ce4"/>
                        </Button>
                    </WrapPanel>
                    <TextBlock Text="{markup:T Ns=Mindmap, Key=Shape}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Command="{Binding SetSelectedNodesShapeCommand}" CommandParameter="rectangle" ToolTip.Tip="{markup:T Ns=Mindmap, Key=Rectangle}" Width="36" Height="36" Padding="0">
                            <Border Width="20" Height="14" CornerRadius="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundPrimaryBrush}"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesShapeCommand}" CommandParameter="pill" ToolTip.Tip="{markup:T Ns=Mindmap, Key=Pill}" Width="36" Height="36" Padding="0">
                            <Border Width="24" Height="14" CornerRadius="7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundPrimaryBrush}"/>
                        </Button>
                        <Button Command="{Binding SetSelectedNodesShapeCommand}" CommandParameter="circle" ToolTip.Tip="{markup:T Ns=Mindmap, Key=Circle}" Width="36" Height="36" Padding="0">
                            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1" Fill="{DynamicResource CardBackgroundPrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Minimap -->
            <Border Name="MinimapBorder" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                    Background="{DynamicResource CardBackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    BoxShadow="{DynamicResource MindmapToolbarBoxShadow}"
                    Width="240" Height="170"
                    ClipToBounds="True"
                    Opacity="0">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="LinearEasing"/>
                    </Transitions>
                </Border.Transitions>

                <Canvas Name="MinimapPanel" ClipToBounds="True" Background="Transparent"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       PointerPressed="OnMinimapPointerPressed"
                       PointerMoved="OnMinimapPointerMoved"
                       PointerReleased="OnMinimapPointerReleased"
                       SizeChanged="OnMinimapSizeChanged">

                    <Panel Name="MinimapTransformPanel" ClipToBounds="False" RenderTransformOrigin="0,0"
                           Canvas.Left="0" Canvas.Top="0">
                        <Panel.RenderTransform>
                            <MatrixTransform />
                        </Panel.RenderTransform>

                        <!-- Dot-grid background texture -->
                        <Canvas Width="240" Height="170" IsHitTestVisible="False">
                            <Canvas.Background>
                                <VisualBrush TileMode="Tile"
                                             SourceRect="0,0,12,12"
                                             DestinationRect="0,0,12,12">
                                    <VisualBrush.Visual>
                                        <Canvas Width="12" Height="12">
                                            <Ellipse Width="1.4" Height="1.4"
                                                     Fill="{DynamicResource BorderBrush}"
                                                     Opacity="0.5"
                                                     Canvas.Left="0.3" Canvas.Top="0.3"/>
                                        </Canvas>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Canvas.Background>
                        </Canvas>

                        <!-- Edges -->
                        <ItemsControl ItemsSource="{Binding Edges}" ClipToBounds="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Background="Transparent" ClipToBounds="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EdgeViewModel">
                                    <Path Stroke="{Binding Color, Converter={StaticResource MindmapColorToBrushConverter}, ConverterParameter=MindmapEdgeStrokeBrush}"
                                          StrokeThickness="3"
                                          StrokeLineCap="Round"
                                          IsHitTestVisible="False">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="{Binding StartPoint}" IsClosed="False">
                                                    <BezierSegment Point1="{Binding ControlPoint1}"
                                                                   Point2="{Binding ControlPoint2}"
                                                                   Point3="{Binding EndPoint}"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Nodes -->
                        <ItemsControl ItemsSource="{Binding Nodes}" ClipToBounds="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Background="Transparent" ClipToBounds="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ItemsControl > ContentPresenter" x:DataType="vm:NodeViewModel">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NodeViewModel">
                                    <Border Width="{Binding Width, TargetNullValue=100}"
                                            Height="{Binding Height, TargetNullValue=40}"
                                            Background="{Binding Color, Converter={StaticResource MindmapColorToBrushConverter}, ConverterParameter=MindmapNodeBorderBrush}"
                                            CornerRadius="{Binding CornerRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}"
                                            Opacity="0.85"
                                            IsHitTestVisible="False"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Panel>

                    <!-- Viewport box -->
                    <Border Name="MinimapViewportBox"
                            Canvas.Left="0" Canvas.Top="0"
                            BorderBrush="{DynamicResource AccentPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#10000000"
                            BoxShadow="0 0 0 1 #18000000, 0 2 8 0 #20000000"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <!-- Top accent strip -->
                        <Border VerticalAlignment="Top"
                                Height="3"
                                CornerRadius="6 6 0 0"
                                Margin="-1 -1 -1 0"
                                Opacity="0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="{DynamicResource AccentPrimary}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <!-- "Minimap" label -->
                    <TextBlock Canvas.Left="10" Canvas.Bottom="8"
                               Text="{markup:T Ns=Mindmap, Key=Minimap}"
                               FontSize="8"
                               FontWeight="SemiBold"
                               LetterSpacing="1.2"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               IsHitTestVisible="False"/>
                </Canvas>
            </Border>

            <!-- Selection Box -->
            <Border Name="SelectionBox" 
                    Background="{DynamicResource AccentPrimaryBrush}" 
                    Opacity="0.2" 
                    BorderBrush="{DynamicResource AccentPrimaryBrush}" 
                    BorderThickness="1" 
                    IsVisible="False" 
                    IsHitTestVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"/>
        </Panel>
    </Grid>
</UserControl>
