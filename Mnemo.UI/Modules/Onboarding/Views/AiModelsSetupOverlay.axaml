<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Mnemo.UI.Modules.Onboarding.Views"
             xmlns:vm="using:Mnemo.UI.Modules.Onboarding.ViewModels"
             xmlns:markup="using:Mnemo.UI.Markup"
             x:Class="Mnemo.UI.Modules.Onboarding.Views.AiModelsSetupOverlay"
             x:DataType="vm:AiModelSetupViewModel">

  <Border Background="{DynamicResource OverlayBackgroundBrush}"
          BorderBrush="{DynamicResource SidebarBorderBrush}"
          BorderThickness="1"
          CornerRadius="12"
          ClipToBounds="True"
          MaxWidth="640"
          MaxHeight="620">
    <Grid RowDefinitions="Auto,Auto,*" Margin="24">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="{markup:T Ns=Settings, Key=AIManagerOverlayTitle}"
                     FontSize="{DynamicResource FontSize.Heading5}"
                     FontFamily="{DynamicResource Font.Bold}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{markup:T Ns=Settings, Key=AIManagerOverlayExperimentalLine}"
                     FontSize="{DynamicResource FontSize.Body.Small}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
        <Button Grid.Column="1"
                Content="{markup:T Ns=Common, Key=Close}"
                VerticalAlignment="Top"
                Classes="Subtle"
                Padding="12,6"
                Click="Close_Click"/>
      </Grid>
      <Separator Grid.Row="1" Height="1" Margin="0,16,0,0"
                 Background="{DynamicResource SidebarBorderBrush}" Opacity="0.5"/>
      <Grid Grid.Row="2" Margin="0,16,0,0" MinHeight="200">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding !IsSetupLoading}">
          <views:AiModelSetupPanel DataContext="{Binding}"/>
        </ScrollViewer>
        <Border Background="{DynamicResource CardBackgroundSecondaryBrush}"
                CornerRadius="8"
                Padding="24"
                IsVisible="{Binding IsSetupLoading}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="16">
            <ProgressBar Width="220"
                         Height="4"
                         IsIndeterminate="True"/>
            <TextBlock Text="{markup:T Ns=Settings, Key=AIManagerLoadingMessage}"
                       FontSize="{DynamicResource FontSize.Body.Small}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Border>
</UserControl>
