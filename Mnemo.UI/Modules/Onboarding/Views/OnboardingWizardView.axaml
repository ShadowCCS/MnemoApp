<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Onboarding.ViewModels"
             xmlns:settings="using:Mnemo.UI.Modules.Settings.ViewModels"
             xmlns:components="using:Mnemo.UI.Components"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:converters="using:Mnemo.UI.Converters"
             x:Class="Mnemo.UI.Modules.Onboarding.Views.OnboardingWizardView"
             x:DataType="vm:OnboardingWizardViewModel">

  <UserControl.Resources>
    <converters:PathToImageConverter x:Key="PathToImageConverter"/>
  </UserControl.Resources>

  <Border Background="{DynamicResource CardBackgroundBrush}"
          BorderBrush="{DynamicResource SidebarBorderBrush}"
          BorderThickness="1"
          CornerRadius="12"
          ClipToBounds="True"
          Width="820"
          Height="560">
    <Grid ColumnDefinitions="300,*">
      
      <!-- LEFT PANE: Context & Navigation Dots -->
      <Border Grid.Column="0" Background="{DynamicResource CardBackgroundSecondaryBrush}">
        <Grid RowDefinitions="*,Auto" Margin="32">
          <!-- Content: Vertically Centered -->
          <StackPanel Grid.Row="0" Spacing="16" VerticalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="{DynamicResource CardAccentBrush}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
              <controls:SvgIcon SvgPath="avares://Mnemo.UI/Assets/Branding/logo_icon.svg"
                                Color="White" Width="28" Height="28"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{Binding StepTitle}"
                       FontSize="{DynamicResource FontSize.Heading4}"
                       FontFamily="{DynamicResource Font.Bold}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding StepDescription}"
                       FontSize="{DynamicResource FontSize.Body.Small}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <!-- Version: only on welcome step, left pane -->
            <TextBlock Text="{Binding VersionText, StringFormat='Version {0}'}"
                       FontSize="{DynamicResource FontSize.Body.ExtraSmall}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding IsWelcomeStep}"/>
          </StackPanel>

          <!-- Dots: Bottom Left -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
            <!-- Step 1 -->
            <Ellipse Width="8" Height="8" Fill="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding !IsWelcomeStep}"/>
            <Ellipse Width="8" Height="8" Fill="{DynamicResource CardAccentBrush}"
                     IsVisible="{Binding IsWelcomeStep}"/>
            
            <!-- Step 2 -->
            <Ellipse Width="8" Height="8" Fill="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding !IsPersonalizationStep}"/>
            <Ellipse Width="8" Height="8" Fill="{DynamicResource CardAccentBrush}"
                     IsVisible="{Binding IsPersonalizationStep}"/>
            
            <!-- Step 3 -->
            <Ellipse Width="8" Height="8" Fill="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding !IsAISetupStep}"/>
            <Ellipse Width="8" Height="8" Fill="{DynamicResource CardAccentBrush}"
                     IsVisible="{Binding IsAISetupStep}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- RIGHT PANE: Interactive Content & Buttons -->
      <Border Grid.Column="1" Background="{DynamicResource OverlayBackgroundBrush}">
        <Grid RowDefinitions="*,Auto" Margin="32,32,32,32">
          <!-- Welcome: full-area centered showcase image -->
          <Grid Grid.Row="0" IsVisible="{Binding IsWelcomeStep}">
            <Image Source="avares://Mnemo.UI/Modules/Onboarding/Assets/showcase.png"
                   Stretch="Uniform"
                   MaxWidth="480"
                   MaxHeight="320"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
          </Grid>

          <!-- Other steps: scrollable content -->
          <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !IsWelcomeStep}">
            <StackPanel Spacing="20">
              <!-- Personalization -->
              <StackPanel IsVisible="{Binding IsPersonalizationStep}" Spacing="16">
                <TextBlock Text="Your name"
                           FontSize="{DynamicResource FontSize.Label}"
                           FontFamily="{DynamicResource Font.Medium}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBox Text="{Binding UserName}"
                         Watermark="Enter your name"
                         Padding="12,10"
                         FontSize="{DynamicResource FontSize.Input}"/>

                <TextBlock Text="{Binding ThemeSettingViewModel.Title}"
                           FontSize="{DynamicResource FontSize.Label}"
                           FontFamily="{DynamicResource Font.Medium}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ItemsControl ItemsSource="{Binding ThemeSettingViewModel.Options}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:ThemeOptionViewModel">
                      <Button Command="{Binding SelectCommand}" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Border Width="56" Height="42" CornerRadius="8" BorderThickness="2"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                Classes.selected="{Binding IsSelected}">
                          <Border.Styles>
                            <Style Selector="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                            <Style Selector="Border.selected">
                              <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
                            </Style>
                          </Border.Styles>
                          <Border CornerRadius="6" ClipToBounds="True" Margin="2">
                            <Grid ColumnDefinitions="*,*,*">
                              <Border Grid.Column="0" Background="{Binding PreviewColors[0]}"/>
                              <Border Grid.Column="1" Background="{Binding PreviewColors[1]}"/>
                              <Border Grid.Column="2" Background="{Binding PreviewColors[2]}"/>
                            </Grid>
                          </Border>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding AppIconSettingViewModel.Title}"
                           FontSize="{DynamicResource FontSize.Label}"
                           FontFamily="{DynamicResource Font.Medium}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ItemsControl ItemsSource="{Binding AppIconSettingViewModel.Options}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:AppIconOptionViewModel">
                      <Button Command="{Binding SelectCommand}" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Border Width="42" Height="42" CornerRadius="8" ClipToBounds="True" BorderThickness="2"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                Classes.selected="{Binding IsSelected}">
                          <Border.Styles>
                            <Style Selector="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                            <Style Selector="Border.selected">
                              <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
                            </Style>
                          </Border.Styles>
                          <Image Source="{Binding IconPath, Converter={StaticResource PathToImageConverter}}"
                                 Width="32" Height="32" Margin="4" Stretch="Uniform"/>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding ProfilePictureSettingViewModel.Title}"
                           FontSize="{DynamicResource FontSize.Label}"
                           FontFamily="{DynamicResource Font.Medium}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ItemsControl ItemsSource="{Binding ProfilePictureSettingViewModel.Options}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:ProfilePictureOptionViewModel">
                      <Button Command="{Binding SelectCommand}" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Border Width="42" Height="42" CornerRadius="21" ClipToBounds="True" BorderThickness="2"
                                Background="{DynamicResource CardBackgroundSecondaryBrush}"
                                Classes.selected="{Binding IsSelected}">
                          <Border.Styles>
                            <Style Selector="Border">
                              <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                            <Style Selector="Border.selected">
                              <Setter Property="BorderBrush" Value="{DynamicResource CardAccentBrush}"/>
                            </Style>
                          </Border.Styles>
                          <Image Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}}"
                                 Stretch="UniformToFill"/>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- AI setup -->
              <StackPanel IsVisible="{Binding IsAISetupStep}" Spacing="24" VerticalAlignment="Center">
                <!-- Hero Icon Replacement -->
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="{DynamicResource CardBackgroundSecondaryBrush}"
                        HorizontalAlignment="Center">
                  <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/sparkles-2.svg"
                                    Color="{DynamicResource CardAccentBrush}"
                                    Width="56" Height="56"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                </Border>

                <StackPanel Spacing="12" HorizontalAlignment="Center">
                  <Button Content="Download models"
                          Command="{Binding DownloadModelsCommand}"
                          IsEnabled="{Binding !IsDownloading}"
                          IsVisible="{Binding !IsDownloadComplete}"
                          Padding="24,10"
                          HorizontalAlignment="Center"/>
                  
                  <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="1"
                               IsVisible="{Binding IsDownloading}"
                               Width="240" Height="6"/>
                  
                  <TextBlock Text="{Binding DownloadStatusMessage}"
                             FontSize="{DynamicResource FontSize.Body.Small}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextAlignment="Center"
                             IsVisible="{Binding IsDownloading}"/>
                  
                  <TextBlock Text="{Binding DownloadError}"
                             FontSize="{DynamicResource FontSize.Body.Small}"
                             Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                             TextAlignment="Center"
                             IsVisible="{Binding ShowDownloadError}"/>
                  
                  <TextBlock Text="{Binding DownloadStatusMessage}"
                             FontSize="{DynamicResource FontSize.Body.Medium}"
                             FontFamily="{DynamicResource Font.Medium}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             TextAlignment="Center"
                             IsVisible="{Binding IsDownloadComplete}"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <!-- Buttons: Bottom Right -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Back" Command="{Binding BackCommand}"
                    IsVisible="{Binding !IsFirstStep}"
                    Classes="Subtle" Padding="16,10"/>
            <Button Content="{Binding NextButtonText}" Command="{Binding NextCommand}"
                    Padding="16,10"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
