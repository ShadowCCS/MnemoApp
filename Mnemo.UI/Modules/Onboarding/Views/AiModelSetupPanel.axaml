<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mnemo.UI.Modules.Onboarding.ViewModels"
             xmlns:controls="using:Mnemo.UI.Controls"
             xmlns:markup="using:Mnemo.UI.Markup"
             x:Class="Mnemo.UI.Modules.Onboarding.Views.AiModelSetupPanel"
             x:DataType="vm:AiModelSetupViewModel">

  <StackPanel Spacing="16">
    <Border Width="120" Height="120" CornerRadius="60"
            Background="{DynamicResource CardBackgroundSecondaryBrush}"
            HorizontalAlignment="Center">
      <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Filled/sparkles-2.svg"
                        Color="{DynamicResource CardAccentBrush}"
                        Width="56" Height="56"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
    </Border>

    <TextBlock Text="{Binding HardwareTierDescription}"
               FontSize="{DynamicResource FontSize.Body.Small}"
               Foreground="{DynamicResource TextSecondaryBrush}"
               TextWrapping="Wrap"/>

    <StackPanel Spacing="4">
      <TextBlock Text="{markup:T Ns=Onboarding, Key=DetectedInstalledLabel}"
                 FontFamily="{DynamicResource Font.Medium}"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>
      <TextBlock Text="{Binding InstalledSummary}"
                 FontSize="{DynamicResource FontSize.Body.Small}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel Spacing="4">
      <TextBlock Text="{markup:T Ns=Onboarding, Key=RequiredMissingLabel}"
                 FontFamily="{DynamicResource Font.Medium}"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>
      <TextBlock Text="{Binding RequiredMissingSummary}"
                 FontSize="{DynamicResource FontSize.Body.Small}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <TextBlock Text="{Binding TransparencyText}"
               FontSize="{DynamicResource FontSize.Body.Small}"
               Foreground="{DynamicResource TextSecondaryBrush}"
               TextWrapping="Wrap"/>

    <StackPanel Spacing="4" IsVisible="{Binding ShowVisionOption}">
      <CheckBox IsChecked="{Binding IncludeVisionBundle}"
                Content="{Binding VisionOptionDescription}"/>
    </StackPanel>

    <TextBlock Text="{Binding EstimatedDownloadText}"
               FontSize="{DynamicResource FontSize.Body.Small}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               TextWrapping="Wrap"/>

    <Button Content="{markup:T Ns=Onboarding, Key=DownloadModels}"
            Command="{Binding DownloadModelsCommand}"
            IsEnabled="{Binding !IsDownloading}"
            IsVisible="{Binding ShowDownloadButton}"
            Padding="24,10"
            HorizontalAlignment="Center"/>

    <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="1"
                 IsVisible="{Binding IsDownloading}"
                 Width="240" Height="6"
                 HorizontalAlignment="Center"/>

    <TextBlock Text="{Binding DownloadStatusMessage}"
               FontSize="{DynamicResource FontSize.Body.Small}"
               Foreground="{DynamicResource TextSecondaryBrush}"
               TextAlignment="Center"
               IsVisible="{Binding IsDownloading}"
               TextWrapping="Wrap"/>

    <TextBlock Text="{Binding DownloadError}"
               FontSize="{DynamicResource FontSize.Body.Small}"
               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
               TextAlignment="Center"
               IsVisible="{Binding ShowDownloadError}"
               TextWrapping="Wrap"/>

    <TextBlock Text="{Binding DownloadStatusMessage}"
               FontSize="{DynamicResource FontSize.Body.Medium}"
               FontFamily="{DynamicResource Font.Medium}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               TextAlignment="Center"
               IsVisible="{Binding IsDownloadComplete}"
               TextWrapping="Wrap"/>
  </StackPanel>
</UserControl>
