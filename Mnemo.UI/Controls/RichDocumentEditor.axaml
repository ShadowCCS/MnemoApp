<UserControl
    x:Class="Mnemo.UI.Controls.RichDocumentEditor"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:blockEditor="using:Mnemo.UI.Components.BlockEditor"
    xmlns:components="using:Mnemo.UI.Components"
    xmlns:controls="using:Mnemo.UI.Controls"
    xmlns:conv="using:Mnemo.UI.Converters">
    <UserControl.Resources>
        <conv:LocalPathToBitmapConverter x:Key="LocalPathToBitmapConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Active alignment indicator for image panel buttons -->
        <Style Selector="Button.img-align.selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
        </Style>
        <Style Selector="Button.img-align.selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.SemiBold}" />
        </Style>
    </UserControl.Styles>

    <Border
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Grid RowDefinitions="Auto,*">

            <!-- ── Toolbar ───────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                        <Button x:Name="BoldButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnBoldClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/FormattingToolbar/bold.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="ItalicButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnItalicClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/FormattingToolbar/italic.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="UnderlineButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnUnderlineClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/FormattingToolbar/underline.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="StrikethroughButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnStrikethroughClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/FormattingToolbar/strikethrough.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="HighlightButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnHighlightClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/FormattingToolbar/highlighter.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="LinkButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnLinkClick"
                                IsEnabled="{Binding IsToolbarEnabled, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/link.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                        <Button x:Name="ImageButton"
                                Classes="ghost"
                                Padding="8,6"
                                Click="OnImageClick"
                                IsVisible="{Binding ShowImageButton, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                IsEnabled="{Binding CanInsertImage, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                            <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/photo.svg"
                                              Width="16" Height="16"
                                              Color="{DynamicResource TextPrimaryBrush}" />
                        </Button>
                    </StackPanel>
                    <Border Grid.Column="2"
                            IsVisible="{Binding ShowModeToggle, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                            Background="{DynamicResource WidgetBackgroundPrimaryBrush}"
                            CornerRadius="8"
                            Padding="3">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Button x:Name="WriteModeButton"
                                    Classes="fc-pill-segment selected"
                                    Padding="10,5"
                                    Click="OnWriteModeClick">
                                <TextBlock Text="{Binding WriteLabel, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}" />
                            </Button>
                            <Button x:Name="PreviewModeButton"
                                    Classes="fc-pill-segment"
                                    Padding="10,5"
                                    Click="OnPreviewModeClick">
                                <TextBlock Text="{Binding PreviewLabel, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Content area ──────────────────────────────────────────── -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*">

                <!-- ── Image panel (shown when images exist) ─────────────── -->
                <Border Grid.Row="0"
                        Margin="12,10,12,0"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource WidgetBackgroundPrimaryBrush}"
                        IsVisible="{Binding HasImages, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}">
                    <StackPanel Spacing="0">

                        <!-- Image display -->
                        <Image MaxHeight="160"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Margin="8,8,8,4"
                               Source="{Binding CurrentImagePath, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}, Converter={StaticResource LocalPathToBitmapConverter}}" />

                        <!-- Controls bar: [prev  count  next]   [Left Center Right]   [🗑] -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Margin="8,0,8,6"
                              VerticalAlignment="Center">

                            <!-- Carousel navigation -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <Button Classes="ghost"
                                        Padding="4,2"
                                        IsEnabled="{Binding CanGoToPreviousImage, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                        Click="OnPreviousImageClick">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-left.svg"
                                                      Width="13" Height="13"
                                                      Color="{DynamicResource TextSecondaryBrush}" />
                                </Button>
                                <TextBlock Text="{Binding ImageCountLabel, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           IsVisible="{Binding HasMultipleImages, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}" />
                                <Button Classes="ghost"
                                        Padding="4,2"
                                        IsEnabled="{Binding CanGoToNextImage, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                        Click="OnNextImageClick">
                                    <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/chevron-right.svg"
                                                      Width="13" Height="13"
                                                      Color="{DynamicResource TextSecondaryBrush}" />
                                </Button>
                            </StackPanel>

                            <!-- Alignment buttons -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Classes="ghost img-align"
                                        Classes.selected="{Binding IsCurrentImageAlignLeft, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                        Padding="6,2"
                                        Click="OnAlignLeftClick">
                                    <TextBlock Text="Left" FontSize="11" />
                                </Button>
                                <Button Classes="ghost img-align"
                                        Classes.selected="{Binding IsCurrentImageAlignCenter, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                        Padding="6,2"
                                        Click="OnAlignCenterClick">
                                    <TextBlock Text="Center" FontSize="11" />
                                </Button>
                                <Button Classes="ghost img-align"
                                        Classes.selected="{Binding IsCurrentImageAlignRight, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                        Padding="6,2"
                                        Click="OnAlignRightClick">
                                    <TextBlock Text="Right" FontSize="11" />
                                </Button>
                            </StackPanel>

                            <!-- Delete current image -->
                            <Button Grid.Column="2"
                                    Classes="ghost"
                                    Padding="4,2"
                                    VerticalAlignment="Center"
                                    Click="OnDeleteImageClick">
                                <controls:SvgIcon SvgPath="avares://Mnemo.UI/Icons/Tabler/Used/Outlined/trashbin.svg"
                                                  Width="13" Height="13"
                                                  Color="{DynamicResource TextSecondaryBrush}" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Editor / Preview ───────────────────────────────────── -->
                <!-- PreviewHost must be declared before Editor so the editor is z-ordered
                     above when both share the same grid cell. -->
                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="PreviewHost"
                                  Margin="12,10"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="False"
                                  IsHitTestVisible="False">
                        <components:MarkdownView Source="{Binding PreviewMarkdown, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}" />
                    </ScrollViewer>
                    <blockEditor:RichTextEditor x:Name="Editor"
                                                Margin="12,10"
                                                Cursor="Ibeam"
                                                Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                                IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=controls:RichDocumentEditor}}"
                                                ShowInlineEquationSourceOnHover="True"
                                                TextChanged="OnEditorTextChanged"
                                                KeyDown="OnEditorKeyDown" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
