{
  "tools": [
    {
      "name": "list_mindmaps",
      "description": "Lists mindmaps. Optional search: keywords on title (OR); fuzzy (default true); limit caps results.",
      "parameters": {
        "type": "object",
        "properties": {
          "search": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
          "fuzzy": { "type": "boolean" }
        }
      },
      "enabled": true
    },
    {
      "name": "read_mindmap",
      "description": "Returns layout_algorithm, nodes (layout, color, shape, collapsed), edges (kind, type), counts.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" }
        },
        "required": ["mindmap_id"]
      },
      "enabled": true
    },
    {
      "name": "create_mindmap",
      "description": "Creates a mindmap. Optional root_label. Optional nodes[] to add many nodes in one call (parent_node_id or parent_index for hierarchy within the batch).",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "root_label": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "parent_node_id": { "type": "string" },
                "parent_index": { "type": "integer" },
                "color": { "type": "string" },
                "shape": { "type": "string", "enum": ["rectangle", "pill", "circle"] }
              },
              "required": ["label"]
            }
          }
        },
        "required": ["title"]
      },
      "enabled": true
    },
    {
      "name": "add_nodes",
      "description": "Adds one or more text nodes in one call. parent_node_id attaches to an existing node; parent_index refers to an earlier entry in this nodes array (0-based). Optional color/shape per node.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "parent_node_id": { "type": "string" },
                "parent_index": { "type": "integer" },
                "color": { "type": "string" },
                "shape": { "type": "string", "enum": ["rectangle", "pill", "circle"] }
              },
              "required": ["label"]
            }
          }
        },
        "required": ["mindmap_id", "nodes"]
      },
      "enabled": true
    },
    {
      "name": "connect_nodes",
      "description": "Creates a link edge between two existing nodes with optional label.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" },
          "source_node_id": { "type": "string" },
          "target_node_id": { "type": "string" },
          "label": { "type": "string" }
        },
        "required": ["mindmap_id", "source_node_id", "target_node_id"]
      },
      "enabled": true
    },
    {
      "name": "style_nodes",
      "description": "Style nodes: pass node_ids for explicit list, OR subtree_of to style all hierarchy descendants of that node (include_anchor optional). Sets color, shape, and/or collapsed.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" },
          "node_ids": { "type": "array", "items": { "type": "string" } },
          "subtree_of": { "type": "string" },
          "include_anchor": { "type": "boolean" },
          "color": { "type": "string" },
          "shape": { "type": "string", "enum": ["rectangle", "pill", "circle"] },
          "collapsed": { "type": "boolean" }
        },
        "required": ["mindmap_id"]
      },
      "enabled": true
    },
    {
      "name": "apply_layout",
      "description": "Recomputes positions from hierarchy edges: TreeVertical, TreeHorizontal, or Radial.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" },
          "layout_algorithm": {
            "type": "string",
            "enum": ["TreeVertical", "TreeHorizontal", "Radial"]
          }
        },
        "required": ["mindmap_id"]
      },
      "enabled": true
    },
    {
      "name": "open_mindmap",
      "description": "Opens the mindmap editor for the given mindmap id.",
      "parameters": {
        "type": "object",
        "properties": {
          "mindmap_id": { "type": "string" }
        },
        "required": ["mindmap_id"]
      },
      "enabled": true
    }
  ]
}
